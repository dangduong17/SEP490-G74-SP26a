@model RJMS.vn.edu.fpt.Models.DTOs.UpdateJobCategoryModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var possibleParents = ViewBag.PossibleParents as List<RJMS.vn.edu.fpt.Models.DTOs.JobCategoryViewModel>;
}

<div class="card border-0 shadow-sm" style="max-width: 600px; margin: 0 auto;">
    <div class="card-body p-4">
        <form asp-action="EditJobCategory" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Level" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Cấp độ danh mục</label>
                <input type="text" class="form-control" readonly 
                    value="@(Model.Level == 1 ? "Nhóm nghề (Cấp 1)" : Model.Level == 2 ? "Nghề nghiệp (Cấp 2)" : "Vị trí chuyên môn (Cấp 3)")" />
                <small class="text-muted">Không thể thay đổi cấp độ sau khi đã tạo.</small>
            </div>

            @if (Model.Level > 1)
            {
                <div class="mb-3">
                    <label asp-for="ParentId" class="form-label fw-bold">Danh mục cha (Cấp @(Model.Level - 1)) <span class="text-danger">*</span></label>
                    <select asp-for="ParentId" class="form-select" required>
                        <option value="">-- Chọn danh mục cha --</option>
                        @if (possibleParents != null)
                        {
                            foreach(var p in possibleParents)
                            {
                                if (Model.ParentId == p.Id)
                                {
                                    <option value="@p.Id" selected>@p.Name</option>
                                }
                                else
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            }
                        }
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger small"></span>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Slug" class="form-label fw-bold">Chuỗi URL (Slug)</label>
                <input asp-for="Slug" class="form-control" placeholder="tu-dong-tao-neu-de-trong" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="JobCategoryList" class="btn btn-outline-secondary w-50">Hủy bỏ</a>
                <button type="submit" class="btn btn-success w-50" style="background-color: #00b14f; border-color: #00b14f;">
                    <i class="fas fa-save me-1"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
