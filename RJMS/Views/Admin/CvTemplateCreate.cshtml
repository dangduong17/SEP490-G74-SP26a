@{
    ViewData["Title"] = "Tạo CV Template";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&family=Roboto:wght@400;500;700&family=Lora:wght@400;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/cv-editor.css?v=2" />
}

<form id="tplForm" method="post" action="@Url.Action("CvTemplateCreate","Admin")">
  <input type="hidden" name="configJson" id="cfgOut"/>
  <input type="hidden" name="name"       id="nameOut"/>
  <input type="hidden" name="categoryId" id="catOut"/>

<div class="shell">
<header class="topbar">
  <span class="logo">Finding Job</span>
  <span class="sep"></span>
  <input class="name-input" id="tplName" type="text" placeholder="Nhập tên template..." required style="border:1.5px solid #e5e7eb;background:#fff"/>
  <div class="topbar-r">
    <a href="@Url.Action("CvTemplates","Admin")" class="btn-ghost">← Quay lại</a>
    <button type="button" class="btn-green" onclick="saveTemplate()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Lưu Template
    </button>
  </div>
</header>

<div class="body">
<aside class="palette">
  <div class="pal-head">Các mục CV</div>
  <div class="pal-section-head">Chưa dùng</div>
  <div class="pal-list" id="palette-unused">
    <div class="pal-chip" draggable="true" data-type="header">Thông tin chính</div>
    <div class="pal-chip" draggable="true" data-type="vcard">Danh thiếp</div>
    <div class="pal-chip" draggable="true" data-type="contact">Liên hệ</div>
    <div class="pal-chip" draggable="true" data-type="summary">Mục tiêu NN</div>
    <div class="pal-chip" draggable="true" data-type="experience">Kinh nghiệm LV</div>
    <div class="pal-chip" draggable="true" data-type="education">Học vấn</div>
    <div class="pal-chip" draggable="true" data-type="skills">Kỹ năng</div>
    <div class="pal-chip" draggable="true" data-type="projects">Dự án</div>
    <div class="pal-chip" draggable="true" data-type="awards">Giải thưởng</div>
    <div class="pal-chip" draggable="true" data-type="certs">Chứng chỉ</div>
    <div class="pal-chip" draggable="true" data-type="activities">Hoạt động</div>
    <div class="pal-chip" draggable="true" data-type="refs">Người tham chiếu</div>
    <div class="pal-chip" draggable="true" data-type="hobbies">Sở thích</div>
    <div class="pal-chip" draggable="true" data-type="extra">Thông tin thêm</div>
  </div>
  <div class="pal-div"></div>
  <div class="pal-section-head" id="used-head" style="display:none">Đã dùng</div>
  <div class="pal-list" id="palette-used"></div>
  <div class="pal-div"></div>
  <div class="pal-sect">
    <label class="pal-lbl">Danh mục template</label>
    <select class="pal-sel" id="tplCat">
      <option value="">-- Chọn danh mục --</option>
      @if (ViewBag.Categories != null)
      {
          foreach (var c in (List<RJMS.vn.edu.fpt.Models.DTOs.TemplateCategoryViewModel>)ViewBag.Categories)
          {
              <option value="@c.Id">@c.Name</option>
          }
      }
    </select>
  </div>
</aside>

<main class="canvas" id="canvas"></main>

<aside class="right-panel">
  <div class="rp-head">Cài đặt & Giao diện</div>
  <div class="pg-info" id="pgInfo">Trang 1 đang chọn</div>
  <div class="rp-info-box">📐 Freeform Layout<br/><span style="font-weight:400">Kéo thả từ panel trái vào A4. Kéo cạnh/góc để resize.</span></div>

  <label class="rp-lbl">Font chữ</label>
  <select class="rp-sel" id="fontSel" onchange="applyTheme()">
    <option value="Inter">Inter (Modern)</option>
    <option value="Be Vietnam Pro">Be Vietnam Pro</option>
    <option value="Roboto">Roboto</option>
    <option value="Open Sans">Open Sans</option>
    <option value="Lora">Lora (Serif)</option>
  </select>

  <label class="rp-lbl">Màu chủ đạo</label>
  <div class="color-r">
    <input type="color" id="colorPick" value="#2563eb" oninput="applyTheme()"/>
    <span class="color-h" id="colorHex">#2563eb</span>
  </div>

  <div class="rp-div"></div>
  <p class="rp-hint">💡 Kéo từ panel trái thả vào vùng A4 giữa.<br/><br/>⠿ Kéo thanh đen để di chuyển section.<br/><br/>⧉ Nhân đôi section để tạo nhiều mục cùng loại.</p>
</aside>
</div>
</div>
</form>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/interactjs@1.10.27/dist/interact.min.js"></script>
<script type="module">
  import { Editor } from 'https://esm.sh/@@tiptap/core@2';
  import StarterKit from 'https://esm.sh/@@tiptap/starter-kit@2';
  import Underline from 'https://esm.sh/@@tiptap/extension-underline@2';
  window.tiptap = { Editor, StarterKit, Underline };
  document.dispatchEvent(new Event('tiptap-ready'));
</script>
<script src="~/js/cv-editor-shared.js"></script>
<script>
let pages = [{ columns: 0, sections: [] }];
let activePg = 0;

function _cvEditorInit() {
  setupPaletteDrag();
  renderCanvas();
  applyTheme();
  initTiptapFloating();
}
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', _cvEditorInit);
} else {
  _cvEditorInit();
}

function applyTheme() {
  const c = document.getElementById('colorPick').value;
  document.getElementById('colorHex').textContent = c;
  const font = document.getElementById('fontSel').value;
  applyThemeToCanvas(c, font);
}

function refreshPalette() {
  const usedCounts = {};
  pages.forEach(p => p.sections.forEach(s => { usedCounts[s.type] = (usedCounts[s.type] || 0) + 1; }));
  const unusedList = document.getElementById('palette-unused');
  const usedList = document.getElementById('palette-used');
  const usedHead = document.getElementById('used-head');
  if (!unusedList || !usedList) return;
  const allChips = Array.from(document.querySelectorAll('#palette-unused .pal-chip, #palette-used .pal-chip'));
  allChips.forEach(chip => {
    const type = chip.dataset.type;
    if (usedCounts[type] > 0) usedList.appendChild(chip);
    else unusedList.appendChild(chip);
  });
  if (usedHead) usedHead.style.display = usedList.children.length > 0 ? '' : 'none';
}

function setupPaletteDrag() {
  document.querySelectorAll('#palette-unused .pal-chip, #palette-used .pal-chip').forEach(chip => {
    chip.addEventListener('dragstart', e => e.dataTransfer.setData('sectype', chip.dataset.type));
  });
}

function bindDroppable() {
  document.querySelectorAll('.a4').forEach((a4, pi) => {
    a4.ondragover = e => { e.preventDefault(); a4.classList.add('dragover'); };
    a4.ondragleave = () => a4.classList.remove('dragover');
    a4.ondrop = e => {
      e.preventDefault(); a4.classList.remove('dragover');
      const type = e.dataTransfer.getData('sectype');
      if (!type) return;
      const rect = a4.getBoundingClientRect();
      addSecAt(pi, type, e.clientX - rect.left, e.clientY - rect.top);
    };
  });
}

function syncPageDom(pi) {
  const a4 = document.querySelector(`.a4[data-page="${pi}"]`);
  if (!a4) return;
  pages[pi].sections = Array.from(a4.querySelectorAll('.cv-sec')).map(el => ({
    type: el.dataset.type,
    top: parseFloat(el.style.top) || 0,
    left: parseFloat(el.style.left) || 0,
    width: parseFloat(el.style.width) || 300,
    height: parseFloat(el.style.height) || 100
  }));
  refreshPalette();
}

function removeSec(el) {
  const pi = el.dataset.page;
  el.remove();
  syncPageDom(pi);
}

function dupSec(el) {
  const pi = parseInt(el.dataset.page);
  const type = el.dataset.type;
  const top = (parseFloat(el.style.top) || 0) + 20;
  const left = (parseFloat(el.style.left) || 0) + 20;
  const width = parseFloat(el.style.width) || SEC[type]?.defaultW || 350;
  const height = parseFloat(el.style.height) || SEC[type]?.defaultH || 150;
  const sec = { type, top, left, width, height };
  pages[pi].sections.push(sec);
  const newEl = buildSectionEl(sec, pi, 'admin');
  if (!newEl) return;
  document.querySelector(`.a4[data-page="${pi}"]`).appendChild(newEl);
  applyTheme();
}

function addSecAt(pi, type, x, y) {
  if (SEC[type]?.singleton && pages.flatMap(p => p.sections).some(s => s.type === type)) return;
  const def = SEC[type];
  if (!def) return;
  const sec = { type, top: Math.max(0, y - 20), left: Math.max(0, x - def.defaultW / 2), width: def.defaultW, height: def.defaultH };
  pages[pi].sections.push(sec);
  const el = buildSectionEl(sec, pi, 'admin');
  if (!el) return;
  const a4 = document.querySelector(`.a4[data-page="${pi}"]`);
  a4.appendChild(el);
  applyTheme();
  refreshPalette();
}

initInteract(
  (target) => syncPageDom(target.dataset.page),
  (target) => syncPageDom(target.dataset.page)
);

function renderCanvas() {
  const cvs = document.getElementById('canvas');
  cvs.innerHTML = '';
  const font = document.getElementById('fontSel').value;

  pages.forEach((pg, pi) => {
    const bar = div('pg-bar');
    bar.innerHTML = `<span>Trang ${pi + 1}</span>` +
      (pages.length > 1 ? `<button type="button" class="pg-rm-btn" onclick="removePg(${pi})">✕ Xoá trang</button>` : '');

    const a4 = div('a4');
    a4.className = 'a4 selected';
    a4.dataset.page = pi;
    a4.style.fontFamily = `'${font}', sans-serif`;
    a4.addEventListener('click', () => selectPg(pi));

    pg.sections.forEach(s => {
      const el = buildSectionEl(s, pi, 'admin');
      if (el) a4.appendChild(el);
    });

    const wrap = div('pgwrap');
    wrap.appendChild(bar); wrap.appendChild(a4);
    cvs.appendChild(wrap);
  });

  if (pages.length < 2) {
    const ab = document.createElement('button');
    ab.type = 'button'; ab.className = 'add-pg-btn';
    ab.textContent = '+ Thêm trang 2'; ab.onclick = addPg;
    cvs.appendChild(ab);
  }

  selectPg(activePg);
  bindDroppable();
  refreshPalette();
  applyTheme();
}

function addPg() { if (pages.length >= 2) return; pages.push({ columns: 0, sections: [] }); activePg = pages.length - 1; renderCanvas(); }
function removePg(pi) { if (pages.length <= 1) return; pages.splice(pi, 1); activePg = Math.min(activePg, pages.length - 1); renderCanvas(); }
function selectPg(pi) {
  activePg = pi;
  document.querySelectorAll('.a4').forEach((el, i) => el.classList.toggle('selected', i === pi));
  document.getElementById('pgInfo').textContent = `Trang ${pi + 1} đang chọn`;
}

function saveTemplate() {
  const name = document.getElementById('tplName').value.trim();
  if (!name) { document.getElementById('tplName').focus(); return; }
  pages.forEach((_, pi) => syncPageDom(pi));
  const config = {
    pages,
    theme: { primaryColor: document.getElementById('colorPick').value, font: document.getElementById('fontSel').value }
  };
  document.getElementById('nameOut').value = name;
  document.getElementById('catOut').value = document.getElementById('tplCat').value;
  document.getElementById('cfgOut').value = JSON.stringify(config);
  document.getElementById('tplForm').submit();
}
</script>
}
