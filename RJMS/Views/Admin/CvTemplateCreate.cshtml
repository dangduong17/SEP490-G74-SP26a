@{
    ViewData["Title"] = "Tạo CV Template";
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; // Utilize admin layout
}

<div class="row pt-4">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="mb-0 fw-bold" style="color: #2563eb;">
                    Tạo Block Template Mới
                </h4>
                <p class="text-muted small mt-1">Cấu hình giao diện CV bằng các block động</p>
            </div>
            
            <div class="card-body p-4">
                <form id="templateForm" method="post" action="@Url.Action("CvTemplateCreate", "Admin")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="configJson" id="configJson" />
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary">Tên Template</label>
                            <input type="text" name="name" class="form-control form-control-lg bg-light border-0" id="name" required placeholder="Nhập tên..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary">Danh mục</label>
                            <select name="categoryId" class="form-select form-select-lg bg-light border-0" id="categoryId">
                                <option value="">-- Chọn danh mục --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var c in (List<RJMS.vn.edu.fpt.Models.DTOs.TemplateCategoryViewModel>)ViewBag.Categories)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary">Bố cục cơ bản</label>
                            <select class="form-select bg-light border-0" id="layoutDef">
                                <option value="one-column">Một cột truyền thống (Hiện đại)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-secondary">Font chữ</label>
                            <select class="form-select bg-light border-0" id="fontDef">
                                <option value="Inter">Inter (Khuyên dùng)</option>
                                <option value="Roboto">Roboto</option>
                                <option value="Open Sans">Open Sans</option>
                                <option value="Segoe UI">Segoe UI</option>
                                <option value="Lora">Lora (Cổ điển)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-secondary">Màu chủ đạo</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="color" class="form-control form-control-color border-0 p-1" id="primaryColor" value="#2563eb" title="Chọn màu chủ đạo" style="width: 60px; height: 40px; cursor: pointer;">
                            <span class="text-muted small">Màu nổi bật cho tiêu đề, viền và điểm nhấn</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold text-secondary d-block mb-3">Các thành phần (Blocks)</label>
                        
                        <div class="row row-cols-1 row-cols-sm-2 g-3">
                            <div class="col">
                                <div class="form-check p-3 border rounded bg-light disabled">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" value="header" checked disabled id="chkHeader">
                                    <label class="form-check-label fw-medium" for="chkHeader">
                                        <i class="fas fa-heading text-primary me-2"></i> Header (Bắt buộc)
                                    </label>
                                </div>
                            </div>
                            
                            <div class="col">
                                <div class="form-check p-3 border rounded hover-shadow-sm transition-all">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" value="summary" checked id="chkSummary">
                                    <label class="form-check-label fw-medium cursor-pointer" for="chkSummary">
                                        <i class="fas fa-align-left text-primary me-2"></i> Giới thiệu
                                    </label>
                                </div>
                            </div>

                            <div class="col">
                                <div class="form-check p-3 border rounded hover-shadow-sm transition-all">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" value="experience" checked id="chkExp">
                                    <label class="form-check-label fw-medium cursor-pointer" for="chkExp">
                                        <i class="fas fa-briefcase text-primary me-2"></i> Kinh nghiệm
                                    </label>
                                </div>
                            </div>

                            <div class="col">
                                <div class="form-check p-3 border rounded hover-shadow-sm transition-all">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" value="education" checked id="chkEdu">
                                    <label class="form-check-label fw-medium cursor-pointer" for="chkEdu">
                                        <i class="fas fa-graduation-cap text-primary me-2"></i> Học vấn
                                    </label>
                                </div>
                            </div>

                            <div class="col">
                                <div class="form-check p-3 border rounded hover-shadow-sm transition-all">
                                    <input class="form-check-input ms-0 me-2" type="checkbox" value="skills" checked id="chkSkills">
                                    <label class="form-check-label fw-medium cursor-pointer" for="chkSkills">
                                        <i class="fas fa-tools text-primary me-2"></i> Kỹ năng
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-5">
                        <a href="@Url.Action("CvTemplates", "Admin")" class="btn btn-light px-4">Hủy</a>
                        <button type="button" class="btn btn-primary px-4 fw-medium" onclick="onSubmitForm()">
                            <i class="fas fa-save me-1"></i> Lưu Template
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hover-shadow-sm:hover {
            box-shadow: 0 .125rem .25rem rgba(0,0,0,.075)!important;
            border-color: #dee2e6!important;
            background-color: #f8f9fa;
        }
        .transition-all {
            transition: all 0.2s ease;
        }
        .cursor-pointer {
            cursor: pointer;
        }
    </style>
}

@section Scripts {
    <script>
        function onSubmitForm() {
            var name = document.getElementById('name').value;
            if(!name) { alert("Vui lòng nhập tên template!"); return; }

            // Lấy danh sách sections
            var sections = [];
            // Header luôn có
            sections.push({ type: "header", position: "top" });
            
            if(document.getElementById('chkSummary').checked)
                sections.push({ type: "summary", position: "left" });
                
            if(document.getElementById('chkExp').checked)
                sections.push({ type: "experience", position: "left" });
                
            if(document.getElementById('chkEdu').checked)
                sections.push({ type: "education", position: "left" });
                
            if(document.getElementById('chkSkills').checked)
                sections.push({ type: "skills", position: "left" });

            // Cấu hình Theme và Layout
            var config = {
                layout: document.getElementById('layoutDef').value,
                theme: {
                    primaryColor: document.getElementById('primaryColor').value,
                    font: document.getElementById('fontDef').value
                },
                sections: sections
            };

            document.getElementById('configJson').value = JSON.stringify(config);
            document.getElementById('templateForm').submit();
        }
    </script>
}
