@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển quản trị";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <style>
        /* ===== Dashboard Override: make admin-card transparent so charts fill naturally ===== */
        .admin-card {
            background: transparent;
            border: none;
            padding: 0;
        }

        /* ===== Toolbar ===== */
        .dash-toolbar {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .dash-toolbar-title {
            flex: 1 1 auto;
        }

        .dash-toolbar-title h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #111827;
            margin: 0 0 2px;
        }

        .dash-toolbar-title p {
            font-size: 0.82rem;
            color: #6b7280;
            margin: 0;
        }

        .dash-period-btn {
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #374151;
            font-size: 0.82rem;
            padding: 6px 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.15s;
        }

        .dash-period-btn:hover,
        .dash-period-btn.active {
            background: #00b14f;
            color: #fff;
            border-color: #00b14f;
        }

        .dash-select-wrap select {
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 6px 12px;
            font-size: 0.82rem;
            color: #374151;
            cursor: pointer;
        }

        /* ===== Stat Cards ===== */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 18px 20px;
            display: flex;
            align-items: flex-start;
            gap: 14px;
            transition: box-shadow 0.2s;
        }

        .stat-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .stat-info .label {
            font-size: 0.78rem;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .stat-info .value {
            font-size: 1.55rem;
            font-weight: 700;
            color: #111827;
            line-height: 1;
            margin-bottom: 4px;
        }

        .stat-info .trend {
            font-size: 0.78rem;
            font-weight: 600;
        }

        .trend-up { color: #00b14f; }
        .trend-down { color: #ef4444; }

        /* ===== Chart cards ===== */
        .chart-row {
            display: grid;
            gap: 16px;
            margin-bottom: 20px;
        }

        .chart-row-2 {
            grid-template-columns: 3fr 2fr;
        }

        .chart-row-2b {
            grid-template-columns: 2fr 2fr;
        }

        .chart-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 20px;
        }

        .chart-card-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 2px;
        }

        .chart-card-sub {
            font-size: 0.75rem;
            color: #6b7280;
            margin-bottom: 14px;
        }

        /* ===== Activity Table ===== */
        .activity-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.82rem;
        }

        .activity-table th {
            font-weight: 600;
            color: #6b7280;
            padding: 8px 10px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            font-size: 0.78rem;
        }

        .activity-table td {
            padding: 10px 10px;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            vertical-align: middle;
        }

        .activity-table tr:last-child td { border-bottom: none; }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
        }

        .status-active   { background: #dcfce7; color: #16a34a; }
        .status-success  { background: #dbeafe; color: #1d4ed8; }
        .status-pending  { background: #fef9c3; color: #92400e; }

        /* ===== Alerts ===== */
        .alert-section .alert-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 8px;
            font-size: 0.84rem;
            font-weight: 500;
        }

        .alert-item.danger  { background: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444; }
        .alert-item.warning { background: #fffbeb; color: #92400e; border-left: 4px solid #f59e0b; }
        .alert-item.success { background: #f0fdf4; color: #166534; border-left: 4px solid #22c55e; }

        @@media (max-width: 1100px) {
            .stat-grid { grid-template-columns: repeat(2, 1fr); }
            .chart-row-2, .chart-row-2b { grid-template-columns: 1fr; }
        }
    </style>
}

<!-- Toolbar -->
<div class="dash-toolbar">
    <div class="dash-toolbar-title">
        <h2>Admin Dashboard</h2>
        <p>Tổng quan tăng trưởng người dùng.</p>
    </div>
    <button class="dash-period-btn active" onclick="setPeriod(this,7)">7 ngày</button>
    <button class="dash-period-btn" onclick="setPeriod(this,30)">30 ngày</button>
    <button class="dash-period-btn" onclick="setPeriod(this,90)">90 ngày</button>
    <div class="dash-select-wrap">
        <select>
            <option>Theo tháng</option>
            <option>Theo tuần</option>
            <option>Theo năm</option>
        </select>
    </div>
    <button class="dash-period-btn">
        <i class="fas fa-download me-1"></i> Xuất báo cáo
    </button>
</div>

<!-- Stat Cards -->
<div class="stat-grid" style="grid-template-columns: repeat(2, 1fr);">
    <div class="stat-card">
        <div class="stat-icon" style="background:#fdf4ff;">
            <i class="fas fa-user-plus" style="color:#a855f7;"></i>
        </div>
        <div class="stat-info">
            <div class="label">Ứng viên mới</div>
            <div class="value">@Model.TotalCandidates</div>
            <div class="trend trend-up"><i class="fas fa-arrow-up"></i> +15%</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fff7ed;">
            <i class="fas fa-building" style="color:#f97316;"></i>
        </div>
        <div class="stat-info">
            <div class="label">Nhà tuyển dụng mới</div>
            <div class="value">@Model.TotalAdmins</div>
            <div class="trend trend-up"><i class="fas fa-arrow-up"></i> +6%</div>
        </div>
    </div>
</div>

<!-- Row 1: Area Chart -->
<div class="chart-row">
    <div class="chart-card">
        <div class="chart-card-title">Tăng trưởng người dùng</div>
        <div class="chart-card-sub">&nbsp;</div>
        <canvas id="userGrowthChart" height="120"></canvas>
    </div>
</div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fdf4ff;">
            <i class="fas fa-user-plus" style="color:#a855f7;"></i>
        </div>
        <div class="stat-info">
            <div class="label">Ứng viên mới</div>
            <div class="value">@Model.TotalCandidates</div>
            <div class="trend trend-up"><i class="fas fa-arrow-up"></i> +15%</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#fff7ed;">
            <i class="fas fa-building" style="color:#f97316;"></i>
        </div>
        <div class="stat-info">
            <div class="label">Nhà tuyển dụng mới</div>
            <div class="value">@Model.TotalAdmins</div>
            <div class="trend trend-up"><i class="fas fa-arrow-up"></i> +6%</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script>
        // ===== User Growth Area Chart =====
        new Chart(document.getElementById('userGrowthChart'), {
            type: 'line',
            data: {
                labels: ['T1','T2','T3','T4','T5','T6','T7'],
                datasets: [
                    {
                        label: 'Ứng viên',
                        data: [300,450,600,800,1100,1600,2100],
                        borderColor: '#22c55e',
                        backgroundColor: 'rgba(34,197,94,0.15)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 2,
                        pointRadius: 3,
                    },
                    {
                        label: 'Nhà tuyển dụng',
                        data: [50,80,110,140,170,190,220],
                        borderColor: '#6b7280',
                        backgroundColor: 'rgba(107,114,128,0.08)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 2,
                        pointRadius: 3,
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top', labels: { font: { size: 11 }, boxWidth: 16 } } },
                scales: {
                    y: { ticks: { font: { size: 10 } }, grid: { color: '#f3f4f6' } },
                    x: { ticks: { font: { size: 10 } }, grid: { display: false } }
                }
            }
        });

        // Period button toggle
        function setPeriod(btn, days) {
            document.querySelectorAll('.dash-period-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }
    </script>
}
