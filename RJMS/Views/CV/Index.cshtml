@model RJMS.vn.edu.fpt.Models.DTOs.CandidateCvViewModel
@{
    ViewData["Title"] = "CV của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        body { background: #f3f5f7; }
        .cv-wrap { max-width: 1000px; margin: 30px auto; padding: 0 16px 60px; }
        
        .cv-panel { 
            background: #fff; 
            border-radius: 12px; 
            padding: 24px; 
            margin-bottom: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }

        .cv-panel-header { 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            margin-bottom: 24px; 
        }

        .cv-panel-title { 
            font-size: 1.25rem; 
            font-weight: 800; 
            color: #111827; 
            margin: 0; 
        }

        .btn-green-action {
            background: #00b14f;
            color: #fff;
            border: none;
            border-radius: 20px;
            padding: 8px 16px;
            font-size: 0.95rem;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
        }

        .btn-green-action:hover {
            background: #009744;
            color: #fff;
        }

        .cv-empty-state { 
            text-align: center; 
            padding: 30px 20px 40px; 
        }

        .cv-empty-icon {
            font-size: 3.5rem;
            color: #d1d5db;
            margin-bottom: 12px;
        }

        .cv-empty-text { 
            color: #9ca3af; 
            font-size: 0.95rem; 
            font-weight: 500;
            margin: 0; 
        }

        .cv-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
            gap: 20px; 
        }

        .cv-card { 
            background: #fff; 
            border-radius: 12px; 
            border: 1px solid #e5e7eb; 
            padding: 20px; 
            display: flex; 
            flex-direction: column; 
            transition: all 0.2s; 
            position: relative;
            overflow: hidden;
        }
        
        .cv-card:hover { 
            border-color: #00b14f; 
            box-shadow: 0 4px 16px rgba(0,177,79,0.08); 
        }

        .cv-card-folder-icon {
            font-size: 3.5rem;
            color: #a7f3d0;
            margin-bottom: 16px;
            line-height: 1;
        }

        .cv-card-title { 
            font-size: 1.05rem; 
            font-weight: 700; 
            color: #111827; 
            margin: 0 0 8px 0; 
            white-space: nowrap; 
            overflow: hidden; 
            text-overflow: ellipsis; 
        }

        .cv-card-meta { 
            font-size: 0.85rem; 
            color: #6b7280; 
            line-height: 1.6; 
            margin-bottom: 16px;
        }
        
        .cv-card-actions { 
            display: flex; gap: 6px; flex-wrap: nowrap; margin-top: auto; 
        }

        .btn-sm-action { 
            padding: 6px 10px; 
            border-radius: 6px; 
            font-size: 0.82rem; 
            font-weight: 600; 
            text-decoration: none; 
            border: none; 
            cursor: pointer; 
            display: inline-flex; 
            align-items: center; 
            justify-content: center;
            flex: 1;
            white-space: nowrap;
            min-width: 0;
            transition: all 0.2s; 
        }

        .btn-primary-action { background: #f0fdf4; color: #00b14f; }
        .btn-primary-action:hover { background: #dcfce7; }
        
        .btn-danger-action { background: #fef2f2; color: #ef4444; }
        .btn-danger-action:hover { background: #fee2e2; }
    </style>
}

<div class="cv-wrap">
    @{
        var builderCvs = Model.Cvs.Where(c => c.CvType == "BUILDER").ToList();
        var uploadCvs = Model.Cvs.Where(c => c.CvType == "UPLOAD").ToList();
    }

    <!-- NỘI DUNG TẠO CV TRÊN FINDING JOB (BUILDER) -->
    <div class="cv-panel">
        <div class="cv-panel-header">
            <h2 class="cv-panel-title">CV đã tạo trên Finding Job</h2>
            <a asp-action="Create" class="btn-green-action">
                + Tạo CV
            </a>
        </div>

        @if (!builderCvs.Any())
        {
            <div class="cv-empty-state">
                <i class="fas fa-folder-open cv-empty-icon" style="opacity: 0.5;"></i>
                <p class="cv-empty-text">Chưa có CV nào được tạo.</p>
            </div>
        }
        else
        {
            <div class="cv-grid">
                @foreach (var cv in builderCvs)
                {
                    <div class="cv-card">
                        <!-- Giả lập icon folder xanh lá nhạt cho CV card như trong ảnh TopCV -->
                        <div class="cv-card-folder-icon">
                            <i class="fas fa-folder"></i>
                        </div>
                        <h3 class="cv-card-title" title="@cv.Title">@cv.Title</h3>
                        <div class="cv-card-meta">
                            @if (cv.UpdatedAt.HasValue)
                            {
                                <span>Cập nhật lần cuối: @cv.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</span><br />
                            }
                            else if (cv.CreatedAt.HasValue)
                            {
                                <span>Ngày tạo: @cv.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</span><br />
                            }
                        </div>
                        <div class="cv-card-actions">
                            <a asp-action="Edit" asp-route-id="@cv.Id" class="btn-sm-action btn-primary-action" style="background:#e0f2fe; color:#2563eb; flex:1; text-align:center; box-sizing:border-box;">Chỉnh sửa</a>
                            <a asp-action="DownloadPdf" asp-route-id="@cv.Id" class="btn-sm-action btn-primary-action" style="flex:1; text-align:center; box-sizing:border-box;" title="Tải xuống PDF">⬇ PDF</a>
                            <form asp-action="Delete" method="post" style="display:flex; flex:1; margin:0; box-sizing:border-box;" onsubmit="return confirm('Xoá CV này?')">
                                <input type="hidden" name="id" value="@cv.Id" />
                                <button type="submit" class="btn-sm-action btn-danger-action" style="flex:1; box-sizing:border-box;">Xoá</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- NỘI DUNG TẢI LÊN (UPLOAD) -->
    <div class="cv-panel">
        <div class="cv-panel-header">
            <h2 class="cv-panel-title">CV đã tải lên Finding Job</h2>
            <a asp-action="Upload" class="btn-green-action">
                &#8613; Tải CV lên
            </a>
        </div>

        @if (!uploadCvs.Any())
        {
            <div class="cv-empty-state">
                <i class="fas fa-folder-open cv-empty-icon" style="opacity: 0.5;"></i>
                <p class="cv-empty-text">Chưa có CV nào được tải lên.</p>
            </div>
        }
        else
        {
            <div class="cv-grid">
                @foreach (var cv in uploadCvs)
                {
                    <div class="cv-card">
                        <!-- Giả lập icon folder xanh lá nhạt cho CV card như trong ảnh TopCV -->
                        <div class="cv-card-folder-icon">
                            <i class="fas fa-folder"></i>
                        </div>
                        <h3 class="cv-card-title" title="@cv.Title">@cv.Title</h3>
                        <div class="cv-card-meta">
                            @if (cv.UpdatedAt.HasValue)
                            {
                                <span>Tải lên lúc: @cv.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</span><br />
                            }
                            else if (cv.CreatedAt.HasValue)
                            {
                                <span>Tải lên lúc: @cv.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm")</span><br />
                            }
                        </div>
                        <div class="cv-card-actions">
                            @if (!string.IsNullOrEmpty(cv.FileUrl))
                            {
                                <button type="button" class="btn-sm-action btn-primary-action" style="flex:1; background:#e0f2fe; color:#2563eb;" onclick="previewCv('@cv.Id', '@cv.CvType', '@cv.FileUrl')">Xem</button>
                                <a href="@cv.FileUrl" target="_blank" class="btn-sm-action btn-primary-action" style="flex:1; text-align:center; box-sizing:border-box;">Tải xuống</a>
                            }
                            <form asp-action="Delete" method="post" style="display:flex; flex:1; margin:0; box-sizing:border-box;" onsubmit="return confirm('Xoá CV này?')">
                                <input type="hidden" name="id" value="@cv.Id" />
                                <button type="submit" class="btn-sm-action btn-danger-action" style="flex:1; box-sizing:border-box;">Xoá</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function previewCv(id, type, fileUrl) {
            if (type === 'UPLOAD' && fileUrl) {
                window.open(fileUrl, '_blank');
            } else if (type === 'BUILDER') {
                window.open('/CV/PreviewHtml?id=' + id, '_blank');
            } else {
                alert('Không thể xem trước CV này.');
            }
        }
    </script>
}
