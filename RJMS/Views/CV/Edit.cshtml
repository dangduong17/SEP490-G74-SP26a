@using System.Text.Json
@model RJMS.vn.edu.fpt.Models.DTOs.CvEditorViewModel
@{
    ViewData["Title"] = "Chỉnh sửa CV";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var baseConfigStr = string.IsNullOrWhiteSpace(Model.ConfigJson) ? "null" : Model.ConfigJson;
    var dataStr = string.IsNullOrWhiteSpace(Model.JsonData) ? "{}" : Model.JsonData;
}
@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&family=Roboto:wght@400;500;700&family=Lora:wght@400;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="~/css/cv-editor.css?v=9" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css"/>
}

<form id="cvForm" method="post" action="@Url.Action("Save","CV")">
  <input type="hidden" name="cvId" value="@Model.CvId"/>
  <input type="hidden" name="templateId" value="@Model.TemplateId"/>
  <input type="hidden" name="jsonData" id="cvDataOutput"/>

<!-- Cropper Modal -->
<div id="cropper-modal">
  <div class="cropper-box">
    <div class="cropper-header">
      <span class="cropper-title">✂️ Cắt ảnh đại diện</span>
      <button type="button" class="cropper-close" onclick="closeCropperModal()">✕</button>
    </div>
    <div class="cropper-body">
      <img id="cropper-img" src="" alt="crop"/>
    </div>
    <div class="cropper-footer">
      <span class="cropper-hint">Kéo để chọn vùng · Cuộn để zoom</span>
      <div class="cropper-actions">
        <button type="button" class="cropper-cancel" onclick="closeCropperModal()">Huỷ</button>
        <button type="button" class="cropper-confirm" onclick="confirmCrop()">✓ Xác nhận</button>
      </div>
    </div>
  </div>
</div>

<div id="cvToast" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:10px 22px;border-radius:10px;font-size:.85rem;font-weight:600;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none;max-width:380px;text-align:center"></div>

<div class="shell">
<header class="topbar">
  <span class="logo">Finding Job</span>
  <span class="sep"></span>
  <input class="name-input" name="title" id="cvTitle" type="text" value="@Model.Title" required placeholder="Tên CV của bạn..."/>
  <div class="topbar-r">
    <a href="@Url.Action("Index","CV")" class="btn-ghost">← Thoát</a>
    <button type="button" id="saveBtn" class="btn-green" onclick="saveCv()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Lưu CV
    </button>
  </div>
</header>

<div class="body">
<aside class="palette">
  <div class="pal-head">Thêm mục vào CV</div>
  <div class="pal-section-head">Chưa dùng</div>
  <div class="pal-list" id="palette-unused">
    <div class="pal-chip" draggable="true" data-type="vcard">Danh thiếp</div>
    <div class="pal-chip" draggable="true" data-type="contact">Liên hệ</div>
    <div class="pal-chip" draggable="true" data-type="summary">Mục tiêu NN</div>
    <div class="pal-chip" draggable="true" data-type="experience">Kinh nghiệm LV</div>
    <div class="pal-chip" draggable="true" data-type="education">Học vấn</div>
    <div class="pal-chip" draggable="true" data-type="skills">Kỹ năng</div>
    <div class="pal-chip" draggable="true" data-type="projects">Dự án</div>
    <div class="pal-chip" draggable="true" data-type="awards">Giải thưởng</div>
    <div class="pal-chip" draggable="true" data-type="certs">Chứng chỉ</div>
    <div class="pal-chip" draggable="true" data-type="activities">Hoạt động</div>
    <div class="pal-chip" draggable="true" data-type="refs">Người tham chiếu</div>
    <div class="pal-chip" draggable="true" data-type="hobbies">Sở thích</div>
    <div class="pal-chip" draggable="true" data-type="extra">Thông tin thêm</div>
  </div>
  <div class="pal-div"></div>
  <div class="pal-section-head" id="used-head" style="display:none">Đã dùng</div>
  <div class="pal-list" id="palette-used"></div>
  <div class="pal-div"></div>
  <div style="padding:0 12px 14px;display:flex;flex-direction:column;gap:6px">
    <label class="pal-lbl" style="margin-left:0">Màu chủ đạo</label>
    <div style="display:flex;align-items:center;gap:8px">
      <input type="color" id="colorPick" value="#2563eb" oninput="applyTheme()" style="width:38px;height:32px;border:1.5px solid #e5e7eb;border-radius:6px;cursor:pointer;padding:2px"/>
      <span id="colorHex" style="font-size:.78rem;color:#64748b;font-family:monospace">#2563eb</span>
    </div>
    <label class="pal-lbl" style="margin-left:0;margin-top:6px">Font chữ</label>
    <select id="fontSel" onchange="applyTheme()" style="border:1.5px solid #e5e7eb;border-radius:7px;padding:6px 8px;font-size:.82rem;color:#374151;outline:none;font-family:inherit;background:#fff">
      <option value="Inter">Inter</option>
      <option value="Be Vietnam Pro">Be Vietnam Pro</option>
      <option value="Roboto">Roboto</option>
      <option value="Open Sans">Open Sans</option>
      <option value="Lora">Lora</option>
    </select>
  </div>
</aside>

<main class="canvas" id="canvas"></main>
</div>
</div>
</form>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/interactjs@1.10.27/dist/interact.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
<script type="module">
  import { Editor } from 'https://esm.sh/@@tiptap/core@2';
  import StarterKit from 'https://esm.sh/@@tiptap/starter-kit@2';
  import Underline from 'https://esm.sh/@@tiptap/extension-underline@2';
  import TextStyle from 'https://esm.sh/@@tiptap/extension-text-style@2';
  import Color from 'https://esm.sh/@@tiptap/extension-color@2';
  import TextAlign from 'https://esm.sh/@@tiptap/extension-text-align@2';
  import FontFamily from 'https://esm.sh/@@tiptap/extension-font-family@2';
  window.tiptap = { Editor, StarterKit, Underline, TextStyle, Color, TextAlign, FontFamily };
  document.dispatchEvent(new Event('tiptap-ready'));
</script>
<script src="~/js/cv-editor-shared.js?v=15"></script>
<script>
let cvDataObj = @Html.Raw(dataStr);
const baseConfig = @Html.Raw(baseConfigStr);
let activeTheme = { primaryColor: '#2563eb', font: 'Inter' };
let pages = [];
let isCvDirty = false;

// ── Initialize pages from saved CustomLayout, or hydrate from template ──
if (cvDataObj.CustomLayout && cvDataObj.CustomLayout.pages && cvDataObj.CustomLayout.pages.length > 0) {
  pages = cvDataObj.CustomLayout.pages;
  if (cvDataObj.CustomLayout.theme) activeTheme = cvDataObj.CustomLayout.theme;
} else {
  pages = migrateLegacyConfig(baseConfig);
  if (baseConfig && baseConfig.theme) activeTheme = baseConfig.theme;
}

// Sync theme UI controls
document.getElementById('colorPick').value = activeTheme.primaryColor;
document.getElementById('colorHex').textContent = activeTheme.primaryColor;
const fontSel = document.getElementById('fontSel');
for (let o of fontSel.options) { if (o.value === activeTheme.font) { fontSel.value = activeTheme.font; break; } }

document.addEventListener('input', (e) => {
  if (e.target.hasAttribute('contenteditable') || e.target.tagName.toLowerCase() === 'input') isCvDirty = true;
});
window.addEventListener('beforeunload', e => { if (isCvDirty) { e.preventDefault(); e.returnValue = ''; } });

function _cvEditorInit() {
  setupPaletteDrag();
  renderCanvas();
  applyTheme();
  initTiptapFloating();
  initContextualToolbar();
  initZoomControl();
  // Auto fit zoom after render
  requestAnimationFrame(() => zoomFit());
}
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', _cvEditorInit);
} else {
  _cvEditorInit();
}

function applyTheme() {
  activeTheme.primaryColor = document.getElementById('colorPick').value;
  activeTheme.font = document.getElementById('fontSel').value;
  document.getElementById('colorHex').textContent = activeTheme.primaryColor;
  applyThemeToCanvas(activeTheme.primaryColor, activeTheme.font);
}

function setupPaletteDrag() {
  document.querySelectorAll('#palette-unused .pal-chip, #palette-used .pal-chip').forEach(chip => {
    chip.addEventListener('dragstart', e => e.dataTransfer.setData('sectype', chip.dataset.type));
  });
}

function refreshPalette() {
  const usedCounts = {};
  pages.forEach(p => p.sections.forEach(s => { usedCounts[s.type] = (usedCounts[s.type] || 0) + 1; }));
  const unusedList = document.getElementById('palette-unused');
  const usedList = document.getElementById('palette-used');
  const usedHead = document.getElementById('used-head');
  if (!unusedList || !usedList) return;
  // Collect all chips from both lists
  const allChips = Array.from(document.querySelectorAll('#palette-unused .pal-chip, #palette-used .pal-chip'));
  allChips.forEach(chip => {
    const type = chip.dataset.type;
    if (usedCounts[type] > 0) {
      usedList.appendChild(chip);
    } else {
      unusedList.appendChild(chip);
    }
  });
  if (usedHead) usedHead.style.display = usedList.children.length > 0 ? '' : 'none';
}

function bindDroppable() {
  document.querySelectorAll('.a4').forEach((a4, pi) => {
    a4.ondragover = e => { e.preventDefault(); a4.classList.add('dragover'); };
    a4.ondragleave = () => a4.classList.remove('dragover');
    a4.ondrop = e => {
      e.preventDefault(); a4.classList.remove('dragover');
      const type = e.dataTransfer.getData('sectype');
      if (!type) return;
      const rect = a4.getBoundingClientRect();
      addSecAt(pi, type, e.clientX - rect.left, e.clientY - rect.top);
    };
  });
}

function addSecAt(pi, type, x, y) {
  const def = SEC[type]; if (!def) return;
  const sec = { type, top: Math.max(0, y - 20), left: Math.max(0, x - def.defaultW / 2), width: def.defaultW, height: def.defaultH, html: null };
  const el = buildSectionEl(sec, pi, 'candidate');
  if (!el) return;
  const a4 = document.querySelector(`.a4[data-page="${pi}"]`);
  hydrateSection(el, type);
  a4.appendChild(el);
  if (typeof resolveAllOverlaps === 'function') resolveAllOverlaps(a4);
  applyTheme();
  isCvDirty = true;
  refreshPalette();
}

function removeSec(el) { el.remove(); isCvDirty = true; refreshPalette(); }

function dupSec(el) {
  const pi = parseInt(el.dataset.page), type = el.dataset.type;
  const cw = el.querySelector('.cv-content-wrap');
  const sec = {
    type,
    top: (parseFloat(el.style.top) || 0) + 20,
    left: (parseFloat(el.style.left) || 0) + 20,
    width: parseFloat(el.style.width) || SEC[type]?.defaultW || 350,
    height: parseFloat(el.style.height) || SEC[type]?.defaultH || 150,
    html: cw ? cw.innerHTML : null
  };
  const newEl = buildSectionEl(sec, pi, 'candidate');
  if (!newEl) return;
  const a4 = document.querySelector(`.a4[data-page="${pi}"]`);
  a4.appendChild(newEl);
  if (typeof resolveAllOverlaps === 'function') resolveAllOverlaps(a4);
  applyTheme();
  isCvDirty = true;
}

function moveSecUp(el) {
  const a4 = el.closest('.a4');
  if (!a4) return;
  const siblings = Array.from(a4.querySelectorAll('.cv-sec')).filter(e => e !== el);
  let closest = null;
  let minDiff = Infinity;
  const myTop = parseFloat(el.style.top) || 0;
  for (let s of siblings) {
    const sTop = parseFloat(s.style.top) || 0;
    if (sTop < myTop && myTop - sTop < minDiff) {
      minDiff = myTop - sTop;
      closest = s;
    }
  }
  if (closest) {
    const tmp = el.style.top;
    el.style.top = closest.style.top;
    closest.style.top = tmp;
    if (typeof resolveAllOverlaps === 'function') resolveAllOverlaps(a4);
    isCvDirty = true;
  }
}

function moveSecDown(el) {
  const a4 = el.closest('.a4');
  if (!a4) return;
  const siblings = Array.from(a4.querySelectorAll('.cv-sec')).filter(e => e !== el);
  let closest = null;
  let minDiff = Infinity;
  const myTop = parseFloat(el.style.top) || 0;
  for (let s of siblings) {
    const sTop = parseFloat(s.style.top) || 0;
    if (sTop > myTop && sTop - myTop < minDiff) {
      minDiff = sTop - myTop;
      closest = s;
    }
  }
  if (closest) {
    const tmp = el.style.top;
    el.style.top = closest.style.top;
    closest.style.top = tmp;
    if (typeof resolveAllOverlaps === 'function') resolveAllOverlaps(a4);
    isCvDirty = true;
  }
}

initInteract(
  (target) => { isCvDirty = true; },
  (target) => { isCvDirty = true; }
);

// ── Hydrate section with existing cvDataObj ──
const _counters = {};
function hydrateSection(sectionEl, type) {
  const data = cvDataObj || {};
  const idx = (_counters[type] = (_counters[type] || 0));
  _counters[type]++;
  const set = (sel, val) => { const e = sectionEl.querySelector(sel); if (e && val) e.textContent = val; };

  if (type === 'header') {
    set('.cv-name', data.FullName);
    set('.cv-jobtitle', data.Position);
    const nodes = sectionEl.querySelectorAll('.cv-contacts [contenteditable="true"]');
    if (nodes[0]) nodes[0].textContent = data.DateOfBirth || nodes[0].textContent;
    if (nodes[1]) nodes[1].textContent = data.Phone || nodes[1].textContent;
    if (nodes[2]) nodes[2].textContent = data.Email || nodes[2].textContent;
    if (nodes[3]) nodes[3].textContent = data.Address || nodes[3].textContent;
    if (nodes[4]) nodes[4].textContent = data.LinkedIn || nodes[4].textContent;
    const avatarEl = sectionEl.querySelector('.cv-avatar');
    if (avatarEl && data.AvatarBase64) avatarEl.innerHTML = `<img src="${data.AvatarBase64}" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" alt="avatar"/>`;
    return;
  }
  if (type === 'summary') { set('.cv-simple', data.Summary); return; }
  if (type === 'skills') {
    const skills = (data.Skills || '').split(',').map(s => s.trim()).filter(Boolean);
    const wrap = sectionEl.querySelector('.cv-skills');
    if (wrap && skills.length) wrap.innerHTML = skills.map(s => `<span class="cv-tag" contenteditable="true" spellcheck="false">${s}</span>`).join('');
    return;
  }
  if (type === 'experience') {
    const item = (data.Experiences || [])[idx] || {};
    set('.cv-company', item.Company); set('.cv-pos', item.Role);
    set('.cv-date', item.Period); set('.cv-desc', item.Description);
    return;
  }
  if (type === 'education') {
    const item = (data.Educations || [])[idx] || {};
    set('.cv-company', item.School); set('.cv-pos', item.Degree);
    set('.cv-date', item.Period); set('.cv-desc', item.Achievement);
    return;
  }
  if (type === 'projects') {
    const item = (data.Projects || [])[idx] || {};
    set('.cv-company', item.Name); set('.cv-pos', item.Role);
    set('.cv-date', item.Period); set('.cv-desc', item.Description);
    return;
  }
  if (type === 'hobbies') { set('.cv-simple', data.Hobbies); return; }
  if (type === 'extra') { set('.cv-simple', data.Extra); return; }
}

function renderCanvas() {
  const cvs = document.getElementById('canvas');
  cvs.innerHTML = '';
  Object.keys(_counters).forEach(k => _counters[k] = 0);

  pages.forEach((pg, pi) => {
    const bar = div('pg-bar'); bar.innerHTML = `<span>Trang ${pi + 1}</span>`;
    const a4 = div('a4'); a4.dataset.page = pi; a4.style.fontFamily = `'${activeTheme.font}', sans-serif`;

    pg.sections.forEach(s => {
      const el = buildSectionEl(s, pi, 'candidate');
      if (!el) return;
      if (!s.html) hydrateSection(el, s.type);
      a4.appendChild(el);
    });

    const wrap = div('pgwrap'); wrap.appendChild(bar); wrap.appendChild(a4); cvs.appendChild(wrap);
  });

  bindDroppable();
  refreshPalette();
  applyTheme();
}

function showToast(msg, isOk) {
  const t = document.getElementById('cvToast');
  t.textContent = msg;
  t.style.background = isOk ? '#059669' : '#dc2626';
  t.style.opacity = '1';
  setTimeout(() => { t.style.opacity = '0'; }, 3000);
}

async function saveCv() {
  const btn = document.getElementById('saveBtn');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Đang lưu...';
  btn.disabled = true;

  // ── Collect current canvas data ──
  const newPages = [];
  const experiences = [], educations = [], projects = [];

  const headerEl = document.querySelector('.cv-sec[data-type="header"]');
  if (headerEl) {
    const nodes = headerEl.querySelectorAll('.cv-contacts [contenteditable="true"]');
    cvDataObj.FullName = (headerEl.querySelector('.cv-name')?.innerText || '').trim();
    cvDataObj.Position = (headerEl.querySelector('.cv-jobtitle')?.innerText || '').trim();
    if (nodes[0]) cvDataObj.DateOfBirth = nodes[0].textContent.trim();
    if (nodes[1]) cvDataObj.Phone = nodes[1].textContent.trim();
    if (nodes[2]) cvDataObj.Email = nodes[2].textContent.trim();
    if (nodes[3]) cvDataObj.Address = nodes[3].textContent.trim();
    if (nodes[4]) cvDataObj.LinkedIn = nodes[4].textContent.trim();
    const avatarImg = headerEl.querySelector('.cv-avatar img, .cv-avatar-sm img');
    if (avatarImg) cvDataObj.AvatarBase64 = avatarImg.src;
  }

  document.querySelectorAll('.a4').forEach(a4 => {
    const secs = [];
    a4.querySelectorAll('.cv-sec').forEach(el => {
      const type = el.dataset.type;
      const top = parseFloat(el.style.top) || 0, left = parseFloat(el.style.left) || 0;
      const width = parseFloat(el.style.width) || 300, height = parseFloat(el.style.height) || 100;
      const cw = el.querySelector('.cv-content-wrap');

      if (type === 'summary') {
        const sumEl = el.querySelector('.cv-simple');
        cvDataObj.Summary = getRichHtml(sumEl) || sumEl?.innerText?.trim() || '';
      } else if (type === 'skills') {
        cvDataObj.Skills = Array.from(el.querySelectorAll('.cv-tag')).map(t => (t.innerText || '').trim()).filter(Boolean).join(', ');
      } else if (type === 'hobbies') {
        cvDataObj.Hobbies = Array.from(el.querySelectorAll('.cv-tag')).map(t => (t.innerText || '').trim()).filter(Boolean).join(', ') || (el.querySelector('.cv-simple')?.innerText || '').trim();
      } else if (type === 'extra') {
        cvDataObj.Extra = (el.querySelector('.cv-simple')?.innerText || '').trim();
      } else if (type === 'experience') {
        el.querySelectorAll('.cv-exp-item').forEach(item => {
          const descEl = item.querySelector('.cv-desc');
          experiences.push({ Company: (item.querySelector('.cv-company')?.innerText || '').trim(), Role: (item.querySelector('.cv-pos')?.innerText || '').trim(), Period: (item.querySelector('.cv-date')?.innerText || '').trim(), Description: getRichHtml(descEl) });
        });
      } else if (type === 'education') {
        el.querySelectorAll('.cv-exp-item').forEach(item => {
          const descEl = item.querySelector('.cv-desc');
          educations.push({ School: (item.querySelector('.cv-company')?.innerText || '').trim(), Degree: (item.querySelector('.cv-pos')?.innerText || '').trim(), Period: (item.querySelector('.cv-date')?.innerText || '').trim(), Achievement: getRichHtml(descEl) });
        });
      } else if (type === 'projects') {
        el.querySelectorAll('.cv-exp-item').forEach(item => {
          const descEl = item.querySelector('.cv-desc');
          projects.push({ Name: (item.querySelector('.cv-company')?.innerText || '').trim(), Role: (item.querySelector('.cv-pos')?.innerText || '').trim(), Period: (item.querySelector('.cv-date')?.innerText || '').trim(), Description: getRichHtml(descEl) });
        });
      }

      // Build section HTML — strip candidate helper buttons before saving
      let secHtml = null;
      if (cw) {
        const clone = cw.cloneNode(true);
        const allOrigRich = Array.from(cw.querySelectorAll('.cv-desc,.cv-simple'));
        const allCloneRich = Array.from(clone.querySelectorAll('.cv-desc,.cv-simple'));
        allCloneRich.forEach((f, i) => {
          const orig = allOrigRich[i];
          if (orig && orig._tiptapEditor) f.innerHTML = orig._tiptapEditor.getHTML();
        });
        clone.querySelectorAll('.cv-item-del, .cv-add-item-btn').forEach(b => b.remove());
        clone.querySelectorAll('.cv-items-wrap').forEach(w => w.replaceWith(...Array.from(w.childNodes)));
        secHtml = clone.innerHTML;
      }
      secs.push({ type, top, left, width, height, html: secHtml });
    });
    newPages.push({ columns: 0, sections: secs });
  });

  cvDataObj.Experiences = experiences;
  cvDataObj.Educations = educations;
  cvDataObj.Projects = projects;
  cvDataObj.CustomLayout = { pages: newPages, theme: activeTheme };

  // ── Upload pending avatar to Cloudinary ──
  const pendingLabel = document.querySelector('.cv-avatar-wrap[data-pending-avatar], .cv-vcard-avatar[data-pending-avatar]');
  if (pendingLabel) {
    try {
      const b64 = pendingLabel.dataset.pendingAvatar;
      const uploadRes = await fetch('/CV/UploadAvatar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ base64: b64 })
      });
      if (uploadRes.ok) {
        const { url } = await uploadRes.json();
        if (url) { cvDataObj.AvatarBase64 = url; delete pendingLabel.dataset.pendingAvatar; }
      }
    } catch (_) { /* keep base64 locally on failure */ }
  }

  document.getElementById('cvDataOutput').value = JSON.stringify(cvDataObj);

  try {
    const form = document.getElementById('cvForm');
    const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
    if (res.ok) {
      isCvDirty = false;
      showToast('✓ Lưu CV thành công!', true);
      if (res.redirected) window.location.href = res.url;
    } else {
      showToast('Lỗi khi lưu CV. Vui lòng thử lại.', false);
    }
  } catch (err) {
    showToast('Lỗi mạng: ' + err.message, false);
  } finally {
    setTimeout(() => { btn.innerHTML = originalHtml; btn.disabled = false; }, 2000);
  }
}
</script>
}
