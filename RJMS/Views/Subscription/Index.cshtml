@model List<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>
@{
    ViewData["Title"] = "Chọn gói dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userRole = Context.Request.Cookies["UserRole"];
    var canSubscribe = userRole == "Recruiter";
}

<style>
    .pricing-hero {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 60px 0 40px;
    }

    .pricing-card {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 30px;
        background: white;
        transition: all 0.3s ease;
        height: 100%;
        position: relative;
    }

    .pricing-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .pricing-card.featured {
        border-color: #00b14f;
        transform: scale(1.05);
    }

    .pricing-badge {
        position: absolute;
        top: -12px;
        right: 20px;
        background: #00b14f;
        color: white;
        padding: 4px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .pricing-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .pricing-subtitle {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 24px;
    }

    .pricing-price {
        font-size: 2.5rem;
        font-weight: 800;
        color: #212529;
        margin-bottom: 12px;
    }

    .pricing-price small {
        font-size: 1rem;
        font-weight: 400;
        color: #6c757d;
    }

    .pricing-period {
        color: #6c757d;
        font-size: 1rem;
        font-weight: 400;
        margin-left: 4px;
    }

    .pricing-vat {
        font-size: 0.85rem;
        color: #868e96;
        margin-bottom: 20px;
    }

    .pricing-features {
        list-style: none;
        padding: 0;
        margin: 24px 0;
    }

    .pricing-features li {
        padding: 10px 0;
        display: flex;
        align-items: start;
        gap: 10px;
        font-size: 0.95rem;
    }

    .pricing-features li i {
        color: #00b14f;
        margin-top: 2px;
        flex-shrink: 0;
    }

    .btn-pricing {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 20px;
    }

    .btn-pricing-primary {
        background: #00b14f;
        border-color: #00b14f;
        color: white;
    }

    .btn-pricing-primary:hover {
        background: #009744;
        border-color: #009744;
    }

    .btn-pricing-outline {
        border: 2px solid #00b14f;
        color: #00b14f;
        background: white;
    }

    .btn-pricing-outline:hover {
        background: #f0fdf4;
    }

    .comparison-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    .comparison-table th {
        background: #f8f9fa;
        padding: 14px 16px;
        font-weight: 600;
        white-space: nowrap;
    }

    .comparison-table td {
        padding: 14px 16px;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
    }

    .comparison-table .featured-col {
        background: #f0fdf4;
    }

    .cycle-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-right: 6px;
        margin-bottom: 4px;
    }

    .cycle-monthly { background: #dbeafe; color: #1d4ed8; }
    .cycle-yearly { background: #dcfce7; color: #15803d; }

    .price-stack {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .price-main {
        font-weight: 700;
        color: #111827;
    }

    .price-sub {
        font-size: 0.78rem;
        color: #6b7280;
    }
</style>

<!-- Hero Section -->
<div class="pricing-hero">
    <div class="container text-center">
        <h1 class="display-5 fw-bold mb-3">Chọn gói dịch vụ</h1>
        <p class="lead text-muted mb-4">Chọn gói phù hợp để đăng tin tuyển dụng và quản lý ứng viên.</p>
        <div class="btn-group billing-toggle" role="group">
            <input type="radio" class="btn-check" name="billing" id="billing-monthly" checked>
            <label class="btn btn-outline-secondary" for="billing-monthly">Theo tháng</label>
            
            <input type="radio" class="btn-check" name="billing" id="billing-yearly">
            <label class="btn btn-outline-secondary" for="billing-yearly">Theo năm</label>
        </div>
    </div>
</div>

<!-- Pricing Cards -->
<div class="container my-5">
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var group in Model)
            {
                <div class="col-lg-4">
                    <div class="pricing-card" data-plan-group="@group.BaseName">
                        @if (group.MonthlyPlan != null && group.MonthlyPlan.Price > 5000000)
                        {
                            <span class="pricing-badge">Phổ biến</span>
                        }
                        
                        <!-- Monthly Plan -->
                        <div class="pricing-plan-monthly" style="display: block;">
                            <h3 class="pricing-title">@group.MonthlyPlan?.Name?.Replace(" (Hàng tháng)", "")</h3>
                            <div class="pricing-price">
                                @(group.MonthlyPlan?.Price.ToString("N0") ?? "0") <small>đ</small>
                                <span class="pricing-period">/ tháng</span>
                            </div>
                            <p class="pricing-subtitle">@group.MonthlyPlan?.Name?.Replace(" (Hàng tháng)", "")</p>
                            <p class="pricing-vat">Thanh toán hết cho suất thời hạn</p>
                            
                            <ul class="pricing-features">
                                @{
                                    var jobLimit = group.MonthlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "JOB_POSTING")?.FeatureLimit ?? 0;
                                    var aiLimit = group.MonthlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "CV_AI_FILTER")?.FeatureLimit ?? 0;
                                }
                                @if (jobLimit > 0)
                                {
                                    <li><i class="fas fa-check-circle"></i> @jobLimit tin đăng / tháng</li>
                                }
                                else
                                {
                                    <li><i class="fas fa-times-circle text-muted"></i> <span class="text-muted">Không có tính năng đăng tin</span></li>
                                }
                                
                                @if (aiLimit > 0)
                                {
                                    <li><i class="fas fa-check-circle"></i> @aiLimit lượt lọc CV bằng AI / tháng</li>
                                }
                                else
                                {
                                    <li><i class="fas fa-times-circle text-muted"></i> <span class="text-muted">Không có tính năng lọc CV bằng AI</span></li>
                                }
                                
                                <li><i class="fas fa-check-circle"></i> Hiển thị đến @group.MonthlyPlan?.DurationDays ngày</li>
                            </ul>

                            @if (canSubscribe)
                            {
                                @if (ViewBag.CurrentPlanId != null && group.MonthlyPlan?.Id == (int)ViewBag.CurrentPlanId)
                                {
                                    <button class="btn btn-pricing btn-pricing-outline" disabled style="background-color: #f8f9fa; border-color: #6c757d; color: #6c757d;">Đang sử dụng</button>
                                }
                                else if (group.MonthlyPlan?.Price == 0)
                                {
                                    <button class="btn btn-pricing btn-pricing-outline" disabled>Gói miễn phí</button>
                                }
                                else
                                {
                                    <a asp-controller="Payment" asp-action="PlanDetail" asp-route-id="@group.MonthlyPlan?.OptionId" class="btn btn-pricing btn-pricing-primary">Đăng ký ngay</a>
                                }
                            }
                        </div>

                        <!-- Yearly Plan -->
                        @if (group.HasYearly)
                        {
                            <div class="pricing-plan-yearly" style="display: none;">
                                <h3 class="pricing-title">@group.YearlyPlan?.Name?.Replace(" (Hàng năm)", "")</h3>
                                <div class="pricing-price">
                                    @(group.YearlyPlan?.Price.ToString("N0") ?? "0") <small>đ</small>
                                    <span class="pricing-period">/ năm</span>
                                </div>
                                @if (group.YearlyPlan?.DiscountPercentage > 0)
                                {
                                    <p style="background: #d4f4d4; padding: 8px; border-radius: 6px; color: #00b14f; font-weight: 600;">Tiết kiệm @group.YearlyPlan?.DiscountPercentage%</p>
                                }
                                <p class="pricing-subtitle">@group.YearlyPlan?.Name?.Replace(" (Hàng năm)", "")</p>
                                <p class="pricing-vat">Thanh toán hết cho suất thời hạn</p>
                                
                                <ul class="pricing-features">
                                    @{
                                        var jobLimitY = group.YearlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "JOB_POSTING")?.FeatureLimit ?? 0;
                                        var aiLimitY = group.YearlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "CV_AI_FILTER")?.FeatureLimit ?? 0;
                                    }
                                    @if (jobLimitY > 0)
                                    {
                                        <li><i class="fas fa-check-circle"></i> @jobLimitY tin đăng / tháng</li>
                                    }
                                    else
                                    {
                                        <li><i class="fas fa-times-circle text-muted"></i> <span class="text-muted">Không có tính năng đăng tin</span></li>
                                    }
                                    
                                    @if (aiLimitY > 0)
                                    {
                                        <li><i class="fas fa-check-circle"></i> @aiLimitY lượt lọc CV bằng AI / tháng</li>
                                    }
                                    else
                                    {
                                        <li><i class="fas fa-times-circle text-muted"></i> <span class="text-muted">Không có tính năng lọc CV bằng AI</span></li>
                                    }
                                    
                                    <li><i class="fas fa-check-circle"></i> Hiển thị đến @group.YearlyPlan?.DurationDays ngày</li>
                                </ul>

                                @if (canSubscribe)
                                {
                                    @if (ViewBag.CurrentPlanId != null && group.YearlyPlan?.Id == (int)ViewBag.CurrentPlanId)
                                    {
                                        <button class="btn btn-pricing btn-pricing-outline" disabled style="background-color: #f8f9fa; border-color: #6c757d; color: #6c757d;">Đang sử dụng</button>
                                    }
                                    else
                                    {
                                        <a asp-controller="Payment" asp-action="PlanDetail" asp-route-id="@group.YearlyPlan?.OptionId" class="btn btn-pricing btn-pricing-primary">Đăng ký ngay</a>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Hiện chưa có gói dịch vụ nào. Vui lòng quay lại sau.
                </div>
            </div>
        }
    </div>
</div>

<!-- Comparison Table -->
<div class="container my-5">
    <h2 class="text-center fw-bold mb-4">So sánh gói</h2>
    <div class="comparison-table">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th style="width: 28%">Tính năng</th>
                    @foreach (var group in Model ?? Enumerable.Empty<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>())
                    {
                        <th class="text-center @(group.HasYearly ? "featured-col" : "")">@group.BaseName</th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-semibold">Giá / tháng</td>
                    @foreach (var group in Model ?? Enumerable.Empty<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>())
                    {
                        <td class="text-center @(group.HasYearly ? "featured-col" : "")">
                            @if (group.MonthlyPlan != null)
                            {
                                <div class="price-stack">
                                    <div class="price-main">@group.MonthlyPlan.Price.ToString("N0") VND</div>
                                    <div class="price-sub">/@group.MonthlyPlan.BillingCycleDisplay.ToLowerInvariant()</div>
                                </div>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                    }
                </tr>
                <tr>
                    <td class="fw-semibold">Giá / năm</td>
                    @foreach (var group in Model ?? Enumerable.Empty<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>())
                    {
                        <td class="text-center @(group.HasYearly ? "featured-col" : "")">
                            @if (group.YearlyPlan != null)
                            {
                                <div class="price-stack">
                                    <div class="price-main">@group.YearlyPlan.Price.ToString("N0") VND</div>
                                    <div class="price-sub">/@group.YearlyPlan.BillingCycleDisplay.ToLowerInvariant()</div>
                                    @if (group.YearlyPlan.DiscountPercentage > 0)
                                    {
                                        <div class="price-sub text-success">Tiết kiệm @group.YearlyPlan.DiscountPercentage%</div>
                                    }
                                </div>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                    }
                </tr>
                <tr>
                    <td class="fw-semibold">Tin đăng / tháng</td>
                    @foreach (var group in Model ?? Enumerable.Empty<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>())
                    {
                        var feature = group.MonthlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "JOB_POSTING")
                            ?? group.YearlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "JOB_POSTING");
                        <td class="text-center @(group.HasYearly ? "featured-col" : "")">
                            @if (feature?.FeatureLimit.HasValue == true)
                            {
                                @if (feature.FeatureLimit.Value <= 0)
                                {
                                    <span>Không giới hạn</span>
                                }
                                else
                                {
                                    <span>@feature.FeatureLimit.Value tin</span>
                                }
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                    }
                </tr>
                <tr>
                    <td class="fw-semibold">Lọc CV bằng AI</td>
                    @foreach (var group in Model ?? Enumerable.Empty<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>())
                    {
                        var feature = group.MonthlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "CV_AI_FILTER")
                            ?? group.YearlyPlan?.Features?.FirstOrDefault(f => f.FeatureCode == "CV_AI_FILTER");
                        <td class="text-center @(group.HasYearly ? "featured-col" : "")">
                            @if (feature?.FeatureLimit.HasValue == true)
                            {
                                @if (feature.FeatureLimit.Value <= 0)
                                {
                                    <span>Không giới hạn</span>
                                }
                                else
                                {
                                    <span>@feature.FeatureLimit.Value lượt</span>
                                }
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                    }
                </tr>
                <tr>
                    <td class="fw-semibold">Chu kỳ có sẵn</td>
                    @foreach (var group in Model ?? Enumerable.Empty<RJMS.vn.edu.fpt.Models.DTOs.SubscriptionPlanGroupDto>())
                    {
                        <td class="text-center @(group.HasYearly ? "featured-col" : "")">
                            @if (group.HasMonthly)
                            {
                                <span class="cycle-badge cycle-monthly">Hàng tháng</span>
                            }
                            @if (group.HasYearly)
                            {
                                <span class="cycle-badge cycle-yearly">Hàng năm</span>
                            }
                        </td>
                    }
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // Billing cycle toggle
    const billingToggle = document.querySelectorAll('input[name="billing"]');
    
    billingToggle.forEach(input => {
        input.addEventListener('change', function() {
            const isYearly = this.id === 'billing-yearly';
            const planCards = document.querySelectorAll('.pricing-card');
            
            planCards.forEach(card => {
                const monthlyPlan = card.querySelector('.pricing-plan-monthly');
                const yearlyPlan = card.querySelector('.pricing-plan-yearly');
                
                if (isYearly && yearlyPlan) {
                    monthlyPlan.style.display = 'none';
                    yearlyPlan.style.display = 'block';
                } else {
                    monthlyPlan.style.display = 'block';
                    if (yearlyPlan) yearlyPlan.style.display = 'none';
                }
            });
        });
    });

</script>
}
