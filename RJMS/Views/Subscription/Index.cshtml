@model List<RJMS.vn.edu.fpt.Models.SubscriptionPlan>
@{
    ViewData["Title"] = "Chọn gói dịch vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .pricing-hero {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 60px 0 40px;
    }

    .pricing-card {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 30px;
        background: white;
        transition: all 0.3s ease;
        height: 100%;
        position: relative;
    }

    .pricing-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .pricing-card.featured {
        border-color: #00b14f;
        transform: scale(1.05);
    }

    .pricing-badge {
        position: absolute;
        top: -12px;
        right: 20px;
        background: #00b14f;
        color: white;
        padding: 4px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .pricing-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .pricing-subtitle {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 24px;
    }

    .pricing-price {
        font-size: 2.5rem;
        font-weight: 800;
        color: #212529;
        margin-bottom: 12px;
    }

    .pricing-price small {
        font-size: 1rem;
        font-weight: 400;
        color: #6c757d;
    }

    .pricing-period {
        color: #6c757d;
        font-size: 1rem;
        font-weight: 400;
        margin-left: 4px;
    }

    .pricing-vat {
        font-size: 0.85rem;
        color: #868e96;
        margin-bottom: 20px;
    }

    .pricing-features {
        list-style: none;
        padding: 0;
        margin: 24px 0;
    }

    .pricing-features li {
        padding: 10px 0;
        display: flex;
        align-items: start;
        gap: 10px;
        font-size: 0.95rem;
    }

    .pricing-features li i {
        color: #00b14f;
        margin-top: 2px;
        flex-shrink: 0;
    }

    .btn-pricing {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 20px;
    }

    .btn-pricing-primary {
        background: #00b14f;
        border-color: #00b14f;
        color: white;
    }

    .btn-pricing-primary:hover {
        background: #009744;
        border-color: #009744;
    }

    .btn-pricing-outline {
        border: 2px solid #00b14f;
        color: #00b14f;
        background: white;
    }

    .btn-pricing-outline:hover {
        background: #f0fdf4;
    }

    .comparison-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .comparison-table th {
        background: #f8f9fa;
        padding: 16px;
        font-weight: 600;
    }

    .comparison-table td {
        padding: 16px;
        border-bottom: 1px solid #e9ecef;
    }

    .comparison-table .featured-col {
        background: #f0fdf4;
    }

    .faq-section {
        background: white;
        border-radius: 12px;
        padding: 30px;
    }

    .faq-item {
        border-bottom: 1px solid #e9ecef;
        padding: 20px 0;
    }

    .faq-item:last-child {
        border-bottom: none;
    }

    .faq-question {
        font-weight: 600;
        font-size: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        color: #212529;
    }
</style>

<!-- Hero Section -->
<div class="pricing-hero">
    <div class="container text-center">
        <h1 class="display-5 fw-bold mb-3">Chọn gói dịch vụ</h1>
        <p class="lead text-muted mb-4">Chọn gói phù hợp để đăng tin tuyển dụng và quản lý ứng viên.</p>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-outline-secondary active">Theo tháng</button>
            <button type="button" class="btn btn-outline-secondary">Theo năm</button>
        </div>
    </div>
</div>

<!-- Pricing Cards -->
<div class="container my-5">
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @for (int i = 0; i < Model.Count; i++)
            {
                var plan = Model[i];
                var isFeatured = Model.Count == 3 && i == 1; // Middle plan is featured if 3 plans
                var jobLimit = plan.PlanFeatures?.FirstOrDefault(f => f.FeatureCode == "JOB_POSTING")?.FeatureLimit ?? 0;
                var aiLimit = plan.PlanFeatures?.FirstOrDefault(f => f.FeatureCode == "CV_AI_FILTER")?.FeatureLimit ?? 0;
                
                <div class="col-lg-4">
                    <div class="pricing-card @(isFeatured ? "featured" : "")">
                        @if (isFeatured)
                        {
                            <span class="pricing-badge">Phổ biến</span>
                        }
                        <h3 class="pricing-title">@plan.Name</h3>
                        <div class="pricing-price">
                            @(plan.Price?.ToString("N0") ?? "0") <small>đ</small>
                            <span class="pricing-period">/ @(plan.BillingCycle ?? "tháng")</span>
                        </div>
                        <p class="pricing-subtitle">@plan.Description</p>
                        <p class="pricing-vat">Thanh toán hết cho suất thời hạn</p>
                        
                        <ul class="pricing-features">
                            @if (jobLimit == -1)
                            {
                                <li><i class="fas fa-check-circle"></i> Không giới hạn tin đăng</li>
                            }
                            else
                            {
                                <li><i class="fas fa-check-circle"></i> @jobLimit tin đăng / tháng</li>
                            }
                            
                            @if (aiLimit > 0)
                            {
                                <li><i class="fas fa-check-circle"></i> @aiLimit lượt lọc CV bằng AI / tháng</li>
                            }
                            else if (aiLimit == -1)
                            {
                                <li><i class="fas fa-check-circle"></i> Không giới hạn lọc CV bằng AI</li>
                            }
                            else
                            {
                                <li><i class="fas fa-times-circle text-muted"></i> <span class="text-muted">Không có tính năng lọc CV bằng AI</span></li>
                            }
                            
                            <li><i class="fas fa-check-circle"></i> Hiển thị đến @plan.DurationDays ngày</li>
                        </ul>

                        @if (plan.Price > 3000000 || plan.Price > 7000000)
                        {
                            <div style="border-top: 1px solid #e9ecef; padding-top: 20px;">
                                @if (plan.Price > 3000000)
                                {
                                    <div class="mb-2"><i class="fas fa-check-circle text-success"></i> Hỗ trợ ưu tiên</div>
                                }
                                @if (plan.Price > 7000000)
                                {
                                    <div class="mb-2"><i class="fas fa-check-circle text-success"></i> Branding công ty</div>
                                }
                            </div>
                        }

                        @if (plan.Price == 0)
                        {
                            <button class="btn btn-pricing btn-pricing-outline" disabled>Gói hiện tại</button>
                        }
                        else if (plan.Price > 8000000)
                        {
                            <a asp-controller="Payment" asp-action="PlanDetail" asp-route-id="@plan.Id" class="btn btn-pricing btn-pricing-outline">Liên hệ tư vấn</a>
                        }
                        else
                        {
                            <a asp-controller="Payment" asp-action="PlanDetail" asp-route-id="@plan.Id" class="btn btn-pricing @(isFeatured ? "btn-pricing-primary" : "btn-pricing-outline")">Chọn gói</a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Hiện chưa có gói dịch vụ nào. Vui lòng quay lại sau.
                </div>
            </div>
        }
    </div>
</div>

<!-- Comparison Table -->
<div class="container my-5">
    <h2 class="text-center fw-bold mb-4">So sánh gói</h2>
    <div class="comparison-table">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th style="width: 40%">Tính năng</th>
                    <th class="text-center">Basic</th>
                    <th class="text-center featured-col">Pro</th>
                    <th class="text-center">Enterprise</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-semibold">Tin đăng / tháng</td>
                    <td class="text-center">10</td>
                    <td class="text-center featured-col">30</td>
                    <td class="text-center">Không giới hạn</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Lượt xem CV / tháng</td>
                    <td class="text-center">100</td>
                    <td class="text-center featured-col">500</td>
                    <td class="text-center">Không giới hạn</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Lượt tải CV</td>
                    <td class="text-center">50</td>
                    <td class="text-center featured-col">200</td>
                    <td class="text-center">Không giới hạn</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Tài khoản HR</td>
                    <td class="text-center">1</td>
                    <td class="text-center featured-col">3</td>
                    <td class="text-center">10</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Lọc CV theo từ khóa</td>
                    <td class="text-center"><i class="fas fa-check text-success"></i></td>
                    <td class="text-center featured-col"><i class="fas fa-check text-success"></i></td>
                    <td class="text-center"><i class="fas fa-check text-success"></i></td>
                </tr>
                <tr>
                    <td class="fw-semibold">Hỗ trợ ưu tiên</td>
                    <td class="text-center"><i class="fas fa-times text-secondary"></i></td>
                    <td class="text-center featured-col"><i class="fas fa-check text-success"></i></td>
                    <td class="text-center"><i class="fas fa-check text-success"></i></td>
                </tr>
                <tr>
                    <td class="fw-semibold">Branding công ty</td>
                    <td class="text-center"><i class="fas fa-times text-secondary"></i></td>
                    <td class="text-center featured-col"><i class="fas fa-times text-secondary"></i></td>
                    <td class="text-center"><i class="fas fa-check text-success"></i></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- FAQ Section -->
<div class="container my-5">
    <h2 class="text-center fw-bold mb-4">Câu hỏi thường gặp</h2>
    <div class="faq-section">
        <div class="faq-item">
            <div class="faq-question">
                <span>Gói cơ bản khác gì so với gói Pro?</span>
                <i class="fas fa-chevron-down"></i>
            </div>
        </div>
        <div class="faq-item">
            <div class="faq-question">
                <span>Có xuất hóa đơn VAT không?</span>
                <i class="fas fa-chevron-down"></i>
            </div>
        </div>
        <div class="faq-item">
            <div class="faq-question">
                <span>Nâng cấp gói giữa kỳ có được không?</span>
                <i class="fas fa-chevron-down"></i>
            </div>
        </div>
        <div class="faq-item">
            <div class="faq-question">
                <span>Hoàn tiền khi hủy gói như thế nào?</span>
                <i class="fas fa-chevron-down"></i>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // FAQ accordion
    document.querySelectorAll('.faq-question').forEach(item => {
        item.addEventListener('click', function() {
            const icon = this.querySelector('i');
            icon.classList.toggle('fa-chevron-down');
            icon.classList.toggle('fa-chevron-up');
        });
    });
</script>
}
