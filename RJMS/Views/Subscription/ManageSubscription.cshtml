@model SubscriptionListViewModel
@using RJMS.vn.edu.fpt.Models.DTOs
@{
    ViewData["Title"] = "Quản lý gói đăng ký";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["HidePageTitle"] = true;
}

@section Styles {
<style>
    /* ===== Page header toolbar ===== */
    .sub-toolbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 18px;
        gap: 16px;
    }
    .sub-toolbar h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px;
    }
    .sub-toolbar p { font-size: 0.84rem; color: #6b7280; margin: 0; }

    .btn-create {
        background: #00b14f;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 0.875rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
        flex-shrink: 0;
    }
    .btn-create:hover { background: #009744; color: #fff; }

    /* ===== Summary cards ===== */
    .sub-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 16px;
    }
    .sum-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }
    .sum-card-left small {
        font-size: 0.78rem;
        color: #9ca3af;
        display: block;
        margin-bottom: 4px;
    }
    .sum-card-left strong { font-size: 1.75rem; font-weight: 700; color: #111827; }
    .sum-card-left span { font-size: 0.78rem; color: #00b14f; margin-top: 2px; display: block; }
    .sum-icon {
        width: 46px; height: 46px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
    }

    /* ===== Filter bar ===== */
    .sub-filterbar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
    }
    .sub-search {
        position: relative;
        flex: 1;
        min-width: 180px;
        max-width: 300px;
    }
    .sub-search input {
        padding-left: 12px;
        border-radius: 8px;
        border: 1px solid #d1d5db;
        font-size: 0.85rem;
        height: 38px;
        width: 100%;
    }
    .sub-search input:focus { border-color: #00b14f; outline: none; box-shadow: 0 0 0 3px rgba(0,177,79,0.12); }
    .sub-filterbar .form-select {
        border-radius: 8px;
        border: 1px solid #d1d5db;
        font-size: 0.85rem;
        height: 38px;
        min-width: 130px;
    }
    .btn-filter-icon {
        width: 38px; height: 38px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #6b7280; flex-shrink: 0;
    }
    .btn-filter-icon:hover { background: #f3f4f6; }

    /* ===== Table ===== */
    .sub-table-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 16px;
    }
    .sub-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
    .sub-table thead tr { border-bottom: 1px solid #f3f4f6; }
    .sub-table th {
        padding: 12px 14px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        white-space: nowrap;
        background: #fafafa;
    }
    .sub-table td {
        padding: 12px;
        border-bottom: 1px solid #f9fafb;
        vertical-align: middle;
        color: #374151;
    }
    .sub-table tr:last-child td { border-bottom: none; }
    .sub-table tr:hover td { background: #f9fafb; }

    .plan-name { font-weight: 700; color: #111827; }
    .plan-code { font-size: 0.72rem; color: #9ca3af; margin-top: 2px; }

    /* Billing cycle badge */
    .bc-badge { display: inline-block; padding: 3px 8px; border-radius: 16px; font-size: 0.7rem; font-weight: 600; margin-top: 4px; }
    .bc-monthly { background: #dbeafe; color: #1e40af; }
    .bc-yearly  { background: #fef3c7; color: #92400e; }

    /* Plan type badges */
    .pt-badge { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 700; }
    .pt-basic    { background: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }
    .pt-standard { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .pt-premium  { background: #fdf4ff; color: #7c3aed; border: 1px solid #e9d5ff; }

    /* Status */
    .st-active   { background: #dcfce7; color: #15803d; padding: 3px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
    .st-inactive { background: #f3f4f6; color: #6b7280; padding: 3px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }

    /* Feature cell */
    .feat-on  { color: #00b14f; font-size: 0.8rem; font-weight: 600; }
    .feat-off { color: #9ca3af; font-size: 0.8rem; }

    /* Action buttons */
    .act-btn {
        height: 30px;
        padding: 0 12px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 500;
        transition: all 0.15s;
        text-decoration: none;
        white-space: nowrap;
    }
    .act-btn:hover { background: #f3f4f6; border-color: #d1d5db; }
    .act-view   { color: #6b7280; }
    .act-edit   { color: #3b82f6; border-color: #3b82f6; }
    .act-edit:hover { background: #eff6ff; }
    .act-toggle { color: #f97316; border-color: #f97316; }
    .act-toggle:hover { background: #fff7ed; }
    .act-delete { color: #ef4444; border-color: #ef4444; }
    .act-delete:hover { background: #fee2e2; }
    
    /* Action buttons container */
    .action-btns {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
        align-items: center;
    }

    /* ===== Pagination ===== */
    .sub-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 14px;
        font-size: 0.82rem;
        color: #6b7280;
        border-top: 1px solid #f3f4f6;
        background: #fff;
        border-radius: 0 0 12px 12px;
        margin-top: -16px;
    }
    .pg-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: 0.82rem;
        color: #374151;
        text-decoration: none;
        background: #fff;
        cursor: pointer;
        transition: all 0.15s;
    }
    .pg-btn:hover { border-color: #00b14f; color: #00b14f; }
    .pg-btn.active { background: #00b14f; border-color: #00b14f; color: #fff; }
    .pg-btn-text {
        padding: 0 14px; height: 32px; border: 1px solid #e5e7eb;
        border-radius: 6px; font-size: 0.82rem; color: #374151;
        display: inline-flex; align-items: center;
        text-decoration: none; background: #fff;
        cursor: pointer; transition: all 0.15s;
    }
    .pg-btn-text:hover { border-color: #00b14f; color: #00b14f; }

    /* ===== Alert info bar ===== */
    .sub-alerts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 4px;
    }
    .sub-alert-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px 18px;
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }
    .sub-alert-icon { font-size: 1.1rem; flex-shrink: 0; padding-top: 2px; }
    .sub-alert-title { font-size: 0.85rem; font-weight: 600; color: #111827; margin-bottom: 4px; }
    .sub-alert-desc  { font-size: 0.78rem; color: #6b7280; line-height: 1.5; }

    /* ===== Modal ===== */
    .modal-header-custom {
        background: linear-gradient(135deg, #00b14f, #009744);
        color: #fff;
        border-radius: 12px 12px 0 0;
        padding: 18px 24px;
    }
    .modal-content { border-radius: 12px; border: none; box-shadow: 0 20px 60px rgba(0,0,0,0.15); }
    .form-label-sm { font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 4px; }
    .form-control-sm2 {
        font-size: 0.85rem; border: 1px solid #d1d5db;
        border-radius: 7px; padding: 8px 12px;
        transition: border-color 0.15s;
    }
    .form-control-sm2:focus { border-color: #00b14f; outline: none; box-shadow: 0 0 0 3px rgba(0,177,79,0.1); }
</style>
}

<!-- Toolbar -->
<div class="sub-toolbar">
    <div>
        <h1>Quản lý gói đăng ký</h1>
        <p>Quản lý các gói dịch vụ dành cho nhà tuyển dụng trên nền tảng Finding Jobs.</p>
    </div>
    <a asp-action="CreatePlan" class="btn-create">
        Tạo gói đăng ký mới
    </a>
</div>

<!-- Summary cards -->
<div class="sub-summary">
    <div class="sum-card">
        <div class="sum-card-left">
            <small>Tổng số gói</small>
            <strong>@Model.TotalPlans</strong>
        </div>
    </div>
    <div class="sum-card">
        <div class="sum-card-left">
            <small>Gói hoạt động</small>
            <strong>@Model.ActivePlans.ToString("D2")</strong>
        </div>
    </div>
    <div class="sum-card">
        <div class="sum-card-left">
            <small>Nhà tuyển dụng sử dụng</small>
            <strong>@Model.RecruitersUsing.ToString("N0")</strong>
        </div>
    </div>
</div>

<!-- Filter bar -->
<form method="get" asp-action="ManageSubscription">
    <div class="sub-filterbar">
        <div class="sub-search">
            <input name="keyword" value="@Model.SearchKeyword" placeholder="Tìm kiếm tên gói..." />
        </div>

        <span style="font-size:0.83rem;color:#374151;font-weight:500;white-space:nowrap;">Trạng thái:</span>
        <select name="status" class="form-select" style="width:150px;">
            <option value="" selected="@(string.IsNullOrEmpty(Model.StatusFilter))">Tất cả</option>
            @foreach (var statusOption in Model.StatusOptions)
            {
                <option value="@statusOption.Value" selected="@(string.Equals(Model.StatusFilter, statusOption.Value, StringComparison.OrdinalIgnoreCase))">@statusOption.Label</option>
            }
        </select>

        <span style="font-size:0.83rem;color:#374151;font-weight:500;white-space:nowrap;">Loại gói:</span>
        <select name="type" class="form-select" style="width:130px;">
            <option value="" selected="@(string.IsNullOrEmpty(Model.TypeFilter))">Tất cả</option>
            <option value="Basic"    selected="@(Model.TypeFilter == "Basic"   )">Basic</option>
            <option value="Standard" selected="@(Model.TypeFilter == "Standard")">Standard</option>
            <option value="Premium"  selected="@(Model.TypeFilter == "Premium" )">Premium</option>
        </select>

        <button type="submit" class="btn-filter-icon" title="Lọc">
            Lọc
        </button>
    </div>
</form>

<!-- Table -->
<div class="sub-table-card">
    <table class="sub-table">
        <thead>
            <tr>
                <th>Tên gói đăng ký</th>
                <th>Loại gói</th>
                <th>Chu kỳ</th>
                <th>Giá</th>
                <th>Giới hạn tin</th>
                <th>Lọc CV AI</th>
                <th>Thời hạn</th>
                <th>Trạng thái</th>
                <th>Ngày tạo</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Plans.Any())
            {
                <tr><td colspan="9" class="text-center text-muted py-5">Không có dữ liệu</td></tr>
            }
            @foreach (var p in Model.Plans)
            {
                <tr>
                    <td>
                        <div class="plan-name">@p.Name</div>
                        <div class="plan-code">@p.Code</div>
                    </td>
                    <td>
                        @{
                            var ptCls = p.PlanType switch
                            {
                                "Standard" => "pt-standard",
                                "Premium"  => "pt-premium",
                                _          => "pt-basic"
                            };
                        }
                        <span class="pt-badge @ptCls">@p.PlanType</span>
                    </td>
                    <td>
                        @{
                            var bcCls = p.BillingCycle == "Yearly" ? "bc-yearly" : "bc-monthly";
                            var bcText = p.BillingCycle == "Yearly" ? "Hàng năm" : "Hàng tháng";
                        }
                        <span class="bc-badge @bcCls">@bcText</span>
                    </td>
                    <td>
                        @if (p.Price == 0)
                        { <span>0 VND</span> }
                        else
                        { <span>@p.Price.ToString("N0") VND</span> }
                    </td>
                    <td>
                        @if (p.JobLimit.HasValue)
                        { <span>@p.JobLimit tin/tháng</span> }
                        else
                        { <span class="feat-off">Không giới hạn</span> }
                    </td>
                    <td>
                        @if (p.CvAiLimit.HasValue)
                        {
                            @if (p.CvAiLimit.Value > 0)
                            {
                                <span class="feat-on">@p.CvAiLimit CV/tháng</span>
                            }
                            else
                            {
                                <span class="feat-off">@p.CvAiLimit CV/tháng</span>
                            }
                        }
                        else
                        {
                            <span class="feat-off">Chưa cấu hình</span>
                        }
                    </td>
                    <td>
                        @if (p.DurationDays == 0)
                        { <span>Vĩnh viễn</span> }
                        else
                        { <span>@p.DurationDays ngày</span> }
                    </td>
                    <td>
                        @if (p.IsActive)
                        { <span class="st-active">Hoạt động</span> }
                        else
                        { <span class="st-inactive">Ngừng hoạt động</span> }
                    </td>
                    <td style="font-size:0.8rem;color:#6b7280;">
                        @(p.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")
                    </td>
                    <td>
                        <div class="action-btns">
                            <!-- Edit -->
                            <a class="act-btn act-edit" title="Sửa"
                               asp-controller="Subscription" asp-action="EditPlan" asp-route-id="@p.Id">
                                Sửa
                            </a>

                            <!-- Toggle status -->
                            <form asp-controller="Subscription" asp-action="ToggleStatus"
                                  asp-route-id="@p.Id" method="post" style="display:inline;" class="confirm-toggle">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="act-btn act-toggle" title="Chuyển trạng thái">
                                    Bật/Tắt
                                </button>
                            </form>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    <div class="sub-pagination">
        <span>Hiển thị <strong>@((Model.Page-1)*Model.PageSize+1)–@Math.Min(Model.Page*Model.PageSize,Model.TotalItems)</strong> trong tổng số <strong>@Model.TotalItems</strong> gói</span>
        <div style="display:flex;gap:6px;align-items:center;">
            @if (Model.Page > 1)
            {
                <a class="pg-btn-text" asp-action="ManageSubscription"
                   asp-route-keyword="@Model.SearchKeyword"
                   asp-route-status="@Model.StatusFilter"
                   asp-route-type="@Model.TypeFilter"
                   asp-route-page="@(Model.Page-1)">Trước</a>
            }
            else
            {
                <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Trước</span>
            }

            @for (int pg = 1; pg <= Math.Min(Model.TotalPages, 5); pg++)
            {
                <a class="pg-btn @(pg == Model.Page ? "active" : "")"
                   asp-action="ManageSubscription"
                   asp-route-keyword="@Model.SearchKeyword"
                   asp-route-status="@Model.StatusFilter"
                   asp-route-type="@Model.TypeFilter"
                   asp-route-page="@pg">@pg</a>
            }

            @if (Model.Page < Model.TotalPages)
            {
                <a class="pg-btn-text" asp-action="ManageSubscription"
                   asp-route-keyword="@Model.SearchKeyword"
                   asp-route-status="@Model.StatusFilter"
                   asp-route-type="@Model.TypeFilter"
                   asp-route-page="@(Model.Page+1)">Sau</a>
            }
            else
            {
                <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Sau</span>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ===== Confirm dialogs =====
    document.querySelectorAll('.confirm-toggle').forEach(f => {
        f.addEventListener('submit', e => {
            if (!confirm('Thay đổi trạng thái gói này?')) e.preventDefault();
        });
    });
    document.querySelectorAll('.confirm-delete').forEach(f => {
        f.addEventListener('submit', e => {
            const name = f.dataset.name || '';
            if (!confirm('Xác nhận xóa gói "' + name + '"?')) e.preventDefault();
        });
    });
</script>
}


