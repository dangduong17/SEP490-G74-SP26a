@model SubscriptionPlanFormViewModel
@using RJMS.vn.edu.fpt.Models.DTOs
@{
    ViewData["Title"] = "Chỉnh sửa gói đăng ký";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
<style>
    /* ===== Page container ===== */
    .edit-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* ===== Breadcrumb ===== */
    .breadcrumb-nav {
        font-size: 0.8rem;
        color: #9ca3af;
        margin-bottom: 16px;
    }
    .breadcrumb-nav strong { color: #374151; }

    /* ===== Page header ===== */
    .page-header {
        margin-bottom: 28px;
    }
    .page-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 8px;
    }
    .page-header p {
        font-size: 0.875rem;
        color: #6b7280;
        margin: 0;
    }

    /* ===== Form card ===== */
    .form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 32px;
        margin-bottom: 24px;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid #f3f4f6;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* ===== Form elements ===== */
    .form-label-custom {
        font-size: 0.875rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }
    .form-label-custom .required {
        color: #ef4444;
        margin-left: 2px;
    }
    .form-label-custom .hint {
        font-weight: 400;
        color: #9ca3af;
        font-size: 0.8rem;
        margin-left: 8px;
    }

    .form-control-custom {
        font-size: 0.875rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 10px 14px;
        transition: border-color 0.15s, box-shadow 0.15s;
        width: 100%;
    }
    .form-control-custom:focus {
        border-color: #00b14f;
        outline: none;
        box-shadow: 0 0 0 3px rgba(0, 177, 79, 0.1);
    }

    .form-select-custom {
        font-size: 0.875rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 10px 14px;
        transition: border-color 0.15s, box-shadow 0.15s;
        width: 100%;
        background-color: #fff;
        cursor: pointer;
    }
    .form-select-custom:focus {
        border-color: #00b14f;
        outline: none;
        box-shadow: 0 0 0 3px rgba(0, 177, 79, 0.1);
    }

    textarea.form-control-custom {
        resize: vertical;
        min-height: 100px;
    }

    .input-group-addon {
        font-size: 0.85rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #d1d5db;
        border-left: none;
        border-radius: 0 8px 8px 0;
        padding: 10px 14px;
        display: flex;
        align-items: center;
    }

    .form-check-custom {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s;
    }
    .form-check-custom:hover {
        background: #f3f4f6;
    }
    .form-check-custom input[type="checkbox"] {
        width: 20px;
        height: 20px;
        cursor: pointer;
        accent-color: #00b14f;
    }
    .form-check-custom label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #374151;
        cursor: pointer;
        margin: 0;
        flex: 1;
    }

    .text-muted-small {
        font-size: 0.8rem;
        color: #9ca3af;
        margin-top: 6px;
        display: block;
    }

    /* ===== Validation ===== */
    .text-danger {
        font-size: 0.8rem;
        color: #ef4444;
        margin-top: 4px;
        display: block;
    }

    .form-control-custom.input-validation-error,
    .form-select-custom.input-validation-error {
        border-color: #ef4444;
    }

    /* ===== Action buttons ===== */
    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding-top: 24px;
        border-top: 1px solid #f3f4f6;
        margin-top: 32px;
    }

    .btn-custom {
        padding: 11px 24px;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-cancel {
        background: #fff;
        color: #6b7280;
        border: 1px solid #d1d5db;
    }
    .btn-cancel:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    .btn-save {
        background: #00b14f;
        color: #fff;
    }
    .btn-save:hover {
        background: #009744;
        color: #fff;
    }

    /* ===== Grid layout ===== */
    .form-row {
        display: grid;
        gap: 16px;
        margin-bottom: 16px;
    }
    .form-row.cols-2 {
        grid-template-columns: 1fr 1fr;
    }
    .form-row.cols-3 {
        grid-template-columns: 1fr 1fr 1fr;
    }

    @@media (max-width: 768px) {
        .form-row.cols-2,
        .form-row.cols-3 {
            grid-template-columns: 1fr;
        }
    }
</style>
}

<div class="edit-container">
    <!-- Page header -->
    <div class="page-header">
        <h1>Chỉnh sửa gói đăng ký</h1>
        <p>Cập nhật thông tin và cấu hình cho gói dịch vụ đã tạo.</p>
    </div>

    <!-- Form -->
    <form asp-action="EditPlan" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Basic Info Section -->
        <div class="form-card">
            <div class="section-title">
                Thông tin cơ bản
            </div>

            <div class="form-row cols-2">
                <div>
                    <label class="form-label-custom">
                        Tên gói <span class="required">*</span>
                    </label>
                    <input asp-for="Name" class="form-control-custom" placeholder="VD: Premium Enterprise" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div>
                    <label class="form-label-custom">
                        Loại gói <span class="required">*</span>
                    </label>
                    <select asp-for="PlanType" class="form-select-custom">
                        <option value="Basic">Basic</option>
                        <option value="Standard">Standard</option>
                        <option value="Premium">Premium</option>
                    </select>
                    <span asp-validation-for="PlanType" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div>
                    <label class="form-label-custom">
                        Mô tả gói
                    </label>
                    <textarea asp-for="Description" class="form-control-custom" rows="4" 
                              placeholder="Mô tả chi tiết về nội dung và quyền lợi của gói..."></textarea>
                    <span class="text-muted-small">Mô tả sẽ hiển thị trên trang chọn gói dịch vụ</span>
                </div>
            </div>
        </div>

        <!-- Pricing & Limits Section -->
        <div class="form-card">
            <div class="section-title"  >
                Giá và giới hạn
            </div>

            <div class="form-row cols-2">
                <div>
                    <label class="form-label-custom">
                        Giá / tháng <span class="required">*</span>
                    </label>
                    <div style="display:flex;">
                        <input asp-for="Price" type="number" min="0" step="1000" 
                               class="form-control-custom" placeholder="0" 
                               style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                        <span class="input-group-addon">VND</span>
                    </div>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div>
                    <label class="form-label-custom">
                        Giá / năm
                    </label>
                    <div style="display:flex;">
                        <input asp-for="YearlyPrice" type="number" min="0" step="1000"
                               class="form-control-custom" placeholder="0"
                               style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                        <span class="input-group-addon">VND</span>
                    </div>
                    <span asp-validation-for="YearlyPrice" class="text-danger"></span>
                    <div class="form-check-custom" style="margin-top:8px; padding: 8px 12px; background: none; border: none;">
                        <input asp-for="EnableYearly" type="checkbox" id="enableYearly" />
                        <label for="enableYearly" style="margin-left: 8px;">Bật gói năm</label>
                    </div>
                </div>
            </div>

            <div class="form-row cols-2">
                <div>
                    <label class="form-label-custom">
                        Giới hạn tin đăng
                    </label>
                    <div style="display:flex;">
                        <input asp-for="JobLimit" type="number" min="1" 
                               class="form-control-custom" placeholder="Không giới hạn" 
                               style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                        <span class="input-group-addon">tin/tháng</span>
                    </div>
                    <span asp-validation-for="JobLimit" class="text-danger"></span>
                </div>

                <div>
                    <label class="form-label-custom">
                        Lọc CV bằng AI
                    </label>
                    <div style="display:flex;">
                        <input asp-for="CvAiLimit" type="number" min="1" 
                               class="form-control-custom" placeholder="Không giới hạn" 
                               style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                        <span class="input-group-addon">CV/tháng</span>
                    </div>
                    <span asp-validation-for="CvAiLimit" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row cols-2">
                <div>
                    <label class="form-label-custom">
                        Thời hạn gói <span class="required">*</span>
                    </label>
                    <div style="display:flex;">
                        <input asp-for="DurationDays" type="number" min="1" max="3650" 
                               class="form-control-custom" placeholder="30" 
                               style="border-top-right-radius:0;border-bottom-right-radius:0;" />
                        <span class="input-group-addon">ngày</span>
                    </div>
                    <span asp-validation-for="DurationDays" class="text-danger"></span>
                </div>

                <div>
                    <label class="form-label-custom">
                        Chu kỳ thanh toán
                    </label>
                    <input class="form-control-custom" value="Hàng tháng / Hàng năm" disabled />
                </div>
            </div>

        </div>

        <!-- Status Section -->
        <div class="form-card">
            <div class="section-title">
                Trạng thái
            </div>

            <div class="form-check-custom">
                <input asp-for="IsActive" type="checkbox" id="chkActive" />
                <label for="chkActive">
                    <strong>Kích hoạt gói</strong>
                    <span style="display:block;font-size:0.8rem;color:#6b7280;margin-top:2px;">
                        Gói sẽ hiển thị cho nhà tuyển dụng có thể đăng ký
                    </span>
                </label>
            </div>
        </div>

        <!-- Action buttons -->
        <div class="form-actions">
            <a asp-action="ManageSubscription" class="btn-custom btn-cancel">
                Hủy
            </a>
            <button type="submit" class="btn-custom btn-save">
                Lưu thay đổi
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
