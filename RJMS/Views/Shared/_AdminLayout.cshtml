@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}
<style>
    /* Ensure main element has no extra spacing in admin layout */
    main[role="main"] {
        padding: 0;
        margin: 0;
    }

    /* Reduce line-height and spacing for admin area */
    body {
        line-height: 1.4;
    }

    .form-label {
        margin-bottom: 0.3rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        padding: 0.4rem 0.75rem;
        font-size: 0.9rem;
    }

    /* Reduce gap between form rows */
    .row.g-3 {
        --bs-gutter-y: 0.8rem;
    }

    /* Compact buttons */
    .btn-sm {
        padding: 0.35rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.3;
    }

    /* ===== Admin page wrapper: flex column full height ===== */
    .admin-page-wrapper {
        display: flex;
        flex-direction: column;
        margin: 10px 12px 14px;
        min-height: calc(100vh - 70px); /* subtract header height */
    }

    /* ===== Inner flex: sidebar + content side by side ===== */
    .admin-body-wrapper {
        display: flex;
        gap: 12px;
        flex: 1 0 auto; /* grow to push footer down */
    }

    /* ===== Sidebar: NOT fixed, flows in the layout ===== */
    .admin-sidebar {
        width: 220px;
        min-width: 220px;
        flex-shrink: 0;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        /* Match header background exactly so no seam */
        background: #fff;
        overflow-y: auto;
    }

    .admin-sidebar .nav-link {
        color: #343a40;
        padding: 9px 18px;
        border-left: 3px solid transparent;
        border-radius: 0;
        font-weight: 500;
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .admin-sidebar .nav-link:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .admin-sidebar .nav-link.active {
        background: #f0fdf4;
        color: #00b14f;
        border-left-color: #00b14f;
        font-weight: 600;
    }

    .admin-sidebar .nav-details {
        margin: 0;
    }

    .admin-sidebar .nav-summary {
        list-style: none;
        cursor: pointer;
        user-select: none;
        color: #343a40;
        padding: 9px 18px;
        border-left: 3px solid transparent;
        border-radius: 0;
        font-weight: 500;
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .admin-sidebar .nav-summary::-webkit-details-marker {
        display: none;
    }

    .admin-sidebar .nav-summary:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .admin-sidebar .nav-details[open] > .nav-summary {
        background: #f0fdf4;
        color: #00b14f;
        border-left-color: #00b14f;
        font-weight: 600;
    }

    .admin-sidebar .nav-subgroup {
        padding: 4px 0 10px;
    }

    .admin-sidebar .nav-subsection {
        padding: 10px 18px 4px;
        font-size: 0.66rem;
        text-transform: uppercase;
        color: #adb5bd;
        letter-spacing: 0.07em;
    }

    .admin-sidebar .nav-sublink {
        color: #495057;
        padding: 7px 18px 7px 34px;
        font-size: 0.84rem;
        display: flex;
        align-items: center;
        gap: 8px;
        border-left: 3px solid transparent;
        text-decoration: none;
    }

    .admin-sidebar .nav-sublink:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .admin-sidebar .nav-sublink.active {
        background: #f0fdf4;
        color: #00b14f;
        border-left-color: #00b14f;
        font-weight: 600;
    }

    .admin-sidebar .nav-section {
        padding: 12px 18px 4px;
        font-size: 0.68rem;
        text-transform: uppercase;
        color: #adb5bd;
        letter-spacing: 0.07em;
    }

    /* ===== Header: full width, white, no left margin ===== */
    /* The header is already sticky via site-header in site.css.
       We override the admin layout's previous margin-left hack. */
    .site-header {
        margin-left: 0 !important;
        width: 100% !important;
        background: #fff !important;
        position: sticky;
        top: 0;
        z-index: 1000;
        border-bottom: 1px solid #e5e7eb;
    }

    /* ===== Footer: also full width ===== */
    .site-footer {
        margin-left: 0 !important;
        width: 100% !important;
        flex-shrink: 0;
        margin-top: 10px;
        border-top: 1px solid #e5e7eb;
    }

    /* ===== Main content area ===== */
    .admin-content {
        flex: 1;
        background: #f4f6f8;
        padding: 24px;
        min-width: 0;
        overflow: auto;
        border: 1px solid #dee2e6;
        border-radius: 10px;
    }
    /* Builder pages need zero padding + no scroll at this level */
    .admin-content--builder {
        padding: 0 !important;
        overflow: hidden !important;
        background: #f1f5f9;
    }

    .admin-page-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 14px;
        padding-bottom: 10px;
        border-bottom: 1px solid #dee2e6;
        color: #212529;
    }

    .admin-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 20px;
    }

    .btn-topcv {
        background: #00b14f;
        border-color: #00b14f;
        color: #fff;
    }

    .btn-topcv:hover {
        background: #009744;
        border-color: #009744;
        color: #fff;
    }

    /* Shared action buttons from ManageSubscription */
    .btn-create {
        background: #00b14f;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 0.875rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
        flex-shrink: 0;
    }
    .btn-create:hover { background: #009744; color: #fff; }

    .btn-filter-icon {
        width: 38px; height: 38px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: #fff;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #6b7280; flex-shrink: 0;
    }
    .btn-filter-icon:hover { background: #f3f4f6; }

    .act-btn {
        height: 30px;
        padding: 0 12px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 500;
        transition: all 0.15s;
        text-decoration: none;
        white-space: nowrap;
    }
    .act-btn:hover { background: #f3f4f6; border-color: #d1d5db; }
    .act-view   { color: #6b7280; }
    .act-view:hover { background: #f3f4f6; }
    .act-edit   { color: #3b82f6; border-color: #3b82f6; }
    .act-edit:hover { background: #eff6ff; }
    .act-toggle { color: #f97316; border-color: #f97316; }
    .act-toggle:hover { background: #fff7ed; }
    .act-delete { color: #ef4444; border-color: #ef4444; }
    .act-delete:hover { background: #fee2e2; }
    
    .action-btns {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
        align-items: center;
    }

    /* Adjust alert spacing */
    .alert {
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
    }

    /* Sidebar logo area */
    .admin-sidebar-logo {
        padding: 14px 18px;
        border-bottom: 1px solid #dee2e6;
        font-weight: 700;
        font-size: 0.85rem;
        color: #6c757d;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    /* ===== Shared Table/List Page Styles from ManageSubscription ===== */
    .sub-toolbar {
        display: flex; align-items: flex-start; justify-content: space-between;
        margin-bottom: 24px; gap: 16px;
    }
    .sub-toolbar h1 { font-size: 1.5rem; font-weight: 700; color: #111827; margin: 0 0 4px; }
    .sub-toolbar p { font-size: 0.84rem; color: #6b7280; margin: 0; }

    .sub-filterbar {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 20px; padding: 16px;
        background: #fff; border: 1px solid #e5e7eb; border-radius: 12px;
    }
    .sub-search { position: relative; flex: 1; min-width: 180px; max-width: 300px; }
    .sub-search input {
        padding: 0 12px; border-radius: 8px; border: 1px solid #d1d5db;
        font-size: 0.85rem; height: 38px; width: 100%;
    }
    .sub-search input:focus { border-color: #00b14f; outline: none; box-shadow: 0 0 0 3px rgba(0,177,79,0.12); }
    .sub-filterbar .form-select {
        border-radius: 8px; border: 1px solid #d1d5db;
        font-size: 0.85rem; height: 38px; min-width: 140px;
    }
    .sub-filterbar .form-select:focus { border-color: #00b14f; outline: none; box-shadow: 0 0 0 3px rgba(0,177,79,0.12); }
    .filter-label { font-size: 0.83rem; color: #374151; font-weight: 500; white-space: nowrap; }

    .sub-table-card {
        background: #fff; border: 1px solid #e5e7eb; border-radius: 12px;
        overflow: hidden; margin-bottom: 16px;
    }
    .sub-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
    .sub-table thead tr { border-bottom: 1px solid #f3f4f6; }
    .sub-table th {
        padding: 12px 14px; font-size: 0.78rem; font-weight: 700;
        color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em;
        white-space: nowrap; background: #fafafa; text-align: left;
    }
    .sub-table td {
        padding: 14px; border-bottom: 1px solid #f9fafb;
        vertical-align: middle; color: #374151;
    }
    .sub-table tr:last-child td { border-bottom: none; }
    .sub-table tr:hover td { background: #f9fafb; }

    .sub-pagination {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 14px; font-size: 0.82rem; color: #6b7280;
        border-top: 1px solid #f3f4f6; background: #fff;
    }
    .pg-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border: 1px solid #e5e7eb; border-radius: 6px;
        font-size: 0.82rem; color: #374151; text-decoration: none;
        background: #fff; cursor: pointer; transition: all 0.15s;
    }
    .pg-btn:hover { border-color: #00b14f; color: #00b14f; }
    .pg-btn.active { background: #00b14f; border-color: #00b14f; color: #fff; }
    .pg-btn-text {
        padding: 0 14px; height: 32px; border: 1px solid #e5e7eb;
        border-radius: 6px; font-size: 0.82rem; color: #374151;
        display: inline-flex; align-items: center; text-decoration: none;
        background: #fff; cursor: pointer; transition: all 0.15s;
    }
    .pg-btn-text:hover { border-color: #00b14f; color: #00b14f; }
</style>

<!-- Wrapper for the whole admin area (below header, above footer) -->
<div class="admin-page-wrapper">
    <div class="admin-body-wrapper">

        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-logo">
                Admin Panel
            </div>
            <nav class="nav flex-column pt-1">
                @{
                    var role = Context.Request.Cookies["UserRole"];
                }
                <span class="nav-section">Tổng quan</span>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                   asp-controller="@(role == "Admin" ? "Admin" : "Manager")" asp-action="Index">
                    Bảng điều khiển
                </a>
                <span class="nav-section">Quản lý</span>
                @if (role == "Admin")
                {
                    var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
                    var userGroupOpen = actionName is "UserList" or "EditUser" or "CreateAdmin" or "CreateCandidate" or "CreateRecruiter" or "CreateManager" or "EmployeeList";
                    var userGroupOpenAttr = userGroupOpen ? "open" : null;
                    <details class="nav-details" @userGroupOpenAttr>
                        <summary class="nav-summary">
                            <span>Người dùng</span>
                        </summary>
                        <div class="nav-subgroup">
                            <div class="nav-subsection">Phía quản lí</div>
                            <a class="nav-sublink @(actionName is "UserList" or "EditUser" or "CreateAdmin" or "CreateManager" ? "active" : "")"
                               asp-controller="Admin" asp-action="UserList"
                               asp-route-role="Admin">
                                Admin
                            </a>
                            <a class="nav-sublink @(actionName == "UserList" && ViewContext.HttpContext.Request.Query["role"] == "Manager" ? "active" : "")"
                               asp-controller="Admin" asp-action="UserList"
                               asp-route-role="Manager">
                                Manager
                            </a>

                            <div class="nav-subsection">Phía người dùng</div>
                            <a class="nav-sublink @(actionName is "UserList" or "EditUser" or "CreateRecruiter" or "EmployeeList" ? "active" : "")"
                               asp-controller="Admin" asp-action="UserList"
                               asp-route-role="Recruiter">
                                Recruiter
                            </a>
                            <a class="nav-sublink @(actionName == "UserList" && ViewContext.HttpContext.Request.Query["role"] == "Candidate" ? "active" : "")"
                               asp-controller="Admin" asp-action="UserList"
                               asp-route-role="Candidate">
                                Candidate
                            </a>

                            <div class="nav-subsection">Thao tác</div>
                            <a class="nav-sublink @(actionName == "EmployeeList" ? "active" : "")"
                               asp-controller="Admin" asp-action="EmployeeList">
                                Danh sách nhân viên
                            </a>
                        </div>
                    </details>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "CvTemplates" or "CvTemplateCreate" or "CvTemplateEdit" ? "active" : "")"
                       asp-controller="Admin" asp-action="CvTemplates">
                        Quản lý CV Template
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "TemplateCategories" ? "active" : "")"
                       asp-controller="Admin" asp-action="TemplateCategories">
                        Danh mục Template
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "JobList" or "JobDetail" ? "active" : "")"
                       asp-controller="Admin" asp-action="JobList">
                        Quản lý tin tuyển dụng
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "SubscriptionList" or "SubscriptionDetail" ? "active" : "")"
                       asp-controller="Admin" asp-action="SubscriptionList">
                        Quản lý gói dịch vụ
                    </a>
                }
                else if (role == "Manager")
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "SkillList" or "CreateSkill" or "EditSkill" ? "active" : "")"
                       asp-controller="Manager" asp-action="SkillList">
                        Kỹ năng
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "JobCategoryList" or "CreateJobCategory" or "EditJobCategory" ? "active" : "")"
                       asp-controller="Manager" asp-action="JobCategoryList">
                        Danh mục nghề nghiệp
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "CompanyList" or "CompanyDetail" ? "active" : "")"
                       asp-controller="Manager" asp-action="CompanyList">
                        Công ty
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "SubscriptionList" or "SubscriptionDetail" ? "active" : "")"
                       asp-controller="Manager" asp-action="SubscriptionList">
                        Gói dịch vụ (Recruiter)
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Subscription" ? "active" : "")"
                       asp-controller="Subscription" asp-action="ManageSubscription">
                        Cấu hình Gói Dịch vụ
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "SliderList" or "SliderCreate" or "SliderEdit" ? "active" : "")"
                       asp-controller="Manager" asp-action="SliderList">
                        Quản lý Slider
                    </a>
                }
            </nav>
        </aside>

        <!-- Main content -->
        <div class="admin-content @(ViewData["IsBuilder"] != null && (bool)ViewData["IsBuilder"]! ? "admin-content--builder" : "")">
            @if (ViewData["HidePageTitle"] == null || !(bool)ViewData["HidePageTitle"]!)
            {
                <div class="admin-page-title">@ViewData["Title"]</div>
                <div class="admin-card">
                    @RenderBody()
                </div>
            }
            else
            {
                @RenderBody()
            }
        </div>

    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}

