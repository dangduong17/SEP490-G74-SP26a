@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .admin-sidebar {
        width: 200px;
        min-width: 200px;
        border-right: 1px solid #dee2e6;
        background: #fff;
        min-height: calc(100vh - 70px);
    }

    .admin-sidebar .nav-link {
        color: #343a40;
        padding: 10px 16px;
        border-left: 3px solid transparent;
        border-radius: 0;
        font-weight: 500;
    }

    .admin-sidebar .nav-link:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .admin-sidebar .nav-link.active {
        background: #f0fdf4;
        color: #00b14f;
        border-left-color: #00b14f;
        font-weight: 600;
    }

    .admin-sidebar .nav-section {
        padding: 12px 16px 4px;
        font-size: 0.72rem;
        text-transform: uppercase;
        color: #adb5bd;
        letter-spacing: 0.07em;
    }

    .admin-content {
        background: #f4f6f8;
        flex: 1;
        padding: 24px;
        min-height: calc(100vh - 70px);
    }

    .admin-page-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 16px;
        padding-bottom: 12px;
        border-bottom: 1px solid #dee2e6;
        color: #212529;
    }

    .admin-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 24px;
    }

    .btn-topcv {
        background: #00b14f;
        border-color: #00b14f;
        color: #fff;
    }

    .btn-topcv:hover {
        background: #009744;
        border-color: #009744;
        color: #fff;
    }
</style>

<div class="d-flex">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <nav class="nav flex-column pt-2">
            <span class="nav-section">Tổng quan</span>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
               asp-controller="Admin" asp-action="Index">
                Bảng điều khiển
            </a>
            <span class="nav-section">Quản lý</span>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "UserList" or "EditUser" or "CreateAdmin" or "CreateCandidate" or "CreateRecruiter" ? "active" : "")"
               asp-controller="Admin" asp-action="UserList">
                Người dùng
            </a>
        </nav>
    </aside>

    <!-- Main content -->
    <div class="admin-content">
        <div class="admin-page-title">@ViewData["Title"]</div>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <div class="admin-card">
            @RenderBody()
        </div>
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)
