@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    /* Reduce line-height and spacing for admin area */
    body {
        line-height: 1.4;
    }

    .form-label {
        margin-bottom: 0.3rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        padding: 0.4rem 0.75rem;
        font-size: 0.9rem;
    }

    /* Reduce gap between form rows */
    .row.g-3 {
        --bs-gutter-y: 0.8rem;
    }

    /* Compact buttons */
    .btn-sm {
        padding: 0.35rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.3;
    }

    /* Admin sidebar - fixed position */
    .admin-sidebar {
        position: fixed;
        left: 0;
        top: 70px;
        width: 200px;
        min-width: 200px;
        border-right: 1px solid #dee2e6;
        background: #fff;
        height: calc(100vh - 70px);
        overflow-y: auto;
        z-index: 999;
    }

    .admin-sidebar .nav-link {
        color: #343a40;
        padding: 8px 16px;
        border-left: 3px solid transparent;
        border-radius: 0;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .admin-sidebar .nav-link:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .admin-sidebar .nav-link.active {
        background: #f0fdf4;
        color: #00b14f;
        border-left-color: #00b14f;
        font-weight: 600;
    }

    .admin-sidebar .nav-section {
        padding: 10px 16px 4px;
        font-size: 0.7rem;
        text-transform: uppercase;
        color: #adb5bd;
        letter-spacing: 0.07em;
    }

    /* Push header to align with sidebar */
    .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    /* Main content - with left margin for sidebar */
    .admin-content {
        margin-left: 200px;
        background: #f4f6f8;
        padding: 20px;
        min-height: calc(100vh - 70px);
    }

    .admin-page-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 14px;
        padding-bottom: 10px;
        border-bottom: 1px solid #dee2e6;
        color: #212529;
    }

    .admin-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 20px;
    }

    .btn-topcv {
        background: #00b14f;
        border-color: #00b14f;
        color: #fff;
    }

    .btn-topcv:hover {
        background: #009744;
        border-color: #009744;
        color: #fff;
    }

    /* Adjust alert spacing */
    .alert {
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
    }

    /* Make header and footer respect sidebar */
    .site-header {
        margin-left: 200px;
        width: calc(100% - 200px);
    }

    .site-footer {
        margin-left: 200px;
        width: calc(100% - 200px);
    }
</style>

<!-- Sidebar -->
<aside class="admin-sidebar">
    <nav class="nav flex-column pt-2">
        <span class="nav-section">Tổng quan</span>
        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Admin" asp-action="Index">
            Bảng điều khiển
        </a>
        <span class="nav-section">Quản lý</span>
        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "UserList" or "EditUser" or "CreateAdmin" or "CreateCandidate" or "CreateRecruiter" ? "active" : "")"
           asp-controller="Admin" asp-action="UserList">
            Người dùng
        </a>
    </nav>
</aside>

<!-- Main content -->
<div class="admin-content">
    <div class="admin-page-title">@ViewData["Title"]</div>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="admin-card">
        @RenderBody()
    </div>
</div>

@await RenderSectionAsync("Scripts", required: false)
