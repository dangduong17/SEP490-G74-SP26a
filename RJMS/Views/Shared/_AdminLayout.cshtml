@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}
<style>
    /* Ensure main element has no extra spacing in admin layout */
    main[role="main"] {
        padding: 0;
        margin: 0;
    }

    /* Reduce line-height and spacing for admin area */
    body {
        line-height: 1.4;
    }

    .form-label {
        margin-bottom: 0.3rem;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        padding: 0.4rem 0.75rem;
        font-size: 0.9rem;
    }

    /* Reduce gap between form rows */
    .row.g-3 {
        --bs-gutter-y: 0.8rem;
    }

    /* Compact buttons */
    .btn-sm {
        padding: 0.35rem 0.75rem;
        font-size: 0.875rem;
        line-height: 1.3;
    }

    /* ===== Admin page wrapper: flex column full height ===== */
    .admin-page-wrapper {
        display: flex;
        flex-direction: column;
        min-height: calc(100vh - 70px); /* subtract header height */
    }

    /* ===== Inner flex: sidebar + content side by side ===== */
    .admin-body-wrapper {
        display: flex;
        flex: 1 0 auto; /* grow to push footer down */
    }

    /* ===== Sidebar: NOT fixed, flows in the layout ===== */
    .admin-sidebar {
        width: 220px;
        min-width: 220px;
        flex-shrink: 0;
        border-right: 1px solid #dee2e6;
        /* Match header background exactly so no seam */
        background: #fff;
        overflow-y: auto;
    }

    .admin-sidebar .nav-link {
        color: #343a40;
        padding: 9px 18px;
        border-left: 3px solid transparent;
        border-radius: 0;
        font-weight: 500;
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .admin-sidebar .nav-link:hover {
        background: #f8f9fa;
        color: #212529;
    }

    .admin-sidebar .nav-link.active {
        background: #f0fdf4;
        color: #00b14f;
        border-left-color: #00b14f;
        font-weight: 600;
    }

    .admin-sidebar .nav-section {
        padding: 12px 18px 4px;
        font-size: 0.68rem;
        text-transform: uppercase;
        color: #adb5bd;
        letter-spacing: 0.07em;
    }

    /* ===== Header: full width, white, no left margin ===== */
    /* The header is already sticky via site-header in site.css.
       We override the admin layout's previous margin-left hack. */
    .site-header {
        margin-left: 0 !important;
        width: 100% !important;
        background: #fff !important;
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    /* ===== Footer: also full width ===== */
    .site-footer {
        margin-left: 0 !important;
        width: 100% !important;
        flex-shrink: 0;
    }

    /* ===== Main content area ===== */
    .admin-content {
        flex: 1;
        background: #f4f6f8;
        padding: 24px;
        min-width: 0; /* prevent flex overflow */
    }

    .admin-page-title {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 14px;
        padding-bottom: 10px;
        border-bottom: 1px solid #dee2e6;
        color: #212529;
    }

    .admin-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 20px;
    }

    .btn-topcv {
        background: #00b14f;
        border-color: #00b14f;
        color: #fff;
    }

    .btn-topcv:hover {
        background: #009744;
        border-color: #009744;
        color: #fff;
    }

    /* Adjust alert spacing */
    .alert {
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
    }

    /* Sidebar logo area */
    .admin-sidebar-logo {
        padding: 14px 18px;
        border-bottom: 1px solid #dee2e6;
        font-weight: 700;
        font-size: 0.85rem;
        color: #6c757d;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
</style>

<!-- Wrapper for the whole admin area (below header, above footer) -->
<div class="admin-page-wrapper">
    <div class="admin-body-wrapper">

        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-logo">
                <i class="fas fa-shield-alt me-2 text-success"></i>Admin Panel
            </div>
            <nav class="nav flex-column pt-1">
                <span class="nav-section">Tổng quan</span>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <i class="fas fa-chart-pie fa-sm"></i> Bảng điều khiển
                </a>
                <span class="nav-section">Quản lý</span>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "UserList" or "EditUser" or "CreateAdmin" or "CreateCandidate" or "CreateRecruiter" ? "active" : "")"
                   asp-controller="Admin" asp-action="UserList">
                    <i class="fas fa-users fa-sm"></i> Người dùng
                </a>
            </nav>
        </aside>

        <!-- Main content -->
        <div class="admin-content">
            @if (ViewData["HidePageTitle"] == null || !(bool)ViewData["HidePageTitle"]!)
            {
                <div class="admin-page-title">@ViewData["Title"]</div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            <div class="admin-card">
                @RenderBody()
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}

