<style>
    .profile-dropdown {
        position: relative;
    }
    
    .profile-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e0e7ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: #4f46e5;
        cursor: pointer;
        transition: all 0.2s;
        border: 2px solid #e0e7ff;
    }
    
    .profile-avatar:hover {
        background: #c7d2fe;
        border-color: #c7d2fe;
    }
    
    .profile-menu {
        position: absolute;
        top: 120%;
        right: 0;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        min-width: 320px;
        z-index: 1000;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.3s ease;
    }
    
    .profile-dropdown.show .profile-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }
    
    .profile-header {
        padding: 20px;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }
    
    .profile-header-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: #e0e7ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #4f46e5;
        font-size: 1.2rem;
        flex-shrink: 0;
    }
    
    .profile-header-info h6 {
        margin: 0 0 4px 0;
        font-weight: 600;
        color: #1f2937;
        font-size: 1rem;
    }
    
    .profile-header-info .email {
        color: #6b7280;
        font-size: 0.875rem;
        margin-bottom: 2px;
    }
    
    .profile-header-info .user-id {
        color: #9ca3af;
        font-size: 0.8rem;
    }
    
    .profile-verified {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #dcfce7;
        color: #16a34a;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: 8px;
    }
    
    .profile-menu-section {
        padding: 8px 0;
        border-bottom: 1px solid #f3f4f6;
    }
    
    .profile-menu-section:last-child {
        border-bottom: none;
    }
    
    .profile-menu-item {
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #4b5563;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        position: relative;
    }
    
    .profile-menu-item:hover {
        background: #f9fafb;
        color: #1f2937;
    }
    
    .profile-menu-item i {
        width: 20px;
        font-size: 1.1rem;
        color: #059669;
    }
    
    .profile-menu-item .label {
        flex: 1;
        font-weight: 500;
    }
    
    .profile-menu-item .arrow {
        color: #9ca3af;
        font-size: 0.8rem;
    }
    
    .profile-submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
        background: #f9fafb;
    }
    
    .profile-menu-item.expanded + .profile-submenu {
        max-height: 300px;
    }
    
    .profile-submenu-item {
        padding: 10px 20px 10px 52px;
        color: #6b7280;
        text-decoration: none;
        display: block;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .profile-submenu-item:hover {
        background: #f3f4f6;
        color: #1f2937;
    }
    
    .notification-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background: #ef4444;
        color: white;
        font-size: 0.7rem;
        padding: 2px 6px;
        border-radius: 10px;
        font-weight: 700;
    }
    
    .header-icons {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .header-icon-btn {
        position: relative;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
    }
    
    .header-icon-btn:hover {
        background: #e5e7eb;
        color: #1f2937;
    }
    
    .logout-btn {
        color: #dc2626 !important;
    }
    
    .logout-btn:hover {
        background: #fee2e2 !important;
    }

    .profile-avatar-wrapper {
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
    }

    .profile-avatar-wrapper .avatar-chevron {
        font-size: 0.7rem;
        color: #9ca3af;
        transition: transform 0.2s;
    }

    .profile-dropdown.show .avatar-chevron {
        transform: rotate(180deg);
    }

    /* Notification Styles */
    .notif-dropdown { position:relative; }
    .notif-menu { position:absolute; top:120%; right:-10px; background:white; border-radius:12px; box-shadow:0 10px 40px rgba(0,0,0,0.15); width:360px; max-width:90vw; z-index:1000; opacity:0; visibility:hidden; transform:translateY(-10px); transition:all 0.3s ease; }
    .notif-dropdown.show .notif-menu { opacity:1; visibility:visible; transform:translateY(0); }
    .notif-header { padding:16px 20px; border-bottom:1px solid #e5e7eb; display:flex; justify-content:space-between; align-items:center; }
    .notif-header h6 { margin:0; font-weight:700; font-size:1rem; color:#111827; }
    .mark-read-all { color:#00b14f; font-size:0.85rem; font-weight:600; cursor:pointer; text-decoration:none; }
    .mark-read-all:hover { text-decoration:underline; }
    .notif-body { max-height:400px; overflow-y:auto; }
    .notif-item { padding:12px 20px; border-bottom:1px solid #f3f4f6; display:flex; gap:12px; cursor:pointer; transition:background 0.2s; text-decoration:none; color:inherit; }
    .notif-item:hover { background:#f9fafb; margin-bottom: 0px; }
    .notif-item.unread { background:#f0fdf4; }
    .notif-icon { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:0.9rem; }
    .notif-icon.APPLICATION { background:#dbeafe; color:#2563eb; }
    .notif-icon.PAYMENT { background:#fef3c7; color:#d97706; }
    .notif-icon.SYSTEM { background:#f3f4f6; color:#4b5563; }
    .notif-content { flex:1; min-width:0; }
    .notif-title { font-weight:600; font-size:0.9rem; color:#111827; margin-bottom:2px; }
    .notif-item.unread .notif-title { color:#00b14f; }
    .notif-desc { font-size:0.8rem; color:#6b7280; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; text-overflow: ellipsis; }
    .notif-time { font-size:0.75rem; color:#9ca3af; margin-top:4px; }
    .notif-empty { padding:40px 20px; text-align:center; color:#9ca3af; }
</style>

<header class="site-header">
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <div class="logo-wrapper">
                    <span class="logo-text">Finding Jobs</span>
                </div>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navigation Menu -->
            @{
                var userId = Context.Request.Cookies["UserId"];
                var isAuthenticated = !string.IsNullOrEmpty(userId);
                var userRole = Context.Request.Cookies["UserRole"];
                var userName = Context.Request.Cookies["UserName"] ?? "User";
                var userEmail = Context.Request.Cookies["UserEmail"] ?? "";
            }
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Job" asp-action="Index">
                            Việc làm
                        </a>
                    </li>
                    @if (userRole == "Candidate")
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-controller="CV" asp-action="Index">
                                Hồ sơ & CV
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">
                            Công ty
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">
                            Công cụ
                        </a>
                    </li>
                    @if (isAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-semibold @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Subscription" ? "active" : "")"
                               asp-controller="Subscription" asp-action="Index">
                                Gói dịch vụ
                            </a>
                        </li>
                    }
                </ul>

                <!-- User Actions -->
                <div class="d-flex align-items-center gap-2">
                    @if (isAuthenticated)
                    {
                        if (userRole == "Admin" || userRole == "Manager")
                        {
                            <div class="header-icons">
                                <div class="profile-dropdown" id="profileDropdown">
                                    <div class="profile-avatar-wrapper" onclick="toggleProfileMenu()">
                                        <div class="profile-avatar">
                                            @((userName?.Length > 0 ? userName.Substring(0, 1) : "A").ToUpper())
                                        </div>
                                        <i class="fas fa-chevron-down avatar-chevron"></i>
                                    </div>
                                    <div class="profile-menu">
                                        <div class="profile-header">
                                            <div class="profile-header-avatar">
                                                @((userName?.Length > 0 ? userName.Substring(0, 1) : "A").ToUpper())
                                            </div>
                                            <div class="profile-header-info">
                                                <h6>@userName</h6>
                                                <div class="email">@userEmail</div>
                                                @if (!string.IsNullOrEmpty(userId))
                                                {
                                                    <div class="user-id">ID @(userId.Length > 8 ? userId.Substring(0, 8) : userId)</div>
                                                }
                                                <span class="profile-verified">
                                                    <i class="fas fa-check-circle"></i>
                                                    @(userRole == "Admin" ? "Quản trị viên" : "Quản lý nội dung")
                                                </span>
                                            </div>
                                        </div>

                                        <div class="profile-menu-section">
                                            <a asp-controller="@(userRole == "Admin" ? "Admin" : "Manager")" asp-action="Index" class="profile-menu-item">
                                                <i class="fas fa-chart-line"></i>
                                                <span class="label">Bảng điều khiển</span>
                                            </a>
                                            @if (userRole == "Admin")
                                            {
                                                <a asp-controller="Admin" asp-action="UserList" class="profile-menu-item">
                                                    <i class="fas fa-users"></i>
                                                    <span class="label">Quản lý người dùng</span>
                                                </a>
                                            }
                                            else if (userRole == "Manager")
                                            {
                                                <a asp-controller="Subscription" asp-action="ManageSubscription" class="profile-menu-item">
                                                    <i class="fas fa-crown"></i>
                                                    <span class="label">Quản lý gói dịch vụ</span>
                                                </a>
                                            }
                                        </div>

                                        <div class="profile-menu-section">
                                            <div class="profile-menu-item" onclick="toggleSubmenu(this)">
                                                <i class="fas fa-user-shield"></i>
                                                <span class="label">Cá nhân & Bảo mật</span>
                                                <i class="fas fa-chevron-down arrow"></i>
                                            </div>
                                            <div class="profile-submenu">
                                                <a asp-controller="Profile" asp-action="Info" class="profile-submenu-item">Thông tin cá nhân</a>
                                                <a asp-controller="Profile" asp-action="ChangePassword" class="profile-submenu-item">Đổi mật khẩu</a>
                                            </div>
                                        </div>

                                        <div class="profile-menu-section">
                                            <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutFormAdmin">
                                                @Html.AntiForgeryToken()
                                                <a href="javascript:void(0)" onclick="document.getElementById('logoutFormAdmin').submit()" class="profile-menu-item logout-btn">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                    <span class="label">Đăng xuất</span>
                                                </a>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (userRole == "Recruiter" || userRole == "Employee")
                        {
                            <div class="header-icons">
                                <!-- Notification Dropdown -->
                                <div class="notif-dropdown" id="notifDropdown" data-role="Recruiter">
                                    <button class="header-icon-btn" title="Thông báo" onclick="toggleNotifMenu(event)">
                                        <i class="fas fa-bell"></i>
                                        <span class="notification-badge" id="notifBadge" style="display:none;">0</span>
                                    </button>
                                    <div class="notif-menu" id="notifMenu" onclick="event.stopPropagation()">
                                        <div class="notif-header">
                                            <h6>Thông báo</h6>
                                            <a href="javascript:void(0)" class="mark-read-all" onclick="markAllRead()">Đánh dấu đã đọc</a>
                                        </div>
                                        <div class="notif-body" id="notifList">
                                            <div class="notif-empty"><i class="fas fa-spinner fa-spin"></i> Đang tải...</div>
                                        </div>
                                    </div>
                                </div>

                                @if (userRole == "Employee")
                                {
                                    <!-- Message Icon -->
                                    <a asp-controller="Chat" asp-action="Index" class="header-icon-btn text-decoration-none" title="Tin nhắn">
                                        <i class="fas fa-comment-dots"></i>
                                    </a>
                                }

                                <div class="profile-dropdown" id="profileDropdown">
                                    <div class="profile-avatar-wrapper" onclick="toggleProfileMenu()">
                                        <div class="profile-avatar" style="background:#dcfce7;color:#16a34a;border-color:#dcfce7;">
                                            @((userName?.Length > 0 ? userName.Substring(0, 1) : "R").ToUpper())
                                        </div>
                                        <i class="fas fa-chevron-down avatar-chevron"></i>
                                    </div>

                                    <div class="profile-menu">
                                        <!-- Profile Header -->
                                        <div class="profile-header">
                                            <div class="profile-header-avatar" style="background:#dcfce7;color:#16a34a;">
                                                @((userName?.Length > 0 ? userName.Substring(0, 1) : "R").ToUpper())
                                            </div>
                                            <div class="profile-header-info">
                                                <h6>@userName</h6>
                                                <div class="email">@userEmail</div>
                                                @if (!string.IsNullOrEmpty(userId))
                                                {
                                                    <div class="user-id">ID @(userId.Length > 8 ? userId.Substring(0, 8) : userId)</div>
                                                }
                                                <span class="profile-verified" style="background:#dcfce7;color:#16a34a;">
                                                    <i class="fas fa-briefcase"></i>
                                                    @(userRole == "Employee" ? "Nhân viên" : "Nhà tuyển dụng")
                                                </span>
                                            </div>
                                        </div>

                                        <!-- Recruiter quick links -->
                                        <div class="profile-menu-section">
                                            <a asp-controller="Recruiter" asp-action="RecruiterDashboard" class="profile-menu-item">
                                                <i class="fas fa-chart-bar"></i>
                                                <span class="label">Bảng điều khiển</span>
                                            </a>
                                            <a asp-controller="Recruiter" asp-action="JobPostingList" class="profile-menu-item">
                                                <i class="fas fa-file-alt"></i>
                                                <span class="label">Quản lý tin đăng</span>
                                            </a>
                                            <a asp-controller="Subscription" asp-action="Index" class="profile-menu-item">
                                                <i class="fas fa-crown"></i>
                                                <span class="label">Gói dịch vụ</span>
                                            </a>
                                            <a asp-controller="Recruiter" asp-action="JobPostingList" class="profile-menu-item">
                                                <i class="fas fa-inbox"></i>
                                                <span class="label">Danh sách ứng tuyển theo tin</span>
                                            </a>
                                        </div>

                                        <!-- Account -->
                                        <div class="profile-menu-section">
                                            <div class="profile-menu-item" onclick="toggleSubmenu(this)">
                                                <i class="fas fa-user-shield"></i>
                                                <span class="label">Cá nhân &amp; Bảo mật</span>
                                                <i class="fas fa-chevron-down arrow"></i>
                                            </div>
                                            <div class="profile-submenu">
                                                <a asp-controller="Profile" asp-action="Info" class="profile-submenu-item">Thông tin cá nhân</a>
                                                <a asp-controller="Profile" asp-action="ChangePassword" class="profile-submenu-item">Đổi mật khẩu</a>
                                            </div>
                                        </div>

                                        <!-- Logout -->
                                        <div class="profile-menu-section">
                                            <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutFormRecruiter">
                                                @Html.AntiForgeryToken()
                                                <a href="javascript:void(0)" onclick="document.getElementById('logoutFormRecruiter').submit()" class="profile-menu-item logout-btn">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                    <span class="label">Đăng xuất</span>
                                                </a>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="header-icons">
                                @if (userRole == "Candidate")
                                {
                                    <!-- Notification Dropdown -->
                                    <div class="notif-dropdown" id="notifDropdown" data-role="Candidate">
                                        <button class="header-icon-btn" title="Thông báo" onclick="toggleNotifMenu(event)">
                                            <i class="fas fa-bell"></i>
                                            <span class="notification-badge" id="notifBadge" style="display:none;">0</span>
                                        </button>
                                        <div class="notif-menu" id="notifMenu" onclick="event.stopPropagation()">
                                            <div class="notif-header">
                                                <h6>Thông báo</h6>
                                                <a href="javascript:void(0)" class="mark-read-all" onclick="markAllRead()">Đánh dấu đã đọc</a>
                                            </div>
                                            <div class="notif-body" id="notifList">
                                                <div class="notif-empty"><i class="fas fa-spinner fa-spin"></i> Đang tải...</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Message Icon -->
                                    <a asp-controller="Chat" asp-action="Index" class="header-icon-btn text-decoration-none" title="Tin nhắn">
                                        <i class="fas fa-comment-dots"></i>
                                    </a>
                                }
                                
                                <!-- Profile Dropdown -->
                                <div class="profile-dropdown" id="profileDropdown">
                                    <div class="profile-avatar-wrapper" onclick="toggleProfileMenu()">
                                        <div class="profile-avatar">
                                            @((userName?.Length > 0 ? userName.Substring(0, 1) : "U").ToUpper())
                                        </div>
                                        <i class="fas fa-chevron-down avatar-chevron"></i>
                                    </div>

                                    <div class="profile-menu">
                                        <!-- Profile Header -->
                                        <div class="profile-header">
                                            <div class="profile-header-avatar">
                                                @((userName?.Length > 0 ? userName.Substring(0, 1) : "U").ToUpper())
                                            </div>
                                            <div class="profile-header-info">
                                                <h6>@userName</h6>
                                                <div class="email">@userEmail</div>
                                                @if (!string.IsNullOrEmpty(userId))
                                                {
                                                    <div class="user-id">ID @(userId.Length > 8 ? userId.Substring(0, 8) : userId)</div>
                                                }
                                                <span class="profile-verified">
                                                    <i class="fas fa-check-circle"></i>
                                                    Tài khoản đã xác thực
                                                </span>
                                            </div>
                                        </div>
                                        
                                        @if (userRole == "Candidate")
                                        {
                                            <!-- Menu Sections -->
                                            <div class="profile-menu-section">
                                                <div class="profile-menu-item" onclick="toggleSubmenu(this)">
                                                    <i class="fas fa-briefcase"></i>
                                                    <span class="label">Quản lý tìm việc</span>
                                                    <i class="fas fa-chevron-down arrow"></i>
                                                </div>
                                                <div class="profile-submenu">
                                                    <a asp-controller="Job" asp-action="Index" class="profile-submenu-item">Tìm việc làm</a>
                                                    <a asp-controller="Job" asp-action="SavedJobs" class="profile-submenu-item">Việc làm đã lưu</a>
                                                    <a asp-controller="Application" asp-action="Index" class="profile-submenu-item">Việc làm đã ứng tuyển</a>
                                                </div>
                                            </div>
                                            
                                            <div class="profile-menu-section">
                                                <div class="profile-menu-item" onclick="toggleSubmenu(this)">
                                                    <i class="fas fa-file-alt"></i>
                                                    <span class="label">Quản lý CV & Cover letter</span>
                                                    <i class="fas fa-chevron-down arrow"></i>
                                                </div>
                                                <div class="profile-submenu">
                                                    <a asp-controller="CV" asp-action="Index" class="profile-submenu-item">CV của tôi</a>
                                                    <a asp-controller="Profile" asp-action="Info" class="profile-submenu-item">Hồ sơ cá nhân</a>
                                                </div>
                                            </div>
                                        }

                                        <div class="profile-menu-section">
                                            <div class="profile-menu-item" onclick="toggleSubmenu(this)">
                                                <i class="fas fa-user-shield"></i>
                                                <span class="label">Cá nhân & Bảo mật</span>
                                                <i class="fas fa-chevron-down arrow"></i>
                                            </div>
                                            <div class="profile-submenu">
                                                <a asp-controller="Profile" asp-action="Info" class="profile-submenu-item">Thông tin cá nhân</a>
                                                <a asp-controller="Profile" asp-action="ChangePassword" class="profile-submenu-item">Đổi mật khẩu</a>
                                            </div>
                                        </div>

                                        <!-- Logout Section -->
                                        <div class="profile-menu-section">
                                            <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutFormHeader">
                                                @Html.AntiForgeryToken()
                                                <a href="javascript:void(0)" onclick="document.getElementById('logoutFormHeader').submit()" class="profile-menu-item logout-btn">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                    <span class="label">Đăng xuất</span>
                                                </a>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <a class="btn btn-outline-primary me-2" asp-controller="Auth" asp-action="Login">
                            Đăng nhập
                        </a>
                        <a class="btn btn-primary" asp-controller="Auth" asp-action="Register">
                            Đăng ký
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>

<script>
    function toggleProfileMenu() {
        const dropdown = document.getElementById('profileDropdown');
        dropdown.classList.toggle('show');
    }
    
    function toggleSubmenu(element) {
        element.classList.toggle('expanded');
        const arrow = element.querySelector('.arrow');
        if (element.classList.contains('expanded')) {
            arrow.style.transform = 'rotate(180deg)';
        } else {
            arrow.style.transform = 'rotate(0deg)';
        }
    }
    
    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
        const dropdown = document.getElementById('profileDropdown');
        if (dropdown && !dropdown.contains(event.target) && !event.target.closest('.profile-avatar-wrapper')) {
            dropdown.classList.remove('show');
        }
        const notifDropdown = document.getElementById('notifDropdown');
        if (notifDropdown && !notifDropdown.contains(event.target)) {
            notifDropdown.classList.remove('show');
        }
    });

    // ── NOTIFICATIONS LOGIC ──
    const notifToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    function toggleNotifMenu(e) {
        e.stopPropagation();
        const dd = document.getElementById('notifDropdown');
        if (dd) {
            dd.classList.toggle('show');
            if (dd.classList.contains('show')) {
                loadNotifications();
            }
        }
    }

    function loadNotifications() {
        const listEl = document.querySelectorAll('#notifList');
        listEl.forEach(el => {
            if (el.innerHTML.includes('không có') || el.innerHTML.includes('Đang tải')) {
                el.innerHTML = '<div class="notif-empty"><i class="fas fa-spinner fa-spin"></i> Đang tải...</div>';
            }
        });

        fetch('/Notification/GetList')
            .then(res => res.json())
            .then(data => {
                updateNotifBadge(data.unreadCount);
                renderNotifList(data.notifications);
            });
    }

    function updateNotifBadge(count) {
        const badges = document.querySelectorAll('#notifBadge, .notification-badge');
        badges.forEach(b => {
            if (count > 0) {
                b.textContent = count > 99 ? '99+' : count;
                b.style.display = 'block';
            } else {
                b.style.display = 'none';
            }
        });
    }

    function renderNotifList(items) {
        const listEl = document.querySelectorAll('#notifList');
        if (!items || items.length === 0) {
            listEl.forEach(el => el.innerHTML = '<div class="notif-empty"><i class="fas fa-bell-slash mb-2" style="font-size:1.5rem;"></i><br>Không có thông báo nào</div>');
            return;
        }

        const html = items.map(n => {
            let icon = 'fa-bell';
            let typeClass = 'SYSTEM';
            if (n.type === 'APPLICATION') { icon = 'fa-file-alt'; typeClass = 'APPLICATION'; }
            else if (n.type === 'PAYMENT') { icon = 'fa-wallet'; typeClass = 'PAYMENT'; }

            let href = 'javascript:void(0)';
            if (n.type === 'APPLICATION') {
                const role = document.getElementById('notifDropdown')?.getAttribute('data-role');
                if (role === 'Recruiter') href = '/Recruiter/JobPostingList';
                else if (role === 'Candidate') href = '/Application/Index';
            }

            return `
                <a href="${href}" class="notif-item ${!n.isRead ? 'unread' : ''}" onclick="markRead(${n.id}, this, event)">
                    <div class="notif-icon ${typeClass}"><i class="fas ${icon}"></i></div>
                    <div class="notif-content">
                        <div class="notif-title">${n.title}</div>
                        <div class="notif-desc">${n.content}</div>
                        <div class="notif-time">${n.timeAgo}</div>
                    </div>
                    ${!n.isRead ? '<div class="ms-2" style="width:8px;height:8px;border-radius:50%;background:#00b14f;margin-top:4px;"></div>' : ''}
                </a>
            `;
        }).join('');

        listEl.forEach(el => el.innerHTML = html);
    }

    function markRead(id, el, e) {
        if (!el.classList.contains('unread')) return;
        
        // Let it navigate normally if there's a href, but record the click async
        fetch('/Notification/MarkRead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': notifToken },
            body: JSON.stringify({ id: id })
        }).then(res => res.json()).then(data => {
            if (data.success) {
                el.classList.remove('unread');
                const dot = el.querySelector('div[style*="background:#00b14f"]');
                if (dot) dot.remove();
                fetchUnreadCount();
            }
        });
    }

    function markAllRead() {
        var fd = new FormData();
        fd.append('__RequestVerificationToken', notifToken);
        
        fetch('/Notification/MarkAllRead', {
            method: 'POST',
            body: fd
        }).then(res => res.json()).then(data => {
            if (data.success) {
                loadNotifications();
            }
        });
    }

    function fetchUnreadCount() {
        fetch('/Notification/UnreadCount')
            .then(res => res.json())
            .then(data => updateNotifBadge(data.count))
            .catch(() => {});
    }

    document.addEventListener('DOMContentLoaded', () => {
        const dd = document.getElementById('notifDropdown');
        if (dd) {
            fetchUnreadCount();
            setInterval(fetchUnreadCount, 60000); // 1 min poll
            
            // SignalR Setup
            const currentUserId = '@userId';
            if (currentUserId && typeof signalR !== 'undefined') {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();

                connection.on("ReceiveNotification", function (title, content) {
                    toastr.info(content, title, { timeOut: 8000 });
                    fetchUnreadCount();
                });

                connection.start().then(function () {
                    connection.invoke("JoinUserGroup", currentUserId);
                }).catch(function (err) {
                    console.error("SignalR Connection Error: ", err);
                });
            }
        }
    });
</script>
