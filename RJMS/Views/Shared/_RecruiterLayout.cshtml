@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
    <style>
        /* Reset container styles inside the layout */
        main[role="main"] {
            padding: 0;
            margin: 0;
        }

        body {
            line-height: 1.4;
        }

        /* Recruiter page wrapper */
        .recruiter-page-wrapper {
            display: flex;
            flex-direction: column;
            margin: 10px 12px 14px;
            min-height: calc(100vh - 70px);
        }

        .recruiter-body-wrapper {
            display: flex;
            gap: 12px;
            flex: 1 0 auto;
        }

        /* Sidebar */
        .recruiter-sidebar {
            width: 250px;
            min-width: 250px;
            flex-shrink: 0;
            border: 1px solid #dee2e6;
            border-radius: 10px;
            background: #fff;
            overflow-y: auto;
        }

        .recruiter-sidebar .nav-link {
            color: #4b5563;
            padding: 12px 20px;
            border-left: 3px solid transparent;
            font-weight: 500;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s;
        }

        .recruiter-sidebar .nav-link:hover {
            background: #f9fafb;
            color: #111827;
        }

        .recruiter-sidebar .nav-link.active {
            background: #f0fdf4;
            color: #00b14f;
            border-left-color: #00b14f;
            font-weight: 600;
        }

        .recruiter-sidebar .nav-section {
            padding: 20px 20px 8px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #9ca3af;
            letter-spacing: 0.05em;
        }

        .recruiter-sidebar-logo {
            padding: 18px 20px;
            border-bottom: 1px solid #dee2e6;
            background: #fff;
            font-weight: 700;
            font-size: 0.85rem;
            color: #6c757d;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .recruiter-sidebar-logo .logo-title {
            color: #00b14f;
            font-size: 1rem;
            font-weight: 700;
            margin: 0 0 2px;
        }

        /* Content area */
        .recruiter-content {
            flex: 1;
            background: #f4f5f5;
            padding: 24px;
            min-width: 0;
            display: flex;
            flex-direction: column;
            border: 1px solid #dee2e6;
            border-radius: 10px;
        }

        .site-header {
            margin-left: 0 !important;
            width: 100% !important;
            background: #fff !important;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid #e5e7eb;
        }

        .site-footer {
            margin-left: 0 !important;
            width: 100% !important;
            flex-shrink: 0;
            margin-top: 10px;
            border-top: 1px solid #e5e7eb;
        }
    </style>
}

<div class="recruiter-page-wrapper">
    <div class="recruiter-body-wrapper">
        <!-- Sidebar -->
        <aside class="recruiter-sidebar">
            @{
                var _role = Context.Request.Cookies["UserRole"];
            }
            <div class="recruiter-sidebar-logo" style="text-align: center;">
                <div class="logo-title">Finding Jobs</div>
            </div>
            <nav class="nav flex-column pt-2 pb-4">
                <span class="nav-section">Tổng quan</span>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "RecruiterDashboard" ? "active" : "")"
                   asp-controller="Recruiter" asp-action="RecruiterDashboard">
                    Bảng tin
                </a>
                
                <span class="nav-section">Tuyển dụng</span>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() is "JobPostingList" or "CreateJob" ? "active" : "")"
                   asp-controller="Recruiter" asp-action="JobPostingList">
                    Quản lý tin đăng
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "CreateJob" ? "text-success fw-bold ps-4 border-start border-3 border-success bg-success bg-opacity-10" : "ps-4 text-muted")"
                   asp-controller="Recruiter" asp-action="CreateJob" style="font-size: 0.85rem">
                    Đăng tin mới
                </a>
                
                <span class="nav-section">Tương tác</span>
                @if (_role == "Employee")
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Chat" ? "active" : "")"
                       asp-controller="Chat" asp-action="Index">
                        Tin nhắn
                    </a>
                }

                <span class="nav-section">Quản lý công ty</span>
                @if (_role != "Employee")
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageLocations" ? "active" : "")"
                       asp-controller="Recruiter" asp-action="ManageLocations">
                        Địa chỉ văn phòng
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "RecruiterManagement" && ViewContext.RouteData.Values["Action"]?.ToString() == "Employees" ? "active" : "")"
                       asp-controller="RecruiterManagement" asp-action="Employees">
                        Nhân viên
                    </a>
                }

                <span class="nav-section">Tài khoản</span>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "EditProfileNew" ? "active" : "")"
                   asp-controller="Profile" asp-action="EditProfileNew">
                    Hồ sơ cá nhân
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "EditCompanyProfile" ? "active" : "")"
                   asp-controller="Profile" asp-action="EditCompanyProfile">
                    Thông tin công ty
                </a>
                @if (_role == "Recruiter")
                {
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "SubscriptionHistory" ? "active" : "")"
                       asp-controller="Recruiter" asp-action="SubscriptionHistory">
                        Lịch sử đăng ký
                    </a>
                }
            </nav>
        </aside>

        <!-- Main content -->
        <div class="recruiter-content">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
