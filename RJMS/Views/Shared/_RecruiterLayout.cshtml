@using Microsoft.AspNetCore.Http
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* Remove default main padding */
        main[role="main"] {
            padding: 0;
            margin: 0;
        }

        /* Page content area */
        .recruiter-content {
            background: #f7f8fa;
            min-height: calc(100vh - 70px);
            padding: 28px 32px;
        }

        /* Page headline area */
        .rpage-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .rpage-header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #111827;
            margin: 0 0 4px;
        }

        .rpage-header p {
            font-size: 0.85rem;
            color: #6b7280;
            margin: 0;
        }

        .btn-post-job {
            background: #00b14f;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 20px;
            font-size: 0.875rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            cursor: pointer;
            transition: background 0.2s;
            text-decoration: none;
        }

        .btn-post-job:hover {
            background: #009744;
            color: #fff;
        }

        /* Breadcrumb */
        .rpage-breadcrumb {
            margin-bottom: 12px;
            font-size: 0.8rem;
            color: #9ca3af;
        }

        .rpage-breadcrumb a { color: #6b7280; }
        .rpage-breadcrumb a:hover { color: #00b14f; }
        .rpage-breadcrumb .sep { margin: 0 6px; }

        /* Alert spacing */
        .alert {
            padding: 0.75rem 1rem;
            margin-bottom: 1rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
}

<!-- Page content -->
<div class="recruiter-content">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
