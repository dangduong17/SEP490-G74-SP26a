@model RJMS.vn.edu.fpt.Models.DTOs.JobDetailViewModel
@{
    ViewData["Title"] = Model.Title + " - " + Model.CompanyName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userRole = Context.Request.Cookies["UserRole"];

    string SalaryText()
    {
        if (Model.MinSalary.HasValue && Model.MaxSalary.HasValue)
            return $"{Model.MinSalary.Value / 1000000:N0} - {Model.MaxSalary.Value / 1000000:N0} triệu";
        if (Model.MaxSalary.HasValue)
            return $"Tới {Model.MaxSalary.Value / 1000000:N0} triệu";
        return "Thoả thuận";
    }

    // Build full location string
    var locationParts = new System.Collections.Generic.List<string>();
    if (!string.IsNullOrEmpty(Model.LocationAddress)) locationParts.Add(Model.LocationAddress);
    if (!string.IsNullOrEmpty(Model.LocationWardName)) locationParts.Add(Model.LocationWardName);
    if (!string.IsNullOrEmpty(Model.LocationName)) locationParts.Add(Model.LocationName);
    var fullLocation = string.Join(", ", locationParts);
}

@section Styles {
<style>
    body { background: #f5f5f5; }
    .dw { max-width: 1140px; margin: 0 auto; padding: 28px 16px 60px; display: flex; gap: 24px; align-items: flex-start; }

    /* MAIN */
    .dmain { flex: 1; min-width: 0; }

    .card-box { background: #fff; border-radius: 14px; border: 1px solid #e5e7eb; margin-bottom: 20px; }

    /* Hero */
    .hero-body { padding: 28px; }
    .hero-top { display: flex; gap: 18px; align-items: flex-start; }
    .hero-logo {
        width: 88px; height: 88px;
        border: 1px solid #e5e7eb; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; background: #fafafa; flex-shrink: 0;
    }
    .hero-logo img { max-width: 90%; max-height: 90%; object-fit: contain; }
    .hero-info { flex: 1; }
    .hero-info h1 { font-size: 1.45rem; font-weight: 800; color: #111827; margin: 0 0 6px; line-height: 1.3; }
    .hero-co-link { color: #00b14f; font-size: 1rem; font-weight: 600; text-decoration: none; display: block; margin-bottom: 12px; }
    .hero-co-link:hover { text-decoration: underline; color: #009744; }
    .hero-meta { display: flex; flex-wrap: wrap; gap: 14px; }
    .meta-tag { display: flex; align-items: center; gap: 6px; font-size: 0.9rem; color: #374151; }
    .meta-tag i { color: #00b14f; }
    .meta-tag.urgent { color: #ef4444; }
    .meta-tag.urgent i { color: #ef4444; }

    /* Apply row */
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; padding: 20px 28px; border-top: 1px solid #f3f4f6; }
    .btn-apply-big {
        background: #00b14f; color: #fff; border: none; border-radius: 8px;
        padding: 13px 36px; font-size: 1rem; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
        transition: background 0.2s;
    }
    .btn-apply-big:hover { background: #009744; color: #fff; }
    .btn-login-apply {
        background: #fff; color: #00b14f; border: 2px solid #00b14f; border-radius: 8px;
        padding: 12px 28px; font-size: 0.95rem; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
        transition: all 0.2s;
    }
    .btn-login-apply:hover { background: #00b14f; color: #fff; }
    .btn-save-job {
        background: #fff; color: #374151; border: 1px solid #e5e7eb; border-radius: 8px;
        padding: 13px 22px; font-size: 0.9rem; font-weight: 600; cursor: pointer;
        display: inline-flex; align-items: center; gap: 7px; transition: all 0.2s;
    }
    .btn-save-job:hover { border-color: #00b14f; color: #00b14f; }

    /* Info grid */
    .card-body { padding: 24px; }
    .card-title { font-size: 1.1rem; font-weight: 700; color: #111827; margin: 0 0 18px; padding-bottom: 12px; border-bottom: 2px solid #f3f4f6; }
    .info-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
    .info-row .lbl { font-size: 0.75rem; text-transform: uppercase; color: #9ca3af; font-weight: 700; letter-spacing: 0.04em; }
    .info-row .val { font-size: 0.95rem; color: #1f2937; font-weight: 600; margin-top: 3px; }
    .info-row .val.salary { color: #00b14f; font-size: 1.1rem; }

    /* Rich content */
    .rich { font-size: 0.95rem; line-height: 1.8; color: #374151; }
    .rich p { margin-bottom: 10px; }
    .rich ul, .rich ol { padding-left: 20px; margin-bottom: 10px; }
    .rich li { margin-bottom: 5px; }

    /* SIDEBAR */
    .dside { width: 290px; flex-shrink: 0; position: sticky; top: 80px; }

    .side-box { background: #fff; border-radius: 14px; border: 1px solid #e5e7eb; margin-bottom: 18px; }
    .side-box-inner { padding: 18px; }
    .side-box-title { font-size: 0.9rem; font-weight: 700; color: #374151; margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid #f3f4f6; }

    /* Quick stats */
    .qs-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #f9fafb; font-size: 0.875rem; }
    .qs-row:last-child { border-bottom: none; }
    .qs-row .k { color: #6b7280; }
    .qs-row .v { font-weight: 600; color: #111827; }
    .qs-row .v.red { color: #ef4444; }

    /* Company card header */
    .co-header {
        background: linear-gradient(135deg, #1c3e2e 0%, #00b14f 100%);
        border-radius: 14px 14px 0 0;
        padding: 22px 18px;
        display: flex; flex-direction: column; align-items: center; gap: 10px;
    }
    .co-logo { width: 72px; height: 72px; border-radius: 10px; border: 2px solid rgba(255,255,255,0.3); overflow: hidden; background: #fff; display: flex; align-items: center; justify-content: center; }
    .co-logo img { max-width: 90%; max-height: 90%; object-fit: contain; }
    .co-header h4 { color: #fff; font-size: 0.95rem; font-weight: 700; margin: 0; text-align: center; }
    .co-info-row { display: flex; gap: 9px; margin-bottom: 10px; font-size: 0.85rem; color: #4b5563; align-items: flex-start; }
    .co-info-row i { color: #00b14f; width: 15px; margin-top: 2px; flex-shrink: 0; }
    .co-info-row a { color: #00b14f; text-decoration: none; }
    .co-info-row a:hover { text-decoration: underline; }
    .co-footer-link { display: block; text-align: center; padding: 11px; border-top: 1px solid #f3f4f6; color: #00b14f; text-decoration: none; font-size: 0.875rem; font-weight: 600; transition: background 0.2s; border-radius: 0 0 14px 14px; }
    .co-footer-link:hover { background: #f0fdf4; }

    /* Skills tags */
    .skills-wrap { display: flex; flex-wrap: wrap; gap: 7px; }
    .skill-tag { background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; border-radius: 6px; padding: 4px 12px; font-size: 0.82rem; font-weight: 600; }

    @@media (max-width: 960px) { .dw { flex-direction: column; } .dside { width: 100%; position: static; } .info-grid { grid-template-columns: 1fr; } }
</style>
}

<div class="dw">
    <!-- MAIN -->
    <div class="dmain">

        <!-- Hero -->
        <div class="card-box">
            <div class="hero-body">
                <div class="hero-top">
                    <div class="hero-logo">
                        <img src="@(string.IsNullOrEmpty(Model.CompanyLogo) ? "/images/logo_default.png" : Model.CompanyLogo)" alt="@Model.CompanyName" />
                    </div>
                    <div class="hero-info">
                        <h1>@Model.Title</h1>
                        <a href="@Url.Action("Detail", "Company", new { id = Model.CompanyId })" class="col-footer-link">@Model.CompanyName</a>
                        <div class="hero-meta">
                            <div class="meta-tag">
                                <i class="fas fa-money-bill-wave"></i> <strong>@SalaryText()</strong>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.LocationName))
                            {
                                <div class="meta-tag"><i class="fas fa-map-marker-alt"></i> @Model.LocationName</div>
                            }
                            @if (!string.IsNullOrEmpty(Model.JobType))
                            {
                                <div class="meta-tag"><i class="fas fa-briefcase"></i> @Model.JobType</div>
                            }
                            @if (Model.ApplicationDeadline.HasValue)
                            {
                                var dl = (int)(Model.ApplicationDeadline.Value - DateTime.Now).TotalDays;
                                <div class="meta-tag @(dl < 5 ? "urgent" : "")">
                                    <i class="fas fa-clock"></i>
                                    Còn @dl ngày để ứng tuyển
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="hero-actions">
                @if (userRole == "Candidate")
                {
                    <button class="btn-apply-big" type="button">
                        <i class="fas fa-paper-plane"></i> Ứng tuyển ngay
                    </button>
                }
                else if (string.IsNullOrEmpty(userRole))
                {
                    <a href="@Url.Action("Login","Auth")" class="btn-login-apply">
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập để ứng tuyển
                    </a>
                }
                else
                {
                    <span class="text-muted fst-italic" style="font-size:0.875rem;padding-top:4px;">
                        Chức năng ứng tuyển chỉ dành cho ứng viên.
                    </span>
                }
                <button class="btn-save-job" type="button">
                    <i class="far fa-heart"></i> Lưu tin
                </button>
            </div>
        </div>

        <!-- Thông tin chung -->
        <div class="card-box">
            <div class="card-body">
                <div class="card-title"><i class="fas fa-info-circle me-2 text-success"></i>Thông tin chung</div>
                <div class="info-grid">
                    <div class="info-row">
                        <div class="lbl">Mức lương</div>
                        <div class="val salary">@SalaryText()</div>
                    </div>
                    <div class="info-row">
                        <div class="lbl">Địa điểm</div>
                        <div class="val">@(string.IsNullOrEmpty(fullLocation) ? "N/A" : fullLocation)</div>
                    </div>
                    <div class="info-row">
                        <div class="lbl">Hình thức</div>
                        <div class="val">@(Model.JobType ?? "N/A")</div>
                    </div>
                    <div class="info-row">
                        <div class="lbl">Số lượng tuyển</div>
                        <div class="val">@(Model.NumberOfPositions.HasValue ? $"{Model.NumberOfPositions} người" : "Không xác định")</div>
                    </div>
                    <div class="info-row">
                        <div class="lbl">Ngành nghề</div>
                        <div class="val">@(Model.CategoryName ?? "N/A")</div>
                    </div>
                    <div class="info-row">
                        <div class="lbl">Hạn nộp hồ sơ</div>
                        <div class="val">@(Model.ApplicationDeadline?.ToString("dd/MM/yyyy") ?? "N/A")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mô tả -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card-box">
                <div class="card-body">
                    <div class="card-title"><i class="fas fa-file-alt me-2 text-success"></i>Mô tả công việc</div>
                    <div class="rich">@Html.Raw(Model.Description.Replace("\n", "<br/>"))</div>
                </div>
            </div>
        }

        <!-- Yêu cầu -->
        @if (!string.IsNullOrEmpty(Model.Requirements))
        {
            <div class="card-box">
                <div class="card-body">
                    <div class="card-title"><i class="fas fa-check-circle me-2 text-success"></i>Yêu cầu ứng viên</div>
                    <div class="rich">@Html.Raw(Model.Requirements.Replace("\n", "<br/>"))</div>
                </div>
            </div>
        }

        <!-- Quyền lợi -->
        @if (!string.IsNullOrEmpty(Model.Benefits))
        {
            <div class="card-box">
                <div class="card-body">
                    <div class="card-title"><i class="fas fa-gift me-2 text-success"></i>Quyền lợi</div>
                    <div class="rich">@Html.Raw(Model.Benefits.Replace("\n", "<br/>"))</div>
                </div>
            </div>
        }

        <!-- Địa điểm làm việc chi tiết -->
        <div class="card-box">
            <div class="card-body">
                <div class="card-title"><i class="fas fa-map-marked-alt me-2 text-success"></i>Địa điểm làm việc</div>
                <div class="d-flex align-items-start gap-2" style="font-size:0.95rem;color:#374151;">
                    <i class="fas fa-map-marker-alt text-success mt-1" style="flex-shrink:0;"></i>
                    <div>
                        @if (!string.IsNullOrEmpty(fullLocation))
                        {
                            @fullLocation
                        }
                        else
                        {
                            <em class="text-muted">Chưa có thông tin địa điểm cụ thể</em>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- SIDEBAR -->
    <aside class="dside">

        <!-- Quick stats -->
        <div class="side-box">
            <div class="side-box-inner">
                <div class="side-box-title"><i class="fas fa-chart-bar me-2 text-success"></i>Thông tin tuyển dụng</div>
                @if (Model.ApplicationDeadline.HasValue)
                {
                    var dl = (int)(Model.ApplicationDeadline.Value - DateTime.Now).TotalDays;
                    <div class="qs-row">
                        <span class="k">Hạn nộp hồ sơ</span>
                        <span class="v @(dl < 5 ? "red" : "")">@Model.ApplicationDeadline.Value.ToString("dd/MM/yyyy")</span>
                    </div>
                }
                <div class="qs-row">
                    <span class="k">Ngày đăng</span>
                    <span class="v">@Model.CreatedAt?.ToString("dd/MM/yyyy")</span>
                </div>
                @if (Model.NumberOfPositions.HasValue)
                {
                    <div class="qs-row">
                        <span class="k">Số lượng</span>
                        <span class="v">@Model.NumberOfPositions người</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.JobType))
                {
                    <div class="qs-row">
                        <span class="k">Hình thức</span>
                        <span class="v">@Model.JobType</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <div class="qs-row">
                        <span class="k">Ngành nghề</span>
                        <span class="v">@Model.CategoryName</span>
                    </div>
                }
            </div>
        </div>

        <!-- Skills — sidebar -->
        @if (Model.Skills.Any())
        {
            <div class="side-box">
                <div class="side-box-inner">
                    <div class="side-box-title"><i class="fas fa-tools me-2 text-success"></i>Kỹ năng yêu cầu</div>
                    <div class="skills-wrap">
                        @foreach (var sk in Model.Skills)
                        {
                            <span class="skill-tag">@sk</span>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Company card -->
        <div class="side-box">
            <div class="co-header">
                <div class="co-logo">
                    <img src="@(string.IsNullOrEmpty(Model.CompanyLogo) ? "/images/logo_default.png" : Model.CompanyLogo)" alt="@Model.CompanyName" />
                </div>
                <h4>@Model.CompanyName</h4>
            </div>
            <div class="side-box-inner">
                @if (!string.IsNullOrEmpty(Model.CompanySize))
                {
                    <div class="co-info-row"><i class="fas fa-users"></i><span>@Model.CompanySize nhân viên</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.CompanyIndustry))
                {
                    <div class="co-info-row"><i class="fas fa-industry"></i><span>@Model.CompanyIndustry</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.CompanyProvince))
                {
                    <div class="co-info-row"><i class="fas fa-map-marker-alt"></i><span>@Model.CompanyProvince</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.CompanyWebsite))
                {
                    <div class="co-info-row">
                        <i class="fas fa-globe"></i>
                        <a href="@Model.CompanyWebsite" target="_blank" rel="noopener">@Model.CompanyWebsite</a>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.CompanyDescription))
                {
                    <p style="font-size:0.82rem;color:#6b7280;margin-top:8px;line-height:1.6;">
                        @(Model.CompanyDescription.Length > 200 ? Model.CompanyDescription[..200] + "..." : Model.CompanyDescription)
                    </p>
                }
            </div>
            <a href="@Url.Action("Detail", "Company", new { id = Model.CompanyId })" class="co-footer-link"><i class="fas fa-building me-1"></i> Xem trang công ty</a>
        </div>

        <!-- Actions again (sticky helpful) -->
        @if (userRole == "Candidate")
        {
            <button class="btn-apply-big w-100 mb-2" type="button" style="justify-content:center;">
                <i class="fas fa-paper-plane"></i> Ứng tuyển ngay
            </button>
        }
        else if (string.IsNullOrEmpty(userRole))
        {
            <a href="@Url.Action("Login","Auth")" class="btn-login-apply w-100 mb-2" style="justify-content:center;">
                <i class="fas fa-sign-in-alt"></i> Đăng nhập để ứng tuyển
            </a>
        }
        <button class="btn-save-job w-100 mb-2" type="button" style="justify-content:center;">
            <i class="far fa-heart"></i> Lưu tin
        </button>

        <a href="@Url.Action("Index","Job")" class="btn btn-outline-secondary w-100" style="font-size:0.875rem;">
            <i class="fas fa-arrow-left me-2"></i> Quay lại danh sách
        </a>
    </aside>
</div>
