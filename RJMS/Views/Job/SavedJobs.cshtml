@model RJMS.vn.edu.fpt.Models.DTOs.PublicJobListViewModel
@{
    ViewData["Title"] = "Việc làm đã lưu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    body { background: #f5f5f5; }
    .saved-page-wrapper { max-width: 1200px; margin: 0 auto; padding: 30px 16px 60px; }
    .saved-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .saved-header h2 { font-size: 1.3rem; font-weight: 800; color: #00b14f; margin: 0; }
    .saved-sub { font-size: 0.85rem; color: #6b7280; margin-top: 3px; }

    .job-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 30px; }
    .job-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: all 0.25s;
        text-decoration: none;
        color: inherit;
        height: 100%;
    }
    .job-card:hover { border-color: #00b14f; box-shadow: 0 6px 18px rgba(0,177,79,0.1); transform: translateY(-3px); }
    .card-top { display: flex; gap: 10px; align-items: flex-start; }
    .logo-box { width: 52px; height: 52px; border: 1px solid #f3f4f6; border-radius: 8px; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; background: #fafafa; }
    .logo-box img { max-width: 90%; max-height: 90%; object-fit: contain; }
    .card-info { flex: 1; min-width: 0; }
    .card-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: #1f2937;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin: 0 0 4px;
        height: 2.4rem;
    }
    .card-company { font-size: 0.75rem; color: #6b7280; text-transform: uppercase; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
    .card-badges { display: flex; gap: 5px; flex-wrap: wrap; }
    .badge-pill { background: #f3f4f6; color: #4b5563; font-size: 0.75rem; font-weight: 600; padding: 4px 9px; border-radius: 4px; white-space: nowrap; }
    .badge-pill.salary { background: #ecfdf5; color: #059669; }

    .btn-heart { width: 32px; height: 32px; border-radius: 50%; border: 1px solid #f43f5e; background: #fff1f2; display: flex; align-items: center; justify-content: center; color: #f43f5e; cursor: pointer; flex-shrink: 0; transition: all 0.2s; }
    .btn-heart:hover { opacity: 0.8; }

    .pagination-wrap { display: flex; justify-content: center; align-items: center; gap: 6px; }
    .pg-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid #e5e7eb; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; color: #374151; text-decoration: none; font-weight: 600; transition: all 0.2s; }
    .pg-btn:hover { border-color: #00b14f; color: #00b14f; }
    .pg-btn.active { background: #00b14f; border-color: #00b14f; color: #fff; }
    .pg-btn.disabled { opacity: 0.4; pointer-events: none; }
    .pg-info { font-size: 0.85rem; color: #6b7280; padding: 0 10px; }

    @@media (max-width: 1024px) { .job-grid { grid-template-columns: repeat(3,1fr); } }
    @@media (max-width: 820px) { .job-grid { grid-template-columns: repeat(2,1fr); } }
    @@media (max-width: 640px) { .job-grid { grid-template-columns: 1fr; } }
</style>
}

<form id="saveJobTokenForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="saved-page-wrapper">
    <div class="saved-header">
        <div>
            <h2>Việc làm đã lưu</h2>
            <div class="saved-sub">Bạn đang lưu @Model.TotalItems công việc</div>
        </div>
        <a asp-controller="Job" asp-action="Index" class="btn btn-outline-success">Tìm thêm việc làm</a>
    </div>

    @if (Model.Jobs.Any())
    {
        <div class="job-grid">
            @foreach (var job in Model.Jobs)
            {
                <a href="@Url.Action("Detail", "Job", new { id = job.Id })" class="job-card">
                    <div class="card-top">
                        <div class="logo-box">
                            @if (!string.IsNullOrEmpty(job.CompanyLogo))
                            {
                                <img src="@job.CompanyLogo" alt="@job.CompanyName" />
                            }
                            else
                            {
                                <img src="~/images/logo_default.png" alt="Logo" />
                            }
                        </div>
                        <div class="card-info">
                            <h3 class="card-title" title="@job.Title">@job.Title</h3>
                            <div class="card-company" title="@job.CompanyName">@job.CompanyName.ToUpper()</div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="card-badges">
                            <span class="badge-pill salary">
                                @if (job.MinSalary.HasValue && job.MaxSalary.HasValue)
                                { @($"{job.MinSalary / 1000000:N0} - {job.MaxSalary / 1000000:N0} triệu") }
                                else if (job.MaxSalary.HasValue)
                                { @($"Tới {job.MaxSalary / 1000000:N0} triệu") }
                                else
                                { @("Thoả thuận") }
                            </span>
                            @if (!string.IsNullOrEmpty(job.LocationName))
                            {
                                <span class="badge-pill">@job.LocationName</span>
                            }
                        </div>
                        <button class="btn-heart" onclick="toggleSaveJob(event, @job.Id, this)" title="Bỏ lưu">
                            <i class="fas fa-heart"></i>
                        </button>
                    </div>
                </a>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="pagination-wrap">
                <a class="pg-btn @(Model.CurrentPage <= 1 ? "disabled" : "")"
                   href="@Url.Action("SavedJobs", new { page = Model.CurrentPage - 1 })">
                    <i class="fas fa-chevron-left"></i>
                </a>
                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                {
                    <a class="pg-btn @(i == Model.CurrentPage ? "active" : "")"
                       href="@Url.Action("SavedJobs", new { page = i })">@i</a>
                }
                <span class="pg-info">@Model.CurrentPage / @Model.TotalPages trang</span>
                <a class="pg-btn @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")"
                   href="@Url.Action("SavedJobs", new { page = Model.CurrentPage + 1 })">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="far fa-heart fa-4x text-muted mb-3 d-block"></i>
            <h4 class="text-muted">Bạn chưa lưu công việc nào</h4>
            <p class="text-muted">Lưu các công việc quan tâm để theo dõi nhanh hơn.</p>
            <a asp-controller="Job" asp-action="Index" class="btn btn-success mt-2">Đi đến trang tìm việc</a>
        </div>
    }
</div>

@section Scripts {
<script>
    async function toggleSaveJob(e, jobId, buttonEl) {
        e.preventDefault();
        e.stopPropagation();

        const token = document.querySelector('#saveJobTokenForm input[name="__RequestVerificationToken"]')?.value;

        try {
            const res = await fetch('/Job/ToggleSave', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': token || ''
                },
                body: `jobId=${encodeURIComponent(jobId)}&__RequestVerificationToken=${encodeURIComponent(token || '')}`
            });

            const data = await res.json();
            if (!data.success) {
                if (typeof toastr !== 'undefined') {
                    toastr.warning(data.message || 'Không thể thao tác với công việc này.');
                }
                return;
            }

            if (data.isSaved === false) {
                const card = buttonEl.closest('.job-card');
                if (card) card.remove();
                if (typeof toastr !== 'undefined') {
                    toastr.info('Đã bỏ lưu công việc.');
                }
                setTimeout(() => window.location.reload(), 300);
            }
        } catch {
            if (typeof toastr !== 'undefined') {
                toastr.error('Có lỗi xảy ra khi cập nhật công việc đã lưu.');
            }
        }
    }
</script>
}
