@model RJMS.Vn.Edu.Fpt.Model.DTOs.RecruiterRegisterViewModel
@{
    ViewData["Title"] = "Đăng ký Nhà tuyển dụng";
}

<section class="auth-section">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="auth-card" style="max-width:100%; border-radius:16px; overflow:hidden;">
                    <div class="auth-header text-center p-4" style="background:linear-gradient(135deg,rgba(0,177,79,.12),rgba(0,177,79,.03)); border-bottom:1px solid #d7efe1;">
                        <h2 class="auth-title mb-1" style="color:#00b14f; font-weight:800;">Đăng ký Nhà tuyển dụng</h2>
                        <p class="auth-subtitle mb-0">Tạo tài khoản để đăng tin tuyển dụng trên Finding Jobs</p>
                    </div>

                    <form asp-action="RegisterRecruiter" method="post" class="p-4">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <!-- Thông tin tài khoản -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 pb-2" style="color:#0f172a; border-bottom:2px solid #d7efe1;">
                                <i class="fas fa-user-circle me-2 text-success"></i>Thông tin tài khoản
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label asp-for="Email" class="form-label fw-semibold small">Email *</label>
                                    <input asp-for="Email" class="form-control" placeholder="name@company.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Password" class="form-label fw-semibold small">Mật khẩu *</label>
                                    <input asp-for="Password" class="form-control" type="password" placeholder="Tối thiểu 6 ký tự" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ConfirmPassword" class="form-label fw-semibold small">Xác nhận mật khẩu *</label>
                                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Thông tin cá nhân -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 pb-2" style="color:#0f172a; border-bottom:2px solid #d7efe1;">
                                <i class="fas fa-id-card me-2 text-success"></i>Thông tin cá nhân
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="FirstName" class="form-label fw-semibold small">Họ *</label>
                                    <input asp-for="FirstName" class="form-control" placeholder="Nhập họ" />
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LastName" class="form-label fw-semibold small">Tên *</label>
                                    <input asp-for="LastName" class="form-control" placeholder="Nhập tên" />
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label fw-semibold small">Số điện thoại</label>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="0912 345 678" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Position" class="form-label fw-semibold small">Vị trí công việc *</label>
                                    <input asp-for="Position" class="form-control" placeholder="VD: HR Manager" />
                                    <span asp-validation-for="Position" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Department" class="form-label fw-semibold small">Phòng ban</label>
                                    <input asp-for="Department" class="form-control" placeholder="VD: Phòng Nhân sự" />
                                </div>
                            </div>
                        </div>

                        <!-- Thông tin công ty -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 pb-2" style="color:#0f172a; border-bottom:2px solid #d7efe1;">
                                <i class="fas fa-building me-2 text-success"></i>Thông tin công ty
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="CompanyName" class="form-label fw-semibold small">Tên công ty *</label>
                                    <input asp-for="CompanyName" class="form-control" placeholder="Tên công ty" />
                                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CompanyTaxCode" class="form-label fw-semibold small">Mã số thuế</label>
                                    <input asp-for="CompanyTaxCode" class="form-control" placeholder="VD: 0123456789" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CompanySize" class="form-label fw-semibold small">Quy mô</label>
                                    <select asp-for="CompanySize" class="form-select">
                                        <option value="">-- Chọn quy mô --</option>
                                        <option>1-10</option>
                                        <option>11-50</option>
                                        <option>51-200</option>
                                        <option>201-500</option>
                                        <option>501-1000</option>
                                        <option>1000+</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CompanyIndustry" class="form-label fw-semibold small">Lĩnh vực</label>
                                    <input asp-for="CompanyIndustry" class="form-control" placeholder="VD: Công nghệ thông tin" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CompanyWebsite" class="form-label fw-semibold small">Website</label>
                                    <input asp-for="CompanyWebsite" class="form-control" placeholder="https://company.com" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CompanyEmail" class="form-label fw-semibold small">Email công ty</label>
                                    <input asp-for="CompanyEmail" class="form-control" placeholder="hr@company.com" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CompanyPhone" class="form-label fw-semibold small">SĐT công ty</label>
                                    <input asp-for="CompanyPhone" class="form-control" placeholder="028 1234 5678" />
                                </div>
                                <div class="col-12">
                                    <label asp-for="CompanyDescription" class="form-label fw-semibold small">Mô tả công ty</label>
                                    <textarea asp-for="CompanyDescription" class="form-control" rows="3" placeholder="Giới thiệu ngắn về công ty..."></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Điều khoản & Submit -->
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="agreeTerms" asp-for="AgreeTerms" required />
                                <label class="form-check-label small" for="agreeTerms">
                                    Tôi đồng ý với <a href="#" class="text-success">Điều khoản dịch vụ</a> và <a href="#" class="text-success">Chính sách bảo mật</a>
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-auth">
                            <i class="fas fa-user-plus me-2"></i>Đăng ký Nhà tuyển dụng
                        </button>

                        <div class="auth-divider mt-3"><span>hoặc</span></div>

                        <div class="text-center">
                            <p class="auth-link-text mb-1">
                                Bạn là ứng viên? <a asp-action="Register" class="auth-link">Đăng ký ứng viên</a>
                            </p>
                            <p class="auth-link-text mb-0">
                                Đã có tài khoản? <a asp-action="Login" class="auth-link">Đăng nhập ngay</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
