@model RJMS.Vn.Edu.Fpt.Model.DTOs.RegisterDTO
@{
    ViewData["Title"] = "Đăng ký Ứng viên";
}

<section class="auth-section">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="auth-card" style="max-width:100%; border-radius:16px; overflow:hidden;">
                    <div class="auth-header text-center p-4"
                         style="background:linear-gradient(135deg,rgba(0,177,79,.12),rgba(0,177,79,.03)); border-bottom:1px solid #d7efe1;">
                        <h2 class="auth-title mb-1" style="color:#00b14f; font-weight:800;">Đăng ký tài khoản Ứng viên</h2>
                        <p class="auth-subtitle mb-0">Tạo tài khoản để tìm kiếm việc làm trên Finding Jobs</p>
                    </div>
                    
                    <form asp-action="Register" method="post" class="auth-form" novalidate id="register-form">
                        @Html.AntiForgeryToken()
                        <input asp-for="Role" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" id="validation-summary"></div>

                        <!-- Thông tin tài khoản -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 pb-2" style="color:#0f172a; border-bottom:2px solid #d7efe1;">
                                <i class="fas fa-user-circle me-2 text-success"></i>Thông tin tài khoản
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label asp-for="Email" class="form-label fw-semibold small">Email *</label>
                                    <input asp-for="Email" class="form-control" type="email" placeholder="name@example.com" required />
                                    <div id="emailErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Password" class="form-label fw-semibold small">Mật khẩu *</label>
                                    <input asp-for="Password" class="form-control" type="password" placeholder="Tối thiểu 8 ký tự" autocomplete="new-password" required />
                                    <div id="passwordErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ConfirmPassword" class="form-label fw-semibold small">Xác nhận mật khẩu *</label>
                                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu" required />
                                    <div id="confirmPasswordErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Thông tin cá nhân -->
                        <div class="mb-4">
                            <h6 class="fw-bold mb-3 pb-2" style="color:#0f172a; border-bottom:2px solid #d7efe1;">
                                <i class="fas fa-id-card me-2 text-success"></i>Thông tin cá nhân
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="FirstName" class="form-label fw-semibold small">Họ *</label>
                                    <input asp-for="FirstName" class="form-control" placeholder="Nhập họ" required />
                                    <div id="firstNameErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="LastName" class="form-label fw-semibold small">Tên *</label>
                                    <input asp-for="LastName" class="form-control" placeholder="Nhập tên" required />
                                    <div id="lastNameErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label fw-semibold small">Số điện thoại *</label>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="0912345678" required maxlength="10" inputmode="numeric" pattern="\d{10}" />
                                    <div id="phoneErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DateOfBirth" class="form-label fw-semibold small">Ngày sinh *</label>
                                    <input asp-for="DateOfBirth" class="form-control" type="date" required />
                                    <div id="dobErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Gender" class="form-label fw-semibold small">Giới tính *</label>
                                    <select asp-for="Gender" class="form-select" required>
                                        <option value="">Chọn giới tính</option>
                                        <option value="Male">Nam</option>
                                        <option value="Female">Nữ</option>
                                        <option value="Other">Khác</option>
                                    </select>
                                    <div id="genderErr" class="text-danger small mt-1" style="min-height:18px"></div>
                                    <span asp-validation-for="Gender" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <a asp-action="RegisterRecruiter" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-briefcase me-2"></i>Bạn là Nhà tuyển dụng? Đăng ký tại đây
                            </a>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="agreeTerms" required>
                                <label class="form-check-label small" for="agreeTerms">
                                    Tôi đồng ý với <a href="#" class="text-success">Điều khoản dịch vụ</a> và <a href="#" class="text-success">Chính sách bảo mật</a>
                                </label>
                                <div id="agreeErr" class="text-danger small mt-1" style="min-height:18px"></div>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 btn-auth">
                            <i class="fas fa-user-plus me-2"></i>Đăng ký
                        </button>
                        
                        <div class="auth-divider mt-3">
                            <span>hoặc</span>
                        </div>
                        
                        <div class="text-center">
                            <p class="auth-link-text mb-0">
                                Đã có tài khoản? <a asp-action="Login" class="auth-link">Đăng nhập ngay</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const summary = document.getElementById('validation-summary');
            if (summary && summary.textContent.trim().length > 0) {
                toastr.error('Vui lòng kiểm tra lại thông tin đăng ký.');
            }

            var form = document.getElementById('register-form');
            if (!form) return;

            var emailInput = document.getElementById('Email');
            var passwordInput = document.getElementById('Password');
            var confirmPasswordInput = document.getElementById('ConfirmPassword');
            var phoneInput = document.getElementById('PhoneNumber');
            var firstNameInput = document.getElementById('FirstName');
            var lastNameInput = document.getElementById('LastName');
            var dobInput = document.getElementById('DateOfBirth');
            var genderInput = document.getElementById('Gender');
            var agreeInput = document.getElementById('agreeTerms');

            function setErr(input, divId, msg) {
                var el = document.getElementById(divId);
                if (el) el.textContent = msg;
                if (!input) return;
                if (msg) {
                    input.classList.add('is-invalid');
                    input.classList.remove('is-valid');
                } else {
                    input.classList.remove('is-invalid');
                    if (input.value) input.classList.add('is-valid');
                }
            }

            function isValidEmail(v) {
                var at = v.indexOf('@@');
                if (at < 1) return false;
                var dot = v.lastIndexOf('.');
                return dot > at + 1 && dot < v.length - 1;
            }

            function isValidPassword(v) {
                return v.length >= 8 && /[A-Z]/.test(v) && /[0-9]/.test(v) && /[^a-zA-Z0-9]/.test(v);
            }

            function validateEmail() {
                var v = emailInput ? emailInput.value.trim() : '';
                if (!v) { setErr(emailInput, 'emailErr', ''); return true; }
                var ok = isValidEmail(v);
                setErr(emailInput, 'emailErr', ok ? '' : 'Email không đúng định dạng.');
                return ok;
            }

            function validatePassword() {
                var v = passwordInput ? passwordInput.value : '';
                if (!v) { setErr(passwordInput, 'passwordErr', ''); return true; }
                var ok = isValidPassword(v);
                setErr(passwordInput, 'passwordErr', ok ? '' : 'Mật khẩu phải có ít nhất 8 ký tự, gồm chữ hoa, chữ số và ký tự đặc biệt.');
                return ok;
            }

            function normalizePhone(input) {
                if (!input) return '';
                var digits = input.value.replace(/\D/g, '').slice(0, 10);
                if (input.value !== digits) input.value = digits;
                return digits;
            }

            function validatePhone() {
                if (!phoneInput) return true;
                var digits = normalizePhone(phoneInput);
                if (!digits) {
                    setErr(phoneInput, 'phoneErr', 'Vui lòng nhập số điện thoại.');
                    return false;
                }
                if (digits.length !== 10) {
                    setErr(phoneInput, 'phoneErr', 'Số điện thoại phải đúng 10 chữ số.');
                    return false;
                }
                setErr(phoneInput, 'phoneErr', '');
                return true;
            }

            function validateRequiredFields() {
                var ok = true;
                var checks = [
                    { input: firstNameInput, errId: 'firstNameErr', msg: 'Vui lòng nhập họ.' },
                    { input: lastNameInput, errId: 'lastNameErr', msg: 'Vui lòng nhập tên.' },
                    { input: confirmPasswordInput, errId: 'confirmPasswordErr', msg: 'Vui lòng xác nhận mật khẩu.' },
                    { input: dobInput, errId: 'dobErr', msg: 'Vui lòng chọn ngày sinh.' },
                    { input: genderInput, errId: 'genderErr', msg: 'Vui lòng chọn giới tính.' }
                ];

                checks.forEach(function (item) {
                    if (!item.input) return;
                    if (!item.input.value) {
                        ok = false;
                        setErr(item.input, item.errId, item.msg);
                    } else {
                        setErr(item.input, item.errId, '');
                    }
                });

                if (agreeInput) {
                    if (!agreeInput.checked) {
                        ok = false;
                        agreeInput.classList.add('is-invalid');
                        setErr(agreeInput, 'agreeErr', 'Vui lòng đồng ý với điều khoản.');
                    } else {
                        agreeInput.classList.remove('is-invalid');
                        setErr(agreeInput, 'agreeErr', '');
                    }
                }

                return ok;
            }

            if (emailInput) {
                emailInput.addEventListener('input', validateEmail);
                emailInput.addEventListener('blur', validateEmail);
            }
            if (passwordInput) {
                passwordInput.addEventListener('input', validatePassword);
                passwordInput.addEventListener('blur', validatePassword);
            }
            if (phoneInput) {
                phoneInput.addEventListener('input', validatePhone);
                phoneInput.addEventListener('blur', validatePhone);
            }

            form.addEventListener('submit', function (e) {
                var rOk = validateRequiredFields();
                var eOk = validateEmail();
                var pOk = validatePassword();
                var phOk = validatePhone();
                if (!rOk || !eOk || !pOk || !phOk) e.preventDefault();
            });
        })();
    </script>
}
