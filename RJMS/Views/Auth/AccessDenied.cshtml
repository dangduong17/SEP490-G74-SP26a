@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<section class="auth-section">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="auth-card text-center" style="padding:48px 36px;">
                    <div class="mb-4">
                        <i class="fas fa-lock fa-4x text-danger"></i>
                    </div>
                    <h2 class="auth-title mb-3">Access Denied</h2>
                    <p class="text-muted mb-4">
                        Bạn không có quyền truy cập trang này. Vui lòng đăng nhập với tài khoản phù hợp
                        hoặc liên hệ quản trị viên nếu bạn cho rằng đây là nhầm lẫn.
                    </p>
                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-home me-2"></i>Về trang chủ
                        </a>
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary">
                            <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>