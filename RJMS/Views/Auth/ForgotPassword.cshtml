@model RJMS.Vn.Edu.Fpt.Model.DTOs.ForgotPasswordDTO
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<section class="auth-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="auth-card">
                    <div class="auth-header">
                        <h2 class="auth-title">Quên mật khẩu</h2>
                        <p class="auth-subtitle">Nhập email của bạn để nhận mật khẩu mới</p>
                    </div>

                    <form asp-action="ForgotPassword" method="post" class="auth-form" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="visually-hidden"></span>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger visually-hidden" role="alert"
                             id="validation-summary"></div>

                        <button type="submit" class="btn btn-primary w-100 btn-auth">Gửi mật khẩu mới</button>

                        <div class="text-center mt-3">
                            <a asp-action="Login" class="auth-link">Quay lại đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
            (function () {
                const summary = document.getElementById('validation-summary');
                if (summary && summary.textContent.trim().length > 0) {
                    toastr.error('Vui lòng kiểm tra lại thông tin email.');
                }
            })();
    </script>
}