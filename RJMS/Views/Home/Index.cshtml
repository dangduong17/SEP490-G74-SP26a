@{
    ViewData["Title"] = "Finding Jobs - Tìm việc làm, Tuyển dụng hiệu quả";
}

<!-- Hero Banner Section -->
<section class="hero-banner">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="hero-heading">
                    Tiếp lửa ý chí<br />
                    <span class="text-primary">Nơi thành công</span>
                </h1>
                <p class="hero-subheading">
                    Finding Jobs - Hệ sinh thái nhân sự tiên tiến<br />
                    Công nghệ AI hóa tuyển dụng & quản trị
                </p>

                <!-- Search Box -->
                <div class="search-box-wrapper">
                    <form class="search-form">
                        <div class="row g-2">
                            <div class="col-md-5">
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0">
                                        <i class="fas fa-search text-muted"></i>
                                    </span>
                                    <input type="text" class="form-control border-start-0"
                                           placeholder="Vị trí ứng tuyển">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0">
                                        <i class="fas fa-map-marker-alt text-muted"></i>
                                    </span>
                                    <select class="form-select border-start-0">
                                        <option>Tất cả địa điểm</option>
                                        <option>Hà Nội</option>
                                        <option>TP. Hồ Chí Minh</option>
                                        <option>Đà Nẵng</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-search me-2"></i>Tìm việc
                                </button>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Popular Keywords -->
                <div class="popular-keywords mt-3">
                    <span class="text-muted me-2">Từ khóa phổ biến:</span>
                    <a href="#" class="keyword-tag">IT</a>
                    <a href="#" class="keyword-tag">Marketing</a>
                    <a href="#" class="keyword-tag">Kinh doanh</a>
                    <a href="#" class="keyword-tag">Kế toán</a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <img src="https://cdn-new.topcv.vn/unsafe/https://static.topcv.vn/v4/image/welcome/hero/image-hero.png"
                     alt="Hero" class="img-fluid">
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section">
    <div class="container">
        <div class="row text-center">
            <div class="col-6 col-md-3 mb-3">
                <div class="stat-item">
                    <h3 class="stat-number">50,000+</h3>
                    <p class="stat-label">Nhà tuyển dụng</p>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="stat-item">
                    <h3 class="stat-number">100,000+</h3>
                    <p class="stat-label">Doanh nghiệp</p>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="stat-item">
                    <h3 class="stat-number">5,000,000+</h3>
                    <p class="stat-label">Việc làm kết nối</p>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="stat-item">
                    <h3 class="stat-number">10,000,000+</h3>
                    <p class="stat-label">Lượt tải ứng dụng</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Jobs Section -->
<section class="featured-jobs-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Việc làm tốt nhất</h2>
            <a asp-controller="Candidates" asp-action="JobList" class="btn btn-outline-primary">
                Xem tất cả <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>

        <div class="row">
            @for (int i = 0; i < 6; i++)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="job-card">
                        <div class="job-card-header">
                            <div class="company-logo">
                                <i class="fas fa-building"></i>
                            </div>
                            <div class="job-actions">
                                <button class="btn-save"><i class="far fa-heart"></i></button>
                            </div>
                        </div>
                        <div class="job-card-body">
                            <h3 class="job-title">
                                <a href="#">Nhân Viên Kinh Doanh - Thu Nhập Hấp Dẫn</a>
                            </h3>
                            <p class="company-name">Công ty TNHH ABC</p>
                            <div class="job-info">
                                <span class="salary"><i class="fas fa-dollar-sign me-1"></i>15 - 25 triệu</span>
                                <span class="location"><i class="fas fa-map-marker-alt me-1"></i>Hà Nội</span>
                            </div>
                            <div class="job-tags">
                                <span class="job-tag">Full-time</span>
                                <span class="job-tag">Kinh nghiệm 2 năm</span>
                            </div>
                        </div>
                        <div class="job-card-footer">
                            <span class="job-date"><i class="far fa-clock me-1"></i>2 ngày trước</span>
                            <a href="#" class="btn btn-sm btn-primary">Ứng tuyển ngay</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Top Companies Section -->
<section class="top-companies-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Thương hiệu lớn tiêu biểu</h2>
            <a href="#" class="view-all-link">Xem tất cả <i class="fas fa-arrow-right ms-2"></i></a>
        </div>

        <div class="row">
            @for (int i = 0; i < 8; i++)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">
                    <div class="company-card">
                        <div class="company-logo-wrapper">
                            <i class="fas fa-building fa-3x text-primary"></i>
                        </div>
                        <h4 class="company-card-name">Công ty ABC</h4>
                        <p class="company-jobs-count">
                            <i class="fas fa-briefcase me-1"></i>25 việc làm
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CV Builder Section -->
<section class="cv-builder-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <img src="https://cdn-new.topcv.vn/unsafe/https://static.topcv.vn/v4/image/welcome/feature-job-seeker/cv-builder/bg-section-cv.png"
                     alt="CV Builder" class="img-fluid">
            </div>
            <div class="col-lg-6">
                <div class="feature-content">
                    <h2 class="feature-title">Tạo CV online miễn phí</h2>
                    <p class="feature-description">
                        Công cụ tạo CV chuyên nghiệp, dễ dàng và nhanh chóng.
                        Hơn 100+ mẫu CV đẹp, chuẩn theo từng ngành nghề.
                    </p>
                    <ul class="feature-list">
                        <li><i class="fas fa-check-circle text-primary me-2"></i>Hơn 100+ mẫu CV đẹp, chuẩn</li>
                        <li><i class="fas fa-check-circle text-primary me-2"></i>Tạo CV nhanh chóng, dễ dùng</li>
                        <li><i class="fas fa-check-circle text-primary me-2"></i>Tải xuống PDF chất lượng cao</li>
                        <li><i class="fas fa-check-circle text-primary me-2"></i>AI gợi ý nội dung CV</li>
                    </ul>
                    <a asp-controller="CVs" asp-action="CVList" class="btn btn-primary btn-lg mt-3">
                        <i class="fas fa-file-alt me-2"></i>Tạo CV ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section">
    <div class="container">
        <h2 class="section-title text-center mb-5">Top ngành nghề nổi bật</h2>
        <div class="row">
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-laptop-code"></i>
                    </div>
                    <h4 class="category-name">IT - Phần mềm</h4>
                    <p class="category-jobs">12,500 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-bullhorn"></i>
                    </div>
                    <h4 class="category-name">Marketing</h4>
                    <p class="category-jobs">8,200 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h4 class="category-name">Kinh doanh</h4>
                    <p class="category-jobs">9,500 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-calculator"></i>
                    </div>
                    <h4 class="category-name">Kế toán</h4>
                    <p class="category-jobs">6,300 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    <h4 class="category-name">Nhân sự</h4>
                    <p class="category-jobs">4,800 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-paint-brush"></i>
                    </div>
                    <h4 class="category-name">Thiết kế</h4>
                    <p class="category-jobs">5,100 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-headset"></i>
                    </div>
                    <h4 class="category-name">Chăm sóc KH</h4>
                    <p class="category-jobs">7,200 việc làm</p>
                </a>
            </div>
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a href="#" class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-gavel"></i>
                    </div>
                    <h4 class="category-name">Pháp lý</h4>
                    <p class="category-jobs">3,600 việc làm</p>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- App Download Section -->
<section class="app-download-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="app-title">Kiến tạo sự nghiệp của riêng bạn với ứng dụng Finding Jobs</h2>
                <p class="app-description">
                    "Tất cả trong một" - Trải nghiệm tạo CV, tìm việc, ứng tuyển và hơn thế nữa
                    chỉ với một ứng dụng duy nhất. Bắt đầu ngay hôm nay!
                </p>
                <div class="app-download-buttons">
                    <a href="#" class="app-btn">
                        <i class="fab fa-apple"></i>
                        <div>
                            <small>Download on the</small>
                            <strong>App Store</strong>
                        </div>
                    </a>
                    <a href="#" class="app-btn">
                        <i class="fab fa-google-play"></i>
                        <div>
                            <small>GET IT ON</small>
                            <strong>Google Play</strong>
                        </div>
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center d-none d-lg-block">
                <img src="https://cdn-new.topcv.vn/unsafe/https://static.topcv.vn/v4/image/welcome/download-app/phone.png"
                     alt="App Screenshot" class="img-fluid" style="max-width: 400px;">
            </div>
        </div>
    </div>
</section>