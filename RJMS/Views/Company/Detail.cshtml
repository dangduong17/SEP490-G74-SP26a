@model RJMS.vn.edu.fpt.Models.DTOs.CompanyDetailsViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userRole = Context.Request.Cookies["UserRole"];

    string SalaryText(decimal? min, decimal? max)
    {
        if (min.HasValue && max.HasValue)
            return $"{min.Value / 1000000:N0} - {max.Value / 1000000:N0} triệu";
        if (max.HasValue)
            return $"Tới {max.Value / 1000000:N0} triệu";
        return "Thoả thuận";
    }
}

@section Styles {
<style>
    body { background: #f4f7f6; }
    .company-container { max-width: 1140px; margin: 0 auto; padding: 30px 15px; }

    /* Hero Section */
    .company-hero {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        margin-bottom: 24px;
        position: relative;
    }
    .hero-cover {
        height: 220px;
        background: linear-gradient(135deg, #1c3e2e 0%, #00b14f 100%);
        background-size: cover;
        background-position: center;
    }
    .hero-content {
        padding: 0 30px 24px;
        display: flex;
        align-items: flex-end;
        margin-top: -60px;
        gap: 24px;
    }
    .company-logo-big {
        width: 140px;
        height: 140px;
        background: #fff;
        border-radius: 16px;
        border: 4px solid #fff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }
    .company-logo-big img { max-width: 90%; max-height: 90%; object-fit: contain; }
    
    .hero-text { flex: 1; padding-bottom: 10px; }
    .hero-text h1 { font-size: 1.75rem; font-weight: 800; color: #1a202c; margin: 0 0 8px; }
    .hero-meta-top { display: flex; gap: 20px; font-size: 0.95rem; color: #4a5568; }
    .hero-meta-top span { display: flex; align-items: center; gap: 8px; }
    .hero-meta-top i { color: #00b14f; }

    .hero-actions { padding-bottom: 15px; display: flex; gap: 12px; }
    .btn-follow {
        background: #00b14f; color: #fff; border: none; border-radius: 8px;
        padding: 10px 24px; font-size: 0.95rem; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s;
    }
    .btn-follow:hover { background: #009744; }
    .btn-follow.following { background: #edf2f7; color: #4a5568; border: 1px solid #cbd5e0; }
    .btn-follow.following:hover { background: #e2e8f0; color: #2d3748; }

    /* Layout tabs */
    .company-body { display: flex; gap: 24px; }
    .company-main { flex: 1; min-width: 0; }
    .company-sidebar { width: 340px; flex-shrink: 0; }

    .card-box { background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; padding: 24px; margin-bottom: 24px; }
    .card-title { font-size: 1.15rem; font-weight: 700; color: #2d3748; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .card-title i { color: #00b14f; }

    .rich-text { font-size: 1rem; line-height: 1.7; color: #4a5568; }
    .rich-text p { margin-bottom: 12px; }

    /* Jobs list */
    .job-item {
        display: flex; gap: 16px; padding: 16px; border: 1px solid #edf2f7; border-radius: 10px;
        margin-bottom: 12px; transition: all 0.2s; text-decoration: none; color: inherit;
    }
    .job-item:hover { border-color: #00b14f; box-shadow: 0 4px 12px rgba(0,177,79,0.08); background: #f0fdf4; }
    .job-item-info { flex: 1; }
    .job-item-title { font-weight: 700; color: #2d3748; font-size: 1rem; margin-bottom: 4px; display: block; }
    .job-item-meta { display: flex; gap: 15px; font-size: 0.85rem; color: #718096; }
    .job-item-salary { color: #00b14f; font-weight: 700; }

    /* Sidebar info */
    .side-info-row { display: flex; gap: 12px; margin-bottom: 16px; align-items: flex-start; }
    .side-info-row i { color: #00b14f; width: 20px; font-size: 1.1rem; margin-top: 3px; flex-shrink: 0; }
    .side-info-row div .label { font-size: 0.75rem; color: #a0aec0; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; }
    .side-info-row div .value { font-size: 0.95rem; color: #2d3748; font-weight: 600; margin-top: 2px; }
    .side-info-row a { color: #00b14f; text-decoration: none; }
    .side-info-row a:hover { text-decoration: underline; }

    @@media (max-width: 992px) {
        .company-body { flex-direction: column; }
        .company-sidebar { width: 100%; order: 1; }
        .hero-content { flex-direction: column; align-items: center; text-align: center; margin-top: -70px; }
        .hero-actions { justify-content: center; }
        .hero-meta-top { justify-content: center; flex-wrap: wrap; }
    }
</style>
}

<div class="company-container">
    <!-- Hero -->
    <div class="company-hero">
        <div class="hero-cover" style="background-image: url(@(string.IsNullOrEmpty(Model.CoverImage) ? "" : Model.CoverImage))"></div>
        <div class="hero-content">
            <div class="company-logo-big">
                <img src="@(string.IsNullOrEmpty(Model.Logo) ? "/images/logo_default.png" : Model.Logo)" alt="@Model.Name" />
            </div>
            <div class="hero-text">
                <h1>@Model.Name</h1>
                <div class="hero-meta-top">
                    @if (!string.IsNullOrEmpty(Model.Website))
                    {
                        <span><i class="fas fa-globe"></i> @(new Uri(Model.Website).Host)</span>
                    }
                    <span><i class="fas fa-users"></i> @(Model.CompanySize ?? "N/A") nhân viên</span>
                    <span><i class="fas fa-heart"></i> @Model.FollowerCount người theo dõi</span>
                </div>
            </div>
            <div class="hero-actions">
                <button id="btnFollow" class="btn-follow @(Model.IsFollowing ? "following" : "")" 
                        data-id="@Model.Id" data-following="@Model.IsFollowing.ToString().ToLower()">
                    @if (Model.IsFollowing)
                    {
                        <i class="fas fa-check"></i> <span>Đang theo dõi</span>
                    }
                    else
                    {
                        <i class="fas fa-plus"></i> <span>Theo dõi công ty</span>
                    }
                </button>
            </div>
        </div>
    </div>

    <div class="company-body">
        <!-- Main Content -->
        <div class="company-main">
            <!-- About -->
            <div class="card-box">
                <div class="card-title"><i class="fas fa-info-circle"></i> Giới thiệu công ty</div>
                <div class="rich-text">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                    }
                    else
                    {
                        <p class="text-muted italic">Chưa có thông tin giới thiệu về công ty.</p>
                    }
                </div>
            </div>

            <!-- Benefits -->
            @if (!string.IsNullOrEmpty(Model.Benefits))
            {
                <div class="card-box">
                    <div class="card-title"><i class="fas fa-gift"></i> Quyền lợi & Phúc lợi</div>
                    <div class="rich-text">
                        @Html.Raw(Model.Benefits.Replace("\n", "<br/>"))
                    </div>
                </div>
            }

            <!-- Active Jobs -->
            <div class="card-box" id="jobs">
                <div class="card-title"><i class="fas fa-briefcase"></i> Tuyển dụng (@Model.ActiveJobs.Count)</div>
                <div class="jobs-list">
                    @if (Model.ActiveJobs.Any())
                    {
                        @foreach (var job in Model.ActiveJobs)
                        {
                            <a href="@Url.Action("Detail", "Job", new { id = job.Id })" class="job-item">
                                <div class="job-item-info">
                                    <span class="job-item-title">@job.Title</span>
                                    <div class="job-item-meta">
                                        <span class="job-item-salary">@SalaryText(job.MinSalary, job.MaxSalary)</span>
                                        <span><i class="fas fa-map-marker-alt me-1"></i> @job.LocationName</span>
                                        <span><i class="far fa-clock me-1"></i> @job.CreatedAt?.ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <button class="btn btn-sm btn-outline-success">Chi tiết</button>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">Hiện tại công ty chưa đăng tin tuyển dụng nào.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="company-sidebar">
            <div class="card-box">
                <div class="card-title"><i class="fas fa-building"></i> Thông tin liên hệ</div>
                
                <div class="side-info-row">
                    <i class="fas fa-map-marker-alt"></i>
                    <div>
                        <div class="label">Địa chỉ</div>
                        <div class="value">@Model.Address</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Industry))
                {
                    <div class="side-info-row">
                        <i class="fas fa-industry"></i>
                        <div>
                            <div class="label">Ngành nghề</div>
                            <div class="value">@Model.Industry</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Website))
                {
                    <div class="side-info-row">
                        <i class="fas fa-globe"></i>
                        <div>
                            <div class="label">Website</div>
                            <div class="value"><a href="@Model.Website" target="_blank">@Model.Website</a></div>
                        </div>
                    </div>
                }

                <div class="side-info-row">
                    <i class="fas fa-check-circle"></i>
                    <div>
                        <div class="label">Trạng thái xác minh</div>
                        <div class="value">
                            @if (Model.IsVerified == true)
                            {
                                <span class="text-success"><i class="fas fa-shield-alt me-1"></i> Đã xác minh</span>
                            }
                            else
                            {
                                <span class="text-muted">Chưa xác minh</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        $('#btnFollow').click(function() {
            const btn = $(this);
            const id = btn.data('id');
            const isFollowing = btn.attr('data-following') === 'true';
            
            const url = isFollowing ? '/Company/Unfollow/' + id : '/Company/Follow/' + id;
            
            $.post(url, function(res) {
                if (res.success) {
                    if (isFollowing) {
                        btn.removeClass('following').attr('data-following', 'false');
                        btn.find('i').removeClass('fa-check').addClass('fa-plus');
                        btn.find('span').text('Theo dõi công ty');
                    } else {
                        btn.addClass('following').attr('data-following', 'true');
                        btn.find('i').removeClass('fa-plus').addClass('fa-check');
                        btn.find('span').text('Đang theo dõi');
                    }
                } else if (res.message) {
                    alert(res.message);
                }
            });
        });
    });
</script>
}
