@model RecruiterDashboardViewModel
@using RJMS.vn.edu.fpt.Models.DTOs
@{
    ViewData["Title"] = "Recruiter Dashboard";
    ViewData["HidePageTitle"] = true;
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
    var userRole = Context.Request.Cookies["UserRole"];
}

@section Styles {
<style>
    /* ===== Breadcrumb ===== */
    .rpage-breadcrumb {
        margin-bottom: 10px;
        font-size: 0.8rem;
        color: #9ca3af;
    }
    .rpage-breadcrumb a { color: #6b7280; text-decoration: none; }
    .rpage-breadcrumb a:hover { color: #00b14f; }

    /* ===== Page Header Row ===== */
    .rpage-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 24px;
    }
    .rpage-header h1 {
        font-size: 1.55rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px;
    }
    .rpage-header p {
        font-size: 0.84rem;
        color: #6b7280;
        margin: 0;
    }
    .btn-post-job {
        background: #00b14f;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 0.875rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
        flex-shrink: 0;
    }
    .btn-post-job:hover { background: #009744; color: #fff; }

    /* ===== Stat Cards ===== */
    .rstat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .rstat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px 22px;
        transition: box-shadow 0.2s;
    }
    .rstat-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,0.07); }
    .rstat-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }
    .rstat-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }
    .rstat-trend {
        font-size: 0.75rem;
        font-weight: 600;
        color: #00b14f;
        background: #f0fdf4;
        padding: 3px 8px;
        border-radius: 20px;
    }
    .rstat-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #111827;
        line-height: 1;
        margin-bottom: 4px;
    }
    .rstat-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 2px;
    }
    .rstat-sub {
        font-size: 0.75rem;
        color: #9ca3af;
    }

    /* ===== Main grid: charts left + sidebar right ===== */
    .rdash-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 20px;
        align-items: start;
    }

    /* ===== Chart cards ===== */
    .rchart-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 20px;
    }
    .rchart-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px;
    }
    .rchart-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 4px;
    }
    .rchart-card-title {
        font-size: 0.93rem;
        font-weight: 700;
        color: #111827;
    }
    .rchart-card-sub {
        font-size: 0.75rem;
        color: #9ca3af;
        margin-bottom: 14px;
    }
    .rchart-period-btn {
        font-size: 0.75rem;
        background: #f3f4f6;
        border: none;
        border-radius: 6px;
        padding: 4px 12px;
        color: #6b7280;
        cursor: pointer;
    }
    .rchart-period-btn:hover { background: #e5e7eb; }

    /* ===== Applications table ===== */
    .rapp-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
    }
    .rapp-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }
    .rapp-title { font-size: 0.95rem; font-weight: 700; color: #111827; }
    .rapp-viewall {
        font-size: 0.82rem;
        font-weight: 600;
        color: #00b14f;
        text-decoration: none;
    }
    .rapp-viewall:hover { color: #009744; }

    .rapp-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .rapp-table th {
        font-size: 0.75rem;
        font-weight: 600;
        color: #9ca3af;
        padding: 8px 10px;
        border-bottom: 1px solid #f3f4f6;
        text-align: left;
    }
    .rapp-table td {
        padding: 12px 10px;
        border-bottom: 1px solid #f9fafb;
        color: #374151;
        vertical-align: middle;
    }
    .rapp-table tr:last-child td { border-bottom: none; }

    /* Candidate avatar */
    .cand-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00b14f, #009744);
        color: #fff;
        font-weight: 700;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-right: 10px;
        flex-shrink: 0;
    }
    .cand-cell { display: flex; align-items: center; }

    /* Application status badges */
    .abadge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .status-new        { background: #dbeafe; color: #1d4ed8; }
    .status-reviewing  { background: #fef9c3; color: #713f12; }
    .status-interview  { background: #fce7f3; color: #9d174d; }
    .status-hired      { background: #dcfce7; color: #15803d; }
    .status-rejected   { background: #fee2e2; color: #b91c1c; }

    /* Action buttons */
    .rapp-action { display: flex; gap: 8px; align-items: center; }
    .rapp-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.75rem;
        color: #6b7280;
        background: #f3f4f6;
        border: none;
        border-radius: 6px;
        padding: 5px 10px;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
        white-space: nowrap;
    }
    .rapp-btn:hover { background: #e5e7eb; color: #374151; }

    /* ===== Job Posts table ===== */
    .rjob-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .rjob-table th {
        font-size: 0.75rem;
        font-weight: 600;
        color: #9ca3af;
        padding: 8px 10px;
        border-bottom: 1px solid #f3f4f6;
        text-align: left;
    }
    .rjob-table td {
        padding: 12px 10px;
        border-bottom: 1px solid #f9fafb;
        color: #374151;
        vertical-align: middle;
    }
    .rjob-table tr:last-child td { border-bottom: none; }

    .jbadge { display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
    .status-active-post  { background: #dcfce7; color: #15803d; }
    .status-expired-post { background: #fee2e2; color: #b91c1c; }

    /* Applicant initials mini-row */
    .app-initials { display: flex; gap: 3px; }
    .app-init-dot {
        width: 22px; height: 22px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.6rem; font-weight: 700; color: #fff;
    }
    .init-a { background: #3b82f6; }
    .init-b { background: #8b5cf6; }
    .init-c { background: #ec4899; }

    /* ===== RIGHT SIDEBAR ===== */
    .rsidebar { display: flex; flex-direction: column; gap: 16px; }

    /* Subscription card */
    .rsub-card {
        background: linear-gradient(135deg, #059669 0%, #00b14f 100%);
        border-radius: 12px;
        padding: 20px;
        color: #fff;
    }
    .rsub-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px; }
    .rsub-title { font-size: 0.95rem; font-weight: 700; }
    .rsub-plan-badge {
        background: rgba(255,255,255,0.25);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .rsub-valid { font-size: 0.75rem; opacity: 0.85; margin-bottom: 18px; }

    .rsub-metric { margin-bottom: 12px; }
    .rsub-metric-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        margin-bottom: 5px;
        opacity: 0.9;
    }
    .rsub-metric-val { font-weight: 600; }
    .rsub-bar-bg { background: rgba(255,255,255,0.25); border-radius: 20px; height: 6px; }
    .rsub-bar-fill {
        background: #fff;
        height: 6px;
        border-radius: 20px;
        transition: width 0.6s ease;
    }

    .rsub-metric-plain {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.82rem;
        padding-top: 8px;
        border-top: 1px solid rgba(255,255,255,0.2);
        margin-top: 4px;
    }
    .rsub-metric-plain .val { font-weight: 700; font-size: 0.9rem; }

    .btn-upgrade {
        display: block;
        width: 100%;
        text-align: center;
        background: #fff;
        color: #059669;
        font-weight: 700;
        font-size: 0.875rem;
        border: none;
        border-radius: 8px;
        padding: 10px;
        margin-top: 18px;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }
    .btn-upgrade:hover { background: #f0fdf4; color: #047857; }
    .rsub-contact {
        text-align: center;
        font-size: 0.72rem;
        color: rgba(255,255,255,0.75);
        margin-top: 8px;
    }
    .rsub-contact a { color: rgba(255,255,255,0.95); text-decoration: underline; }

    /* Recruitment tip card */
    .rtip-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 18px;
    }
    .rtip-label {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #9ca3af;
        margin-bottom: 12px;
    }
    .rtip-content { display: flex; gap: 12px; align-items: flex-start; }
    .rtip-icon {
        width: 36px; height: 36px;
        background: #f0fdf4;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }
    .rtip-body h5 { font-size: 0.88rem; font-weight: 700; color: #111827; margin: 0 0 4px; }
    .rtip-body p  { font-size: 0.78rem; color: #6b7280; margin: 0 0 8px; line-height: 1.5; }
    .rtip-link { font-size: 0.8rem; font-weight: 600; color: #00b14f; text-decoration: none; }
    .rtip-link:hover { color: #009744; text-decoration: underline; }

    @@media (max-width: 1100px) {
        .rstat-grid { grid-template-columns: repeat(2, 1fr); }
        .rdash-grid  { grid-template-columns: 1fr; }
        .rchart-row  { grid-template-columns: 1fr; }
    }
</style>
}

<!-- Breadcrumb -->
<div class="rpage-breadcrumb">
    <a href="#">Trang chủ</a>
    <span class="sep">›</span>
    <span>Recruiter Dashboard</span>
</div>

<!-- Page header -->
<div class="rpage-header">
    <div>
        <h1>Recruiter Dashboard</h1>
        <p>Tổng quan hoạt động tuyển dụng của bạn.</p>
    </div>
    <a asp-action="CreateJob" class="btn-post-job">
        <i class="fas fa-plus"></i> Đăng tin tuyển dụng
    </a>
</div>

<!-- Stat cards -->
<div class="rstat-grid">
    <div class="rstat-card">
        <div class="rstat-top">
            <div class="rstat-icon" style="background:#ecfdf5;"><i class="fas fa-briefcase" style="color:#00b14f;"></i></div>
            <span class="rstat-trend">+12%</span>
        </div>
        <div class="rstat-value">@Model.ActiveJobPosts</div>
        <div class="rstat-label">Tin tuyển dụng hoạt động</div>
        <div class="rstat-sub">Tin đang hiển thị</div>
    </div>
    <div class="rstat-card">
        <div class="rstat-top">
            <div class="rstat-icon" style="background:#eff6ff;"><i class="fas fa-file-alt" style="color:#3b82f6;"></i></div>
            <span class="rstat-trend">+12%</span>
        </div>
        <div class="rstat-value">@Model.TotalApplications</div>
        <div class="rstat-label">Tổng hồ sơ ứng tuyển</div>
        <div class="rstat-sub">Trên tất cả các tin đăng</div>
    </div>
    <div class="rstat-card">
        <div class="rstat-top">
            <div class="rstat-icon" style="background:#fdf4ff;"><i class="fas fa-calendar-check" style="color:#a855f7;"></i></div>
            <span class="rstat-trend">+12%</span>
        </div>
        <div class="rstat-value">@Model.InterviewsScheduled</div>
        <div class="rstat-label">Lịch hẹn phỏng vấn</div>
        <div class="rstat-sub">Trong tuần này</div>
    </div>
    <div class="rstat-card">
        <div class="rstat-top">
            <div class="rstat-icon" style="background:#fff7ed;"><i class="fas fa-users" style="color:#f97316;"></i></div>
            <span class="rstat-trend">+10%</span>
        </div>
        <div class="rstat-value">@Model.FollowerCount</div>
        <div class="rstat-label">Người theo dõi</div>
        <div class="rstat-sub">Độ quan tâm công ty</div>
    </div>
</div>

<!-- Main grid: charts + sidebar -->
<div class="rdash-grid">

    <!-- LEFT COLUMN -->
    <div>
        <!-- Charts row -->
        <div class="rchart-row">
            <!-- Applications Overview - Bar -->
            <div class="rchart-card">
                <div class="rchart-card-header">
                    <div>
                        <div class="rchart-card-title">Tổng quan ứng tuyển</div>
                        <div class="rchart-card-sub">Số lượng ứng viên trong 7 ngày qua</div>
                    </div>
                    <button class="rchart-period-btn">7 Ngày qua</button>
                </div>
                <canvas id="appOverviewChart" height="150"></canvas>
            </div>

            <!-- Subscription card (Moved from sidebar) -->
            <div class="rsub-card" style="margin-bottom: 0;">
                <div class="rsub-header">
                    <span class="rsub-title">Gói dịch vụ hiện tại</span>
                    <span class="rsub-plan-badge">@Model.SubscriptionPlan</span>
                </div>
                <div class="rsub-valid">Hạn dùng đến @Model.SubscriptionValidTo</div>

                <div class="rsub-metric">
                    <div class="rsub-metric-label">
                        <span>Lượt đăng tin còn lại</span>
                        <span class="rsub-metric-val">@Model.JobPostsUsed / @Model.JobPostsTotal</span>
                    </div>
                    <div class="rsub-bar-bg">
                        <div class="rsub-bar-fill" style="width:@((Model.JobPostsTotal > 0) ? (int)((double)Model.JobPostsUsed/Model.JobPostsTotal*100) : 0)%;"></div>
                    </div>
                </div>

                <div class="rsub-metric">
                    <div class="rsub-metric-label">
                        <span>Lượt lọc AI CV còn lại</span>
                        <span class="rsub-metric-val">@Model.CvSearchesUsed / @Model.CvSearchesTotal</span>
                    </div>
                    <div class="rsub-bar-bg">
                        <div class="rsub-bar-fill" style="width:@((Model.CvSearchesTotal > 0) ? (int)((double)Model.CvSearchesUsed/Model.CvSearchesTotal*100) : 0)%;"></div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3 mt-4">
                    <a asp-controller="Subscription" asp-action="Index" class="btn-upgrade mb-0" style="margin-top: 0; flex: 1;">
                        Nâng cấp gói <i class="fas fa-arrow-trend-up ms-1"></i>
                    </a>
                    @if (Model.PlanPrice > 0)
                    {
                        <button class="btn btn-outline-light btn-sm" style="font-size: 0.8rem; border-color: rgba(255,255,255,0.3); height: 40px;">
                            <i class="fas fa-times-circle"></i> Hủy gói
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Applications -->
        <div class="rapp-card">
            <div class="rapp-header">
                <span class="rapp-title">Hồ sơ ứng tuyển gần đây</span>
                <a asp-action="Applications" class="rapp-viewall">Xem tất cả ứng tuyển</a>
            </div>
            <table class="rapp-table">
                <thead>
                    <tr>
                        <th>Tên ứng viên</th>
                        <th>Vị trí tuyển dụng</th>
                        <th>Ngày nộp</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model.RecentApplications)
                    {
                        <tr>
                            <td>
                                <div class="cand-cell">
                                    <div class="cand-avatar">@app.Initials</div>
                                    @app.CandidateName
                                </div>
                            </td>
                            <td>@app.JobTitle</td>
                            <td>@app.AppliedDate</td>
                            <td><span class="abadge @app.StatusClass">@app.Status</span></td>
                            <td>
                                <div class="rapp-action">
                                    <a asp-action="ViewCV" asp-route-id="@app.CvId" class="rapp-btn" target="_blank"><i class="fas fa-file-alt"></i> Xem CV</a>
                                    @if (userRole == "Employee")
                                    {
                                        <a asp-controller="Chat" asp-action="Index" class="rapp-btn"><i class="fas fa-comment"></i> Chat</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Recent Job Posts -->
        <div class="rapp-card">
            <div class="rapp-header">
                <span class="rapp-title">Bài đăng việc làm gần đây</span>
                <a asp-action="JobPostingList" class="rapp-viewall">Quản lý tất cả tin tuyển dụng</a>
            </div>
            <table class="rjob-table">
                <thead>
                    <tr>
                        <th>Tiêu đề công việc</th>
                        <th>Ngày đăng</th>
                        <th>Ngày hết hạn</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.RecentJobPosts)
                    {
                        <tr>
                            <td style="font-weight:600;color:#111827;">
                                <a asp-action="EditJob" asp-route-id="@job.Id" style="color: #111827; text-decoration: none;">@job.JobTitle</a>
                            </td>
                            <td>@job.PostedDate</td>
                            <td>@job.ExpiryDate</td>
                            <td><span class="jbadge @job.StatusClass">@job.Status</span></td>
                            <td>
                                <div class="rapp-action">
                                    <a asp-action="Applications" asp-route-jobId="@job.Id" class="rapp-btn">Ứng tuyển</a>
                                    <a asp-action="EditJob" asp-route-id="@job.Id" class="rapp-btn" title="Chỉnh sửa"><i class="fas fa-edit"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div><!-- /LEFT COLUMN -->

    </div><!-- /RIGHT SIDEBAR -->

</div><!-- /rdash-grid -->

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
    // ===== Applications Overview - Bar Chart =====
    new Chart(document.getElementById('appOverviewChart'), {
        type: 'bar',
        data: {
            labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
            datasets: [{
                label: 'Applications',
                data: [42, 47, 38, 63, 45, 28, 18],
                backgroundColor: '#00b14f',
                borderRadius: 5,
                borderSkipped: false,
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { font: { size: 10 } },
                    grid: { color: '#f3f4f6' }
                },
                x: {
                    ticks: { font: { size: 10 } },
                    grid: { display: false }
                }
            }
        }
    });

</script>
}
