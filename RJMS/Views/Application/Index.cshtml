@using System.Linq
@model IReadOnlyCollection<RJMS.Vn.Edu.Fpt.Model.DTOs.JobApplicationDTO>

@{
    ViewData["Title"] = "Việc làm đã ứng tuyển";
}

<div class="container py-4" style="max-width: 900px;">
    <h3 class="fw-bold mb-4">Việc làm đã ứng tuyển</h3>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-light text-center p-5 border rounded-3">
            <i class="fas fa-file-invoice mb-3" style="font-size: 3rem; color: #ccc;"></i>
            <h5 class="text-muted">Bạn chưa ứng tuyển công việc nào.</h5>
            <a href="/Job/Index" class="btn btn-primary mt-3">Tìm việc ngay</a>
        </div>
    }
    else
    {
        <div class="row gy-3">
            @foreach (var app in Model)
            {
                <div class="col-12">
                    <div class="card border border-light shadow-sm">
                        <div class="card-body d-flex flex-column flex-md-row align-items-md-center gap-3">
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(app.CompanyLogo))
                                {
                                    <img src="@app.CompanyLogo" alt="@app.CompanyName" class="rounded object-fit-cover border" style="width: 80px; height: 80px;" onerror="this.src='/images/default-company.png';"/>
                                }
                                else
                                {
                                    <div class="rounded border d-flex align-items-center justify-content-center bg-light" style="width: 80px; height: 80px;">
                                        <i class="fas fa-building text-secondary fs-3"></i>
                                    </div>
                                }
                            </div>
                            
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1">
                                    <a href="/Job/Detail/@app.JobId" class="text-decoration-none text-dark">
                                        @app.PositionTitle
                                    </a>
                                </h5>
                                <div class="text-muted mb-2">@app.CompanyName</div>
                                <div class="d-flex gap-3 text-secondary" style="font-size: 0.9rem;">
                                    <span>
                                        <i class="far fa-clock"></i> Đã ứng tuyển: @app.AppliedAt.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                    <span>
                                        @{
                                            string badgeClass = app.Status switch {
                                                "Đang xem xét" => "bg-warning text-dark",
                                                "Từ chối" => "bg-danger",
                                                "Chấp nhận" => "bg-success",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@app.Status</span>
                                    </span>
                                </div>
                            </div>
                            
                            <div class="mt-3 mt-md-0 ms-md-auto text-end">
                                <a href="/Chat/Start?jobId=@app.JobId&applicationId=@app.Id" class="btn btn-outline-primary w-100 w-md-auto">
                                    <i class="fas fa-comment-dots me-1"></i> Nhắn tin
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>