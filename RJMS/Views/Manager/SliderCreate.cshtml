@model RJMS.vn.edu.fpt.Models.DTOs.WebSliderFormViewModel
@{
    bool isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Chỉnh sửa Slider" : "Thêm Slider mới";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="sub-toolbar">
    <a asp-action="SliderList" class="btn btn-sm btn-outline-secondary">← Quay lại danh sách</a>
    <h2 class="page-title">@ViewData["Title"]</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="table-card p-4">
            <form asp-action="@(isEdit ? "SliderEdit" : "SliderCreate")" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề banner..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Subtitle" class="form-label fw-bold">Phụ đề</label>
                    <textarea asp-for="Subtitle" class="form-control" rows="2" placeholder="Mô tả ngắn gọn hiển thị trên banner..."></textarea>
                    <span asp-validation-for="Subtitle" class="text-danger small"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="ButtonText" class="form-label fw-bold">Text trên nút</label>
                        <input asp-for="ButtonText" class="form-control" placeholder="Ví dụ: Xem ngay, Khám phá..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LinkUrl" class="form-label fw-bold">Link liên kết</label>
                        <input asp-for="LinkUrl" class="form-control" placeholder="URL khi click vào slider..." />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Hình ảnh banner <span class="text-danger">*</span></label>
                    <div class="input-group mb-2">
                        <input type="file" asp-for="ImageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                    </div>
                    <div class="form-text">Kích thước khuyến nghị: 940x340px. Định dạng: JPG, PNG, WebP.</div>
                    
                    <div id="imagePreviewContainer" class="mt-3 @(string.IsNullOrEmpty(Model.ExistingImageUrl) ? "d-none" : "")">
                        <p class="small text-muted mb-1">Xem trước:</p>
                        <img id="imagePreview" src="@Model.ExistingImageUrl" class="rounded border shadow-sm" style="max-width: 100%; height: 200px; object-fit: cover;" />
                    </div>
                </div>

                <hr/>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="DisplayOrder" class="form-label fw-bold">Thứ tự hiển thị</label>
                        <input asp-for="DisplayOrder" type="number" class="form-control" />
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive">
                            <label class="form-check-label fw-bold" asp-for="IsActive">Hiển thị ngay</label>
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label fw-bold">Ngày bắt đầu</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label fw-bold">Ngày kết thúc</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fas fa-save me-1"></i> @(isEdit ? "Cập nhật" : "Lưu Slider")
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="table-card p-4 bg-light border-0">
            <h5 class="fw-bold mb-3"><i class="fas fa-info-circle text-primary me-2"></i>Hướng dẫn</h5>
            <ul class="small text-muted ps-3 mb-0">
                <li class="mb-2">Slider sẽ được hiển thị trên trang chủ theo thứ tự từ nhỏ đến lớn.</li>
                <li class="mb-2">Nếu đặt <strong>Ngày bắt đầu/kết thúc</strong>, slider sẽ chỉ hiển thị trong khoảng thời gian đó.</li>
                <li class="mb-2">Hệ thống sẽ tự động tắt slider nếu đã quá ngày kết thúc.</li>
                <li>Hãy sử dụng hình ảnh chất lượng cao để đảm bảo tính thẩm mỹ của website.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            const container = document.getElementById('imagePreviewContainer');
            const preview = document.getElementById('imagePreview');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    container.classList.remove('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
