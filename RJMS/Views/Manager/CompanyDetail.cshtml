@model RJMS.vn.edu.fpt.Models.DTOs.AdminCompanyDetailViewModel
@{
    ViewData["Title"] = $"Chi tiết công ty - {Model.Name}";
    ViewData["HidePageTitle"] = true;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
<style>
    .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .info-item label { display: block; font-weight: 600; color: #6b7280; font-size: 0.82rem; margin-bottom: 4px; }
    .info-item .val { font-size: 0.95rem; color: #111827; }
    .section-label { font-size: 0.9rem; font-weight: 700; color: #374151; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb; margin-bottom: 16px; }
    .badge-verified   { display:inline-block; padding:3px 12px; border-radius:20px; background:#dcfce7; color:#16a34a; font-size:0.78rem; font-weight:600; }
    .badge-unverified { display:inline-block; padding:3px 12px; border-radius:20px; background:#fee2e2; color:#991b1b; font-size:0.78rem; font-weight:600; }
    .list-row { padding: 10px 0; border-bottom: 1px solid #f3f4f6; font-size: 0.85rem; }
    .list-row:last-child { border-bottom: none; }
</style>
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="CompanyList" class="btn btn-sm btn-outline-secondary">← Quay lại danh sách</a>
    <h2 class="mb-0 fw-bold" style="font-size:1.4rem; color:#111827;">Chi tiết công ty</h2>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="admin-card">
            <div class="section-label">Thông tin công ty</div>
            <div class="info-grid">
                <div class="info-item"><label>Tên công ty</label><div class="val"><strong>@Model.Name</strong></div></div>
                <div class="info-item"><label>Mã số thuế</label><div class="val">@(Model.TaxCode ?? "—")</div></div>
                <div class="info-item"><label>Ngành nghề</label><div class="val">@(Model.Industry ?? "—")</div></div>
                <div class="info-item"><label>Quy mô</label><div class="val">@(Model.CompanySize ?? "—")</div></div>
                <div class="info-item">
                    <label>Website</label>
                    <div class="val">
                        @if (!string.IsNullOrEmpty(Model.Website)) { <a href="@Model.Website" target="_blank" style="color:#3b82f6;">@Model.Website</a> }
                        else { <span>—</span> }
                    </div>
                </div>
                <div class="info-item"><label>Email</label><div class="val">@(Model.Email ?? "—")</div></div>
                <div class="info-item"><label>Số điện thoại</label><div class="val">@(Model.Phone ?? "—")</div></div>
                <div class="info-item">
                    <label>Địa chỉ</label>
                    <div class="val">
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            @Model.Address
                            @if (!string.IsNullOrEmpty(Model.WardName)) { <text>, @Model.WardName</text> }
                            @if (!string.IsNullOrEmpty(Model.ProvinceName)) { <text>, @Model.ProvinceName</text> }
                        }
                        else { <span>—</span> }
                    </div>
                </div>
                <div class="info-item">
                    <label>Trạng thái xác minh</label>
                    <div class="val">
                        @if (Model.IsVerified)
                        {
                            <span class="badge-verified"><i class="fas fa-check-circle me-1"></i>Đã xác minh@(Model.VerifiedAt != null ? $" ({Model.VerifiedAt?.ToString("dd/MM/yyyy")})" : "")</span>
                        }
                        else
                        {
                            <span class="badge-unverified">Chưa xác minh</span>
                        }
                    </div>
                </div>
                <div class="info-item"><label>Ngày tạo</label><div class="val">@(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div></div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mt-3">
                    <label class="fw-bold" style="font-size:0.82rem;color:#6b7280;">Mô tả công ty</label>
                    <div class="mt-1" style="color:#374151;font-size:0.9rem;">@Model.Description</div>
                </div>
            }

            <div class="mt-3 d-flex gap-2">
                @if (Model.IsVerified)
                {
                    <form method="post" asp-action="UnverifyCompany" asp-route-id="@Model.Id" onsubmit="return confirm('Bạn có chắc muốn hủy xác minh công ty này?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm px-4">Hủy xác minh</button>
                    </form>
                }
                else
                {
                    <form method="post" asp-action="VerifyCompany" asp-route-id="@Model.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-sm px-4">Xác minh công ty</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="admin-card">
            <div class="section-label">Nhà tuyển dụng (@Model.Recruiters.Count)</div>
            @if (Model.Recruiters.Any())
            {
                @foreach (var rec in Model.Recruiters)
                {
                    <div class="list-row">
                        <div class="fw-bold">@rec.FullName <span class="text-muted fw-normal">— @(rec.Position ?? "N/A")</span></div>
                        <div class="text-muted mt-1">
                            @rec.Email · @(rec.Phone ?? "N/A") ·
                            @if (rec.IsVerified) { <span style="color:#16a34a;">Đã xác minh</span> }
                            else { <span style="color:#ef4444;">Chưa xác minh</span> }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4 text-muted small">Chưa có nhà tuyển dụng nào</div>
            }
        </div>
    </div>

    <div class="col-md-6">
        <div class="admin-card">
            <div class="section-label">Tin tuyển dụng (@Model.Jobs.Count)</div>
            @if (Model.Jobs.Any())
            {
                @foreach (var job in Model.Jobs)
                {
                    <div class="list-row">
                        <div class="fw-bold">@job.Title</div>
                        <div class="text-muted mt-1">Lương: @(job.Salary ?? "Thỏa thuận") · Ngày đăng: @(job.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")</div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4 text-muted small">Chưa có tin tuyển dụng nào</div>
            }
        </div>
    </div>
</div>
