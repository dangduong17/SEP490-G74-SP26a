@model RJMS.vn.edu.fpt.Models.DTOs.AdminSkillListViewModel
@{
    ViewData["Title"] = "Quản lý kỹ năng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["HidePageTitle"] = true;
}

<style>
    .category-badge {
        padding: 0.25rem 0.75rem;
        background: #dbeafe;
        color: #1e40af;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 500;
    }
</style>

<div class="sub-toolbar">
    <h1>Quản lý kỹ năng</h1>
    <a asp-action="CreateSkill" class="btn-create">
        Thêm kỹ năng mới
    </a>
</div>

<form method="get" asp-action="SkillList">
    <div class="sub-filterbar">
        <div class="sub-search">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tìm kiếm kỹ năng..." />
        </div>
        
        <span class="filter-label">Danh mục:</span>
        <select name="category" class="form-select" style="width:200px;">
            <option value="">-- Tất cả danh mục --</option>
            @foreach (var cat in Model.Categories)
            {
                <option value="@cat" selected="@(cat == Model.Category)">@cat</option>
            }
        </select>
        <button type="submit" class="btn-filter-icon" title="Lọc">
            Lọc
        </button>
    </div>
</form>

<div class="sub-table-card">
    <table class="sub-table">
        <thead>
            <tr>
                <th>Tên kỹ năng</th>
                <th>Danh mục</th>
                <th>Số công việc</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Skills.Any())
            {
                <tr><td colspan="4" style="text-align:center; padding: 3rem; color: #9ca3af;">Không có dữ liệu</td></tr>
            }
            @foreach (var skill in Model.Skills)
            {
                <tr>
                    <td><strong>@skill.Name</strong></td>
                    <td>
                        @if (!string.IsNullOrEmpty(skill.Category))
                        {
                            <span class="category-badge">@skill.Category</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td>@skill.JobCount</td>
                    <td style="text-align:right;">
                        <div class="action-btns">
                            <a asp-action="EditSkill" asp-route-id="@skill.Id" class="act-btn act-edit" title="Sửa">
                                Sửa
                            </a>
                            <form method="post" asp-action="DeleteSkill" asp-route-id="@skill.Id" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa kỹ năng này?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="act-btn act-delete" title="Xóa">
                                    Xóa
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="sub-pagination">
            <span>
                Hiển thị <strong>@((Model.Page-1)*Model.PageSize+1)–@Math.Min(Model.Page*Model.PageSize,Model.TotalItems)</strong> 
                trong tổng số <strong>@Model.TotalItems</strong> kỹ năng
            </span>
            <div style="display:flex;gap:6px;align-items:center;">
                @if (Model.Page > 1)
                {
                    <a class="pg-btn-text" asp-action="SkillList" asp-route-keyword="@Model.Keyword" asp-route-category="@Model.Category" asp-route-page="@(Model.Page-1)" asp-route-pageSize="@Model.PageSize">Trước</a>
                }
                else
                {
                    <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Trước</span>
                }
                
                @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                {
                    <a class="pg-btn @(i == Model.Page ? "active" : "")" asp-action="SkillList" asp-route-keyword="@Model.Keyword" asp-route-category="@Model.Category" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                }
                
                @if (Model.Page < Model.TotalPages)
                {
                    <a class="pg-btn-text" asp-action="SkillList" asp-route-keyword="@Model.Keyword" asp-route-category="@Model.Category" asp-route-page="@(Model.Page+1)" asp-route-pageSize="@Model.PageSize">Sau</a>
                }
                else
                {
                    <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Sau</span>
                }
            </div>
        </div>
    }
</div>
