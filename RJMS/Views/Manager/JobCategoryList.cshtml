@model RJMS.vn.edu.fpt.Models.DTOs.JobCategoryListViewModel
@{
    ViewData["Title"] = "Danh mục nghề nghiệp";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["HidePageTitle"] = true;
}

<div class="sub-toolbar">
    <h1>Danh mục nghề nghiệp</h1>
    <a asp-action="CreateJobCategory" class="btn-create">Thêm mới</a>
</div>

<form method="get" asp-action="JobCategoryList">
    <div class="sub-filterbar">
        <div class="sub-search">
            <input type="text" name="keyword" placeholder="Tìm tên danh mục..." value="@Model.Keyword" />
        </div>
        
        <span class="filter-label">Cấp độ:</span>
    <select name="filterLevel" class="form-select" style="width:220px;">
        <option value="">-- Tất cả các cấp --</option>
        @if (Model.FilterLevel == 1) { <option value="1" selected>Nhóm nghề (Cấp 1)</option> } else { <option value="1">Nhóm nghề (Cấp 1)</option> }
        @if (Model.FilterLevel == 2) { <option value="2" selected>Nghề nghiệp (Cấp 2)</option> } else { <option value="2">Nghề nghiệp (Cấp 2)</option> }
        @if (Model.FilterLevel == 3) { <option value="3" selected>Vị trí chuyên môn (Cấp 3)</option> } else { <option value="3">Vị trí chuyên môn (Cấp 3)</option> }
    </select>
    
    <button type="submit" class="btn-filter-icon" title="Lọc">Lọc</button>
    
    @if (!string.IsNullOrEmpty(Model.Keyword) || Model.FilterLevel.HasValue)
    {
        <a asp-action="JobCategoryList" class="btn btn-sm btn-link text-decoration-none ms-2">Xóa lọc</a>
    }
    </div>
</form>

<div class="sub-table-card">
    <table class="sub-table">
        <thead>
            <tr>
                <th style="width: 50px;">ID</th>
                <th>Tên danh mục</th>
                <th>Cấp độ</th>
                <th>Danh mục cha</th>
                <th>Mô tả</th>
                <th>Số mục con</th>
                <th style="text-align:right; width: 150px;">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Categories.Any())
            {
                foreach (var cat in Model.Categories)
                {
                    <tr>
                        <td>@cat.Id</td>
                        <td class="fw-bold text-success">@cat.Name</td>
                        <td>
                            @if (cat.Level == 1)
                            {
                                <span class="badge bg-primary bg-opacity-10 text-primary">Nhóm nghề (Cấp 1)</span>
                            }
                            else if (cat.Level == 2)
                            {
                                <span class="badge bg-info bg-opacity-10 text-info">Nghề nghiệp (Cấp 2)</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary">Vị trí (Cấp 3)</span>
                            }
                        </td>
                        <td>@(cat.ParentName ?? "-")</td>
                        <td class="text-muted small text-truncate" style="max-width: 200px;">
                            @cat.Description
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border">@cat.ChildrenCount</span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a asp-action="EditJobCategory" asp-route-id="@cat.Id" class="act-btn act-edit" title="Sửa">
                                    Sửa
                                </a>
                                <form asp-action="DeleteJobCategory" asp-route-id="@cat.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa danh mục này?');">
                                    <button type="submit" class="act-btn act-delete" title="Xóa">
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        <i class="fas fa-folder-open fs-4 text-light-gray mb-2 d-block"></i>
                        Không tìm thấy danh mục nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="sub-pagination">
            <span>
                Trang <strong>@Model.CurrentPage/@Model.TotalPages</strong> 
                trong tổng số <strong>@Model.TotalItems</strong> danh mục
            </span>
            <div style="display:flex;gap:6px;align-items:center;">
                @if (Model.CurrentPage > 1)
                {
                    <a class="pg-btn-text" asp-action="JobCategoryList" asp-route-page="@(Model.CurrentPage - 1)" asp-route-keyword="@Model.Keyword" asp-route-filterLevel="@Model.FilterLevel">Trước</a>
                }
                else
                {
                    <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Trước</span>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a class="pg-btn @(i == Model.CurrentPage ? "active" : "")" asp-action="JobCategoryList" asp-route-page="@i" asp-route-keyword="@Model.Keyword" asp-route-filterLevel="@Model.FilterLevel">@i</a>
                }
                
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a class="pg-btn-text" asp-action="JobCategoryList" asp-route-page="@(Model.CurrentPage + 1)" asp-route-keyword="@Model.Keyword" asp-route-filterLevel="@Model.FilterLevel">Sau</a>
                }
                else
                {
                    <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Sau</span>
                }
            </div>
        </div>
    }
</div>
