@model RJMS.vn.edu.fpt.Models.DTOs.CreateJobCategoryModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var possibleParents = ViewBag.PossibleParents as List<RJMS.vn.edu.fpt.Models.DTOs.JobCategoryViewModel>;
}

<div class="card border-0 shadow-sm" style="max-width: 600px; margin: 0 auto;">
    <div class="card-body p-4">
        <form asp-action="CreateJobCategory" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Level" class="form-label fw-bold">Cấp độ danh mục <span class="text-danger">*</span></label>
                <select asp-for="Level" class="form-select" id="levelSelect" onchange="window.location.href='?level=' + this.value;">
                    @if (Model.Level == 1) { <option value="1" selected>Nhóm nghề (Cấp 1 - Cao nhất)</option> } else { <option value="1">Nhóm nghề (Cấp 1 - Cao nhất)</option> }
                    @if (Model.Level == 2) { <option value="2" selected>Nghề nghiệp (Cấp 2)</option> } else { <option value="2">Nghề nghiệp (Cấp 2)</option> }
                    @if (Model.Level == 3) { <option value="3" selected>Vị trí chuyên môn (Cấp 3)</option> } else { <option value="3">Vị trí chuyên môn (Cấp 3)</option> }
                </select>
            </div>

            @if (Model.Level > 1)
            {
                <div class="mb-3">
                    <label asp-for="ParentId" class="form-label fw-bold">Danh mục cha (Cấp @(Model.Level - 1)) <span class="text-danger">*</span></label>
                    <select asp-for="ParentId" class="form-select" required>
                        <option value="">-- Chọn danh mục cha --</option>
                        @if (possibleParents != null)
                        {
                            foreach(var p in possibleParents)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger small"></span>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả ngắn gọn..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="JobCategoryList" class="btn btn-outline-secondary w-50">Hủy bỏ</a>
                <button type="submit" class="btn btn-success w-50" style="background-color: #00b14f; border-color: #00b14f;">
                    <i class="fas fa-save me-1"></i> Lưu danh mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
