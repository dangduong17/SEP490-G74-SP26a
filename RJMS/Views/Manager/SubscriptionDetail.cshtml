@model RJMS.vn.edu.fpt.Models.DTOs.AdminSubscriptionDetailViewModel
@{
    ViewData["Title"] = $"Chi tiết gói dịch vụ - {Model.UserName}";
    ViewData["HidePageTitle"] = true;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
<style>
    .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
    .info-item label { display: block; font-weight: 600; color: #6b7280; font-size: 0.82rem; margin-bottom: 4px; }
    .info-item .val { font-size: 0.95rem; color: #111827; }
    .section-label { font-size: 0.9rem; font-weight: 700; color: #374151; padding-bottom: 8px; border-bottom: 1px solid #e5e7eb; margin-bottom: 16px; }
    .badge-active   { display:inline-block; padding:3px 12px; border-radius:20px; background:#dcfce7; color:#16a34a; font-size:0.78rem; font-weight:600; }
    .badge-expired  { display:inline-block; padding:3px 12px; border-radius:20px; background:#fee2e2; color:#991b1b; font-size:0.78rem; font-weight:600; }
    .badge-cancelled{ display:inline-block; padding:3px 12px; border-radius:20px; background:#f3f4f6; color:#4b5563; font-size:0.78rem; font-weight:600; }
    .badge-pending  { display:inline-block; padding:3px 12px; border-radius:20px; background:#fef9c3; color:#92400e; font-size:0.78rem; font-weight:600; }
    .badge-success  { display:inline-block; padding:3px 12px; border-radius:20px; background:#dcfce7; color:#16a34a; font-size:0.78rem; font-weight:600; }
    .badge-failed   { display:inline-block; padding:3px 12px; border-radius:20px; background:#fee2e2; color:#991b1b; font-size:0.78rem; font-weight:600; }
    .detail-table { width:100%; border-collapse:collapse; font-size:0.85rem; }
    .detail-table th { padding:8px 10px; background:#f9fafb; font-weight:600; color:#6b7280; border-bottom:2px solid #e5e7eb; text-align:left; font-size:0.78rem; }
    .detail-table td { padding:10px; border-bottom:1px solid #f3f4f6; color:#374151; vertical-align:middle; }
    .detail-table tr:last-child td { border-bottom:none; }
</style>
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="SubscriptionList" class="btn btn-sm btn-outline-secondary">← Quay lại danh sách</a>
    <h2 class="mb-0 fw-bold" style="font-size:1.4rem; color:#111827;">Chi tiết gói dịch vụ</h2>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="admin-card">
            <div class="section-label">Thông tin người dùng</div>
            <div class="info-grid">
                <div class="info-item"><label>Tên người dùng</label><div class="val"><strong>@Model.UserName</strong></div></div>
                <div class="info-item"><label>Email</label><div class="val">@Model.UserEmail</div></div>
                <div class="info-item"><label>User ID</label><div class="val">@Model.UserId</div></div>
                <div class="info-item"><label>Vai trò</label><div class="val">@Model.UserRole</div></div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="admin-card">
            <div class="section-label">Thông tin gói dịch vụ</div>
            <div class="info-grid">
                <div class="info-item"><label>Tên gói</label><div class="val"><strong>@Model.PlanName</strong></div></div>
                <div class="info-item"><label>Giá</label><div class="val fw-bold" style="color:#10b981;font-size:1.1rem;">@Model.PlanPrice.ToString("N0") VNĐ</div></div>
                <div class="info-item"><label>Thời hạn</label><div class="val">@Model.PlanDurationDays ngày</div></div>
                <div class="info-item"><label>Ngày đăng ký</label><div class="val">@(Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div></div>
                <div class="info-item"><label>Ngày bắt đầu</label><div class="val">@(Model.StartDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div></div>
                <div class="info-item"><label>Ngày kết thúc</label><div class="val">@(Model.EndDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div></div>
                <div class="info-item">
                    <label>Trạng thái</label>
                    <div class="val">
                        @{ var st = Model.Status?.ToUpper(); }
                        @if (st == "ACTIVE") { <span class="badge-active">Đang hoạt động</span> }
                        else if (st == "EXPIRED") { <span class="badge-expired">Hết hạn</span> }
                        else if (st == "CANCELLED") { <span class="badge-cancelled">Đã hủy</span> }
                        else if (st == "PENDING") { <span class="badge-pending">Chờ xác nhận</span> }
                        else { <span class="badge-cancelled">@Model.Status</span> }
                    </div>
                </div>
                <div class="info-item">
                    <label>Tự động gia hạn</label>
                    <div class="val">@(Model.AutoRenew ? "Có" : "Không")</div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.PlanDescription))
            {
                <div class="mt-3">
                    <label class="fw-bold" style="font-size:0.82rem;color:#6b7280;">Mô tả gói</label>
                    <div class="mt-1" style="color:#374151;font-size:0.9rem;">@Model.PlanDescription</div>
                </div>
            }
        </div>
    </div>

    <div class="col-12">
        <div class="admin-card">
            <div class="section-label">Lịch sử thanh toán (@Model.Payments.Count)</div>
            @if (Model.Payments.Any())
            {
                <table class="detail-table">
                    <thead>
                        <tr>
                            <th>Ngày thanh toán</th>
                            <th>Số tiền</th>
                            <th>Mã giao dịch</th>
                            <th>Phương thức</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Payments)
                        {
                            <tr>
                                <td>@(payment.PaymentDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td class="fw-bold" style="color:#10b981;">@payment.Amount.ToString("N0") VNĐ</td>
                                <td><code>@(payment.TransactionId ?? "—")</code></td>
                                <td>@(payment.PaymentMethod ?? "—")</td>
                                <td>
                                    @{ var ps = payment.Status?.ToUpper(); }
                                    @if (ps == "SUCCESS") { <span class="badge-success">Thành công</span> }
                                    else if (ps == "PENDING") { <span class="badge-pending">Chờ xác nhận</span> }
                                    else if (ps == "FAILED") { <span class="badge-failed">Thất bại</span> }
                                    else { <span class="badge-cancelled">@payment.Status</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-4 text-muted small">Chưa có lịch sử thanh toán</div>
            }
        </div>
    </div>
</div>
