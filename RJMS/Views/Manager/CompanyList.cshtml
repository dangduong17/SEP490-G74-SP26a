@model RJMS.vn.edu.fpt.Models.DTOs.AdminCompanyListViewModel
@{
    ViewData["Title"] = "Quản lý công ty";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["HidePageTitle"] = true;
}

<style>
    .verified-badge {
        padding: 0.25rem 0.75rem;
        background: #d1fae5;
        color: #065f46;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 500;
    }
    .unverified-badge {
        padding: 0.25rem 0.75rem;
        background: #fee2e2;
        color: #991b1b;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 500;
    }
</style>

<div class="sub-toolbar">
    <h1>Quản lý công ty</h1>
</div>

<form method="get" asp-action="CompanyList">
    <div class="sub-filterbar">
        <div class="sub-search">
            <input type="text" name="keyword" value="@Model.Keyword" placeholder="Tìm theo tên, mã số thuế, email..." />
        </div>
        
        <div class="sub-search" style="max-width:200px;">
            <input type="text" name="industry" value="@Model.Industry" placeholder="Ngành nghề..." />
        </div>
        
        <span class="filter-label">Trạng thái:</span>
        <select name="verificationStatus" class="form-select">
            <option value="">-- Trạng thái xác minh --</option>
            <option value="verified" selected="@(Model.VerificationStatus == "verified")">Đã xác minh</option>
            <option value="unverified" selected="@(Model.VerificationStatus == "unverified")">Chưa xác minh</option>
        </select>
        <button type="submit" class="btn-filter-icon" title="Lọc">
            Lọc
        </button>
    </div>
</form>

<div class="sub-table-card">
    <table class="sub-table">
        <thead>
            <tr>
                <th>Tên công ty</th>
                <th>Mã số thuế</th>
                <th>Ngành nghề</th>
                <th>Số nhân viên</th>
                <th>Recruiter</th>
                <th>Công việc</th>
                <th>Số Follower</th>
                <th>Trạng thái</th>
                <th>Ngày tạo</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Companies.Any())
            {
                <tr><td colspan="9" style="text-align:center; padding: 3rem; color: #9ca3af;">Không có dữ liệu</td></tr>
            }
            @foreach (var company in Model.Companies)
            {
                <tr>
                    <td><strong>@company.Name</strong></td>
                    <td>@(company.TaxCode ?? "—")</td>
                    <td>@(company.Industry ?? "—")</td>
                    <td>@(company.CompanySize ?? "—")</td>
                    <td>@company.RecruiterCount</td>
                    <td>@company.JobCount</td>
                    <td style="font-weight:600; color:#00b14f;">@company.FollowerCount</td>
                    <td>
                        @if (company.IsVerified)
                        {
                            <span class="verified-badge">Đã xác minh</span>
                        }
                        else
                        {
                            <span class="unverified-badge">Chưa xác minh</span>
                        }
                    </td>
                    <td style="font-size:0.85rem; color:#6b7280;">
                        @(company.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")
                    </td>
                    <td>
                        <div class="action-btns">
                            <a asp-action="CompanyDetail" asp-route-id="@company.Id" class="act-btn act-view" title="Xem chi tiết">
                                Xem
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="sub-pagination">
            <span>
                Hiển thị <strong>@((Model.Page-1)*Model.PageSize+1)–@Math.Min(Model.Page*Model.PageSize,Model.TotalItems)</strong> 
                trong tổng số <strong>@Model.TotalItems</strong> công ty
            </span>
            <div style="display:flex;gap:6px;align-items:center;">
                @if (Model.Page > 1)
                {
                    <a class="pg-btn-text" asp-action="CompanyList" 
                       asp-route-keyword="@Model.Keyword" 
                       asp-route-industry="@Model.Industry" 
                       asp-route-verificationStatus="@Model.VerificationStatus"
                       asp-route-page="@(Model.Page-1)" 
                       asp-route-pageSize="@Model.PageSize">Trước</a>
                }
                else
                {
                    <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Trước</span>
                }

                @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                {
                    <a class="pg-btn @(i == Model.Page ? "active" : "")" 
                       asp-action="CompanyList" 
                       asp-route-keyword="@Model.Keyword" 
                       asp-route-industry="@Model.Industry" 
                       asp-route-verificationStatus="@Model.VerificationStatus"
                       asp-route-page="@i" 
                       asp-route-pageSize="@Model.PageSize">@i</a>
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <a class="pg-btn-text" asp-action="CompanyList" 
                       asp-route-keyword="@Model.Keyword" 
                       asp-route-industry="@Model.Industry" 
                       asp-route-verificationStatus="@Model.VerificationStatus"
                       asp-route-page="@(Model.Page+1)" 
                       asp-route-pageSize="@Model.PageSize">Sau</a>
                }
                else
                {
                    <span class="pg-btn-text" style="opacity:.4;cursor:not-allowed;">Sau</span>
                }
            </div>
        </div>
    }
</div>
