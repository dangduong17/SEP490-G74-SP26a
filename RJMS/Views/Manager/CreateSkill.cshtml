@model RJMS.vn.edu.fpt.Models.DTOs.AdminCreateSkillViewModel
@{
    ViewData["Title"] = "Thêm kỹ năng mới";
    ViewData["HidePageTitle"] = true;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="SkillList" class="btn btn-sm btn-outline-secondary">← Quay lại danh sách</a>
    <h2 class="mb-0 fw-bold" style="font-size:1.4rem; color:#111827;">@ViewData["Title"]</h2>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="admin-card">
            <form method="post" asp-action="CreateSkill">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên kỹ năng <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="VD: C#, Java, React, SQL..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Category" class="form-label fw-bold">Danh mục</label>
                    <input asp-for="Category" class="form-control" placeholder="VD: Lập trình, Thiết kế, Quản lý..." />
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="SkillList" class="btn btn-outline-secondary me-2">Huỷ</a>
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fas fa-save me-1"></i> Lưu kỹ năng
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
