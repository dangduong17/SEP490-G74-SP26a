@using System.Text.Json
@using RJMS.vn.edu.fpt.Models.DTOs
@model ManagerDashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển quản lý";
    ViewData["HidePageTitle"] = true;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var defaultPeriod = 7;
    var defaultData = Model.Periods.ContainsKey(defaultPeriod)
        ? Model.Periods[defaultPeriod]
        : new ManagerPeriodData();
    var periodDataJson = JsonSerializer.Serialize(
        Model.Periods,
        new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}

@section Styles {
    <style>
        .admin-card {
            background: transparent;
            border: none;
            padding: 0;
        }

        .dash-toolbar {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .dash-toolbar-title {
            flex: 1 1 auto;
        }

        .dash-toolbar-title h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #111827;
            margin: 0 0 2px;
        }

        .dash-toolbar-title p {
            font-size: 0.82rem;
            color: #6b7280;
            margin: 0;
        }

        .dash-period-btn {
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #374151;
            font-size: 0.82rem;
            padding: 6px 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.15s;
        }

        .dash-period-btn:hover,
        .dash-period-btn.active {
            background: #00b14f;
            color: #fff;
            border-color: #00b14f;
        }

        .dash-filter-bar {
            display: flex;
            align-items: flex-end;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 14px 18px;
        }

        .dash-filter-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .dash-filter-group label {
            font-size: 0.75rem;
            font-weight: 600;
            color: #6b7280;
        }

        .dash-filter-group select,
        .dash-filter-group input[type=month] {
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 5px 10px;
            font-size: 0.83rem;
            color: #374151;
            background: #fff;
            height: 34px;
        }

        .dash-filter-sep {
            font-size: 0.82rem;
            color: #9ca3af;
            padding-bottom: 6px;
        }

        .stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 18px 20px;
            display: flex;
            align-items: flex-start;
            gap: 14px;
            transition: box-shadow 0.2s;
        }

        .stat-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .stat-info .label {
            font-size: 0.78rem;
            color: #6b7280;
            margin-bottom: 4px;
        }

        .stat-info .value {
            font-size: 1.55rem;
            font-weight: 700;
            color: #111827;
            line-height: 1;
            margin-bottom: 0;
        }

        .chart-row {
            display: grid;
            gap: 16px;
            margin-bottom: 20px;
        }

        .chart-row-2 {
            grid-template-columns: 3fr 2fr;
        }

        .chart-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 20px;
        }

        .chart-card-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: #111827;
            margin-bottom: 2px;
        }

        .chart-card-sub {
            font-size: 0.75rem;
            color: #6b7280;
            margin-bottom: 14px;
        }

        .activity-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.82rem;
        }

        .activity-table th {
            font-weight: 600;
            color: #6b7280;
            padding: 8px 10px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            font-size: 0.78rem;
        }

        .activity-table td {
            padding: 10px 10px;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            vertical-align: middle;
        }

        .activity-table tr:last-child td { border-bottom: none; }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
        }

        .status-active   { background: #dcfce7; color: #16a34a; }
        .status-success  { background: #dbeafe; color: #1d4ed8; }
        .status-pending  { background: #fef9c3; color: #92400e; }

        .alert-section .alert-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 8px;
            font-size: 0.84rem;
            font-weight: 500;
        }

        .alert-item.danger  { background: #fef2f2; color: #991b1b; border-left: 4px solid #ef4444; }
        .alert-item.warning { background: #fffbeb; color: #92400e; border-left: 4px solid #f59e0b; }
        .alert-item.success { background: #f0fdf4; color: #166534; border-left: 4px solid #22c55e; }

        @@media (max-width: 1100px) {
            .stat-grid { grid-template-columns: repeat(2, 1fr); }
            .chart-row-2 { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="dash-toolbar">
    <div class="dash-toolbar-title">
        <h2>Bảng điều khiển quản lý</h2>
        <p>Tổng quan hoạt động hệ thống và doanh thu.</p>
    </div>
    <button class="dash-period-btn active" onclick="setPeriod(this,7)">7 ngày</button>
    <button class="dash-period-btn" onclick="setPeriod(this,30)">30 ngày</button>
    <button class="dash-period-btn" onclick="setPeriod(this,90)">90 ngày</button>
</div>

<div class="dash-filter-bar">
    <div class="dash-filter-group">
        <label>Tháng</label>
        <select id="filterMonth">
            <option value="">-- Tháng --</option>
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m">Tháng @m</option>
            }
        </select>
    </div>
    <div class="dash-filter-group">
        <label>Năm</label>
        <select id="filterYear">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--)
            {
                <option value="@y">@y</option>
            }
        </select>
    </div>
    <button class="dash-period-btn" onclick="applyMonthFilter()" style="align-self:flex-end;">Xem theo tháng</button>

    <div class="dash-filter-sep" style="margin: 0 6px;">|</div>

    <div class="dash-filter-group">
        <label>Từ tháng</label>
        <input type="month" id="filterFrom" />
    </div>
    <div class="dash-filter-sep" style="align-self:flex-end;padding-bottom:8px;">→</div>
    <div class="dash-filter-group">
        <label>Đến tháng</label>
        <input type="month" id="filterTo" />
    </div>
    <button class="dash-period-btn" onclick="applyRangeFilter()" style="align-self:flex-end;">Xem khoảng</button>
    <span id="filterLabel" style="align-self:flex-end;font-size:0.78rem;color:#6b7280;padding-bottom:6px;"></span>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-icon" style="background:#ecfdf5;">
            <i class="fas fa-chart-line" style="color:#00b14f;"></i>
        </div>
        <div class="stat-info">
            <div class="label">Doanh thu</div>
            <div class="value" id="statRevenue">@string.Format("{0:N0} đ", defaultData.TotalRevenue)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#eff6ff;">
            <i class="fas fa-briefcase" style="color:#3b82f6;"></i>
        </div>
        <div class="stat-info">
            <div class="label">Tin tuyển dụng</div>
            <div class="value" id="statJobPosts">@defaultData.TotalJobPosts</div>
        </div>
    </div>
</div>

<div class="chart-row chart-row-2">
    <div class="chart-card">
        <div class="chart-card-title">Doanh thu</div>
        <div class="chart-card-sub">Theo thời gian</div>
        <canvas id="revenueChart" height="110"></canvas>
    </div>
    <div class="chart-card">
        <div class="chart-card-title">Bài đăng tuyển dụng</div>
        <div class="chart-card-sub">Theo thời gian</div>
        <canvas id="jobPostChart" height="110"></canvas>
    </div>
</div>

<div class="chart-row">
    <div class="chart-card">
        <div class="chart-card-title">Doanh thu theo gói</div>
        <div class="chart-card-sub">Tỷ trọng theo kỳ đã chọn</div>
        <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;">
            <canvas id="revenueDonut" width="200" height="200" style="max-width:200px;max-height:200px;"></canvas>
            <div id="donutLegend" style="font-size:0.8rem;line-height:2;"></div>
        </div>
    </div>
</div>

<div class="chart-card mb-4">
    <div class="chart-card-title mb-3">Hoạt động gần đây</div>
    <table class="activity-table">
        <thead>
            <tr>
                <th>Thời gian</th>
                <th>Loại sự kiện</th>
                <th>Người dùng / Công ty</th>
                <th>Chi tiết</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RecentActivities.Count == 0)
            {
                <tr>
                    <td colspan="5">Chưa có dữ liệu.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.RecentActivities)
                {
                    <tr>
                        <td>@item.TimeLabel</td>
                        <td>@item.Type</td>
                        <td>@item.Actor</td>
                        <td>@item.Detail</td>
                        <td><span class="status-badge @item.StatusClass">@item.StatusLabel</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="chart-card alert-section mb-2">
    <div class="chart-card-title mb-3">Cảnh báo</div>
    @if (Model.Alerts.Count == 0)
    {
        <div class="alert-item success">
            <i class="fas fa-check-circle"></i>
            Không có cảnh báo mới.
        </div>
    }
    else
    {
        foreach (var alert in Model.Alerts)
        {
            <div class="alert-item @alert.Style">
                <i class="fas fa-exclamation-triangle"></i>
                @alert.Message
            </div>
        }
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script>
        const periodData = @Html.Raw(periodDataJson);
        const defaultPeriod = @defaultPeriod;

        function getPeriod(days) {
            return periodData[days] || periodData[String(days)] || {};
        }

        function formatCurrency(value) {
            return new Intl.NumberFormat('vi-VN').format(value || 0) + ' đ';
        }

        function normalizeSeries(labels, values) {
            if (!labels || labels.length === 0) {
                return { labels: ['Chưa có dữ liệu'], values: [0] };
            }
            return { labels, values };
        }

        function buildRevenueDatasets(series) {
            const colors = ['#22c55e', '#3b82f6', '#a855f7', '#f59e0b', '#0ea5e9'];
            if (!series || series.length === 0) {
                return [{ label: 'Chưa có dữ liệu', data: [0], borderColor: colors[0], backgroundColor: 'rgba(34,197,94,0.07)', tension: 0.4, borderWidth: 2, pointRadius: 3, fill: false }];
            }
            return series.map((item, idx) => ({
                label: item.label,
                data: item.values,
                borderColor: colors[idx % colors.length],
                backgroundColor: 'rgba(34,197,94,0.07)',
                tension: 0.4,
                borderWidth: 2,
                pointRadius: 3,
                fill: false
            }));
        }

        function toDonutData(items) {
            if (!items || items.length === 0) {
                return { labels: ['Chưa có dữ liệu'], values: [0] };
            }
            return {
                labels: items.map(x => x.label),
                values: items.map(x => x.value)
            };
        }

        const initial = getPeriod(defaultPeriod);
        const initialJobPosts = normalizeSeries(initial.labels, initial.jobPostCounts || []);
        const initialDonut = toDonutData(initial.revenueByPlan || []);

        const revenueChart = new Chart(document.getElementById('revenueChart'), {
            type: 'line',
            data: {
                labels: initial.labels || initialJobPosts.labels,
                datasets: buildRevenueDatasets(initial.revenueSeries)
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'top', labels: { font: { size: 11 }, boxWidth: 16 } } },
                scales: {
                    y: {
                        ticks: { font: { size: 10 }, callback: v => new Intl.NumberFormat('vi-VN').format(v) },
                        grid: { color: '#f3f4f6' }
                    },
                    x: { ticks: { font: { size: 10 } }, grid: { display: false } }
                }
            }
        });

        const jobPostChart = new Chart(document.getElementById('jobPostChart'), {
            type: 'bar',
            data: {
                labels: initialJobPosts.labels,
                datasets: [{
                    label: 'Bài đăng',
                    data: initialJobPosts.values,
                    backgroundColor: '#10b981',
                    borderRadius: 4,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { ticks: { font: { size: 10 } }, grid: { color: '#f3f4f6' } },
                    x: { ticks: { font: { size: 10 } }, grid: { display: false } }
                }
            }
        });

        const donutColors = ['#3b82f6', '#a855f7', '#22c55e', '#f59e0b', '#0ea5e9'];
        const revenueDonut = new Chart(document.getElementById('revenueDonut'), {
            type: 'doughnut',
            data: {
                labels: initialDonut.labels,
                datasets: [{
                    data: initialDonut.values,
                    backgroundColor: donutColors,
                    borderWidth: 3,
                    borderColor: '#fff',
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: false,
                cutout: '60%',
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => ctx.label + ': ' + formatCurrency(ctx.parsed) } }
                }
            }
        });

        function renderDonutLegend(labels, values) {
            const legend = document.getElementById('donutLegend');
            legend.innerHTML = '';
            labels.forEach((item, i) => {
                const div = document.createElement('div');
                div.style.display = 'flex';
                div.style.alignItems = 'center';
                div.style.gap = '8px';
                div.innerHTML = `<span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:${donutColors[i % donutColors.length]};"></span> ${item} - ${formatCurrency(values[i])}`;
                legend.appendChild(div);
            });
        }

        renderDonutLegend(initialDonut.labels, initialDonut.values);

        function setPeriod(btn, days) {
            const data = getPeriod(days);
            document.querySelectorAll('.dash-period-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('filterLabel').textContent = '';
            applyData(data);
        }

        function applyData(data) {
            const jobSeries = normalizeSeries(data.labels, data.jobPostCounts || []);

            revenueChart.data.labels = data.labels || jobSeries.labels;
            revenueChart.data.datasets = buildRevenueDatasets(data.revenueSeries || []);
            revenueChart.update();

            jobPostChart.data.labels = jobSeries.labels;
            jobPostChart.data.datasets[0].data = jobSeries.values;
            jobPostChart.update();

            const donutData = toDonutData(data.revenueByPlan || []);
            revenueDonut.data.labels = donutData.labels;
            revenueDonut.data.datasets[0].data = donutData.values;
            revenueDonut.update();
            renderDonutLegend(donutData.labels, donutData.values);

            document.getElementById('statRevenue').textContent = formatCurrency(data.totalRevenue ?? 0);
            document.getElementById('statJobPosts').textContent = data.totalJobPosts ?? 0;
        }

        async function fetchRange(from, to, label) {
            document.querySelectorAll('.dash-period-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('filterLabel').textContent = label ? `Đang xem: ${label}` : '';
            try {
                const res = await fetch(`/Manager/DashboardData?from=${from}&to=${to}`);
                if (!res.ok) { alert('Lỗi khi tải dữ liệu'); return; }
                const data = await res.json();
                applyData(data);
            } catch (e) {
                alert('Không thể tải dữ liệu');
            }
        }

        function applyMonthFilter() {
            const month = document.getElementById('filterMonth').value;
            const year = document.getElementById('filterYear').value;
            if (!month) { alert('Vui lòng chọn tháng'); return; }
            const from = `${year}-${String(month).padStart(2,'0')}-01`;
            const lastDay = new Date(year, month, 0).getDate();
            const to = `${year}-${String(month).padStart(2,'0')}-${lastDay}`;
            fetchRange(from, to, `Tháng ${month}/${year}`);
        }

        function applyRangeFilter() {
            const from = document.getElementById('filterFrom').value;
            const to = document.getElementById('filterTo').value;
            if (!from || !to) { alert('Vui lòng chọn cả từ tháng và đến tháng'); return; }
            const fromDate = from + '-01';
            const toParts = to.split('-');
            const lastDay = new Date(toParts[0], toParts[1], 0).getDate();
            const toDate = `${to}-${lastDay}`;
            if (fromDate > toDate) { alert('Từ tháng phải nhỏ hơn hoặc bằng đến tháng'); return; }
            fetchRange(fromDate, toDate, `${from.replace('-','/')} → ${to.replace('-','/')}`);
        }
    </script>
}
