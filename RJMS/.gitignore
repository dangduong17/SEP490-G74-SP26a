```gitignore
# Build output
bin/
obj/
out/
publish/
artifacts/

# User-specific files
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Visual Studio
.vs/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains Rider / ReSharper
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ASP.NET Core configuration (local only)
appsettings.Development.json
appsettings.Local.json
.env
.env.*

# Logs
logs/
*.log

# Test results / coverage
TestResults/
coverage/
coverage*.json
coverage*.xml
*.coverage
*.coveragexml

# Package folders
node_modules/
wwwroot/lib/

# Database files
*.mdf
*.ldf
*.ndf

# Azure publish profiles and deployment files
*.pubxml
*.publishproj
*.azurePubxml
*.publishsettings

# Certificates and secrets
*.pfx
*.snk
secrets.json

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Misc
*.tmp
*.temp
*.cache
*.nupkg

# Optional: keep if using local SQLite
# *.db
# *.db-shm
# *.db-wal
```
